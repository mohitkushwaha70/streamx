<%- include('partials/header', { pageTitle: 'Login with OTP' }) %>

<div class="auth-container">
  <div class="auth-box">
    <div class="logo">STREAM<span>X</span></div>
    <p class="subtitle">Login with a one-time password</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert" style="background:#00c85322;color:#00c853;border:1px solid #00c85344;"><%= success %></div><% } %>

    <form method="POST" action="/auth/otp/send">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" class="form-input" placeholder="you@example.com" required
               value="<%= email || '' %>">
      </div>
      <button type="submit" class="btn btn-primary btn-lg">SEND OTP</button>
    </form>

    <div class="auth-footer">
      <a href="/auth/login" style="color: var(--accent);">← Back to Sign In</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
