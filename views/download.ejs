<%- include('partials/header', { pageTitle: 'Download - ' + item.title }) %>
<%- include('partials/navbar', { active: '' }) %>

<style>
.dl-page { max-width: 900px; margin: 0 auto; padding: 40px 24px 80px; }
.dl-back { display: inline-flex; align-items: center; gap: 6px; color: var(--text-muted); text-decoration: none; font-size: 0.85rem; margin-bottom: 24px; transition: color 0.3s; }
.dl-back:hover { color: #fff; }
.dl-header { display: flex; gap: 24px; margin-bottom: 36px; }
.dl-poster { width: 200px; height: 300px; border-radius: 12px; overflow: hidden; flex-shrink: 0; background: #111; }
.dl-poster img { width: 100%; height: 100%; object-fit: cover; }
.dl-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.dl-info h1 { font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 8px; }
.dl-info .dl-meta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
.dl-info .dl-meta span { font-size: 0.85rem; color: var(--text-muted); }
.dl-info .dl-meta .rating { color: #f59e0b; font-weight: 700; }
.dl-info .dl-desc { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }

.dl-section { margin-bottom: 36px; }
.dl-section h2 { font-size: 1.2rem; font-weight: 700; color: #fff; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
.dl-section h2 svg { color: var(--blue-light); }

.quality-card { display: flex; align-items: center; justify-content: space-between; padding: 16px 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; margin-bottom: 10px; transition: all 0.3s; }
.quality-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(37,99,235,0.3); }
.quality-card.unavailable { opacity: 0.4; pointer-events: none; }
.q-info { display: flex; align-items: center; gap: 16px; }
.q-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.75rem; }
.q-icon.ultra { background: linear-gradient(135deg, #f59e0b, #f97316); color: #000; }
.q-icon.hd { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; }
.q-icon._720 { background: rgba(37,99,235,0.2); color: var(--blue-light); border: 1px solid rgba(37,99,235,0.3); }
.q-icon.sd { background: rgba(255,255,255,0.1); color: var(--text-muted); border: 1px solid rgba(255,255,255,0.15); }
.q-text h3 { font-size: 0.95rem; font-weight: 600; color: #fff; }
.q-text p { font-size: 0.8rem; color: var(--text-muted); margin-top: 2px; }
.q-actions { display: flex; gap: 10px; align-items: center; }
.q-size { font-size: 0.8rem; color: var(--text-muted); margin-right: 8px; }
.dl-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer; border: none; transition: all 0.3s; text-decoration: none; }
.dl-btn.primary { background: var(--blue-primary); color: #fff; }
.dl-btn.primary:hover { background: #2563eb; }
.dl-btn.outline { background: transparent; color: var(--text-secondary); border: 1px solid rgba(255,255,255,0.15); }
.dl-btn.outline:hover { border-color: rgba(255,255,255,0.3); color: #fff; }
.dl-btn.disabled { background: rgba(255,255,255,0.05); color: #555; cursor: not-allowed; pointer-events: none; }

.dl-notice { display: flex; gap: 12px; padding: 16px; background: rgba(37,99,235,0.08); border: 1px solid rgba(37,99,235,0.2); border-radius: 10px; margin-bottom: 32px; }
.dl-notice svg { flex-shrink: 0; color: var(--blue-light); margin-top: 2px; }
.dl-notice p { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }

.ep-dl-list { display: flex; flex-direction: column; gap: 6px; }
.ep-dl-item { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; transition: all 0.3s; }
.ep-dl-item:hover { background: rgba(255,255,255,0.06); }
.ep-dl-item .ep-num { font-weight: 700; color: var(--blue-light); font-size: 0.8rem; min-width: 40px; }
.ep-dl-item .ep-title { flex: 1; color: #fff; font-size: 0.85rem; margin: 0 12px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

@media (max-width: 600px) {
  .dl-header { flex-direction: column; align-items: center; text-align: center; }
  .dl-poster { width: 160px; height: 240px; }
  .quality-card { flex-direction: column; gap: 12px; align-items: flex-start; }
  .q-actions { width: 100%; justify-content: flex-end; }
}
</style>

<main class="main-content">
  <div class="dl-page">
    <a href="<%= type === 'movie' ? '/movies/' + item.id : '/series/' + item.id %>" class="dl-back">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Back to Details
    </a>

    <div class="dl-header">
      <div class="dl-poster">
        <img src="<%= item.poster %>" alt="<%= item.title %>">
      </div>
      <div class="dl-info">
        <h1><%= item.title %></h1>
        <div class="dl-meta">
          <span class="rating">★ <%= item.rating %></span>
          <span><%= item.year %></span>
          <span><%= item.genre %></span>
          <% if (item.duration) { %><span><%= item.duration %></span><% } %>
          <% if (item.premium) { %><span style="background:linear-gradient(135deg,#f59e0b,#f97316);color:#000;padding:2px 10px;border-radius:20px;font-size:0.75rem;font-weight:700;">PREMIUM</span><% } %>
        </div>
        <p class="dl-desc"><%= item.description %></p>
      </div>
    </div>

    <div class="dl-notice">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
      <p>Download quality depends on source availability. Some qualities may not be available for all content. Files are hosted on our secure servers.</p>
    </div>

    <div class="dl-section">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Options
      </h2>

      <% qualities.forEach(q => { %>
      <div class="quality-card <%= q.available ? '' : 'unavailable' %>">
        <div class="q-info">
          <div class="q-icon <%= q.tag %>"><%= q.resolution %></div>
          <div class="q-text">
            <h3><%= q.label %></h3>
            <p><%= q.resolution %> • <%= q.size %> • MP4</p>
          </div>
        </div>
        <div class="q-actions">
          <span class="q-size"><%= q.size %></span>
          <% if (q.available) { %>
          <a href="<%= q.url %>" download class="dl-btn primary" target="_blank">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
          <% } else { %>
          <button class="dl-btn disabled">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
            Not Available
          </button>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>

    <% if (type === 'series' && episodes.length > 0) { %>
    <div class="dl-section">
      <h2>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
        Episodes
      </h2>
      <div class="ep-dl-list">
        <% episodes.forEach(ep => { %>
        <div class="ep-dl-item">
          <span class="ep-num">E<%= ep.number %></span>
          <span class="ep-title"><%= ep.title %></span>
          <span style="font-size:0.75rem;color:var(--text-muted);"><%= ep.duration || '' %></span>
          <% if (ep.videoUrl) { %>
          <a href="<%= ep.videoUrl %>" download class="dl-btn outline" target="_blank" style="margin-left:12px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </a>
          <% } else { %>
          <button class="dl-btn disabled" style="margin-left:12px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
          </button>
          <% } %>
        </div>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
