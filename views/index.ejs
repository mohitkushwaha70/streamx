<%- include('partials/header', { pageTitle: 'Home' }) %>
<%- include('partials/navbar', { active: 'home' }) %>

<style>
.hero-slider { position: relative; width: 100%; height: 80vh; min-height: 500px; overflow: hidden; }
.hero-slide { position: absolute; inset: 0; opacity: 0; transition: opacity 0.8s ease; pointer-events: none; }
.hero-slide.active { opacity: 1; pointer-events: auto; }
.hero-slide .hero-bg { position: absolute; inset: 0; background-size: cover; background-position: center top; }
.hero-slide .hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.1) 100%), linear-gradient(to top, #0a0a0f 0%, transparent 30%); }
.hero-slide .hero-content { position: absolute; bottom: 80px; left: 48px; z-index: 2; max-width: 600px; }
@media (max-width: 768px) { .hero-slide .hero-content { left: 20px; right: 20px; bottom: 60px; max-width: none; } }
.hero-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.15); border-radius: 50%; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.3s; }
.hero-arrow:hover { background: rgba(37,99,235,0.7); border-color: rgba(37,99,235,0.8); }
.hero-prev { left: 20px; }
.hero-next { right: 20px; }
.hero-dots { position: absolute; bottom: 30px; left: 50%; transform: translateX(-50%); display: flex; gap: 10px; z-index: 10; }
.hero-dot { width: 12px; height: 12px; border-radius: 50%; background: rgba(255,255,255,0.3); border: none; cursor: pointer; transition: all 0.3s; }
.hero-dot.active { background: var(--blue-primary, #2563eb); transform: scale(1.3); }
@media (max-width: 768px) { .hero-slider { height: 60vh; min-height: 400px; } .hero-arrow { width: 36px; height: 36px; } }
.card-progress { position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: rgba(255,255,255,0.2); z-index: 5; }
.card-progress .progress-bar { height: 100%; background: var(--accent, #6c5ce7); border-radius: 2px; transition: width 0.3s; }
</style>

<main class="main-content">
  <!-- Hero Slider -->
  <section class="hero-slider">
    <% heroMovies.forEach((m, i) => { %>
    <div class="hero-slide <%= i === 0 ? 'active' : '' %>" data-index="<%= i %>">
      <div class="hero-bg" style="background-image: url('<%= m.backdrop || m.poster || '' %>')"></div>
      <div class="hero-content">
        <div class="hero-badge">
          <% if (m.premium) { %>⭐ PREMIUM<% } else { %>🔥 TRENDING<% } %>
        </div>
        <h1 class="hero-title"><%= m.title %></h1>
        <div class="hero-meta">
          <span class="rating">★ <%= m.rating %></span>
          <span><%= m.year %></span>
          <span><%= m.duration %></span>
          <span><%= m.genre %></span>
        </div>
        <p class="hero-desc"><%= m.description %></p>
        <div class="hero-actions">
          <% if (m.id) { %>
          <a href="/watch/movie/<%= m.id %>" class="btn btn-primary btn-lg">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            Watch Now
          </a>
          <% if (user) { %>
          <form action="/watchlist/add" method="POST" style="display:inline">
            <input type="hidden" name="id" value="<%= m.id %>">
            <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(255,255,255,0.1);border:1.5px solid rgba(255,255,255,0.3);box-shadow:none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
              Watchlist
            </button>
          </form>
          <% } %>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>

    <button class="hero-arrow hero-prev" onclick="heroSlide(-1)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="hero-arrow hero-next" onclick="heroSlide(1)">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M9 6l6 6-6 6"/></svg>
    </button>

    <div class="hero-dots">
      <% heroMovies.forEach((m, i) => { %>
      <button class="hero-dot <%= i === 0 ? 'active' : '' %>" onclick="heroGoTo(<%= i %>)"></button>
      <% }) %>
    </div>
  </section>

  <script>
  (function() {
    let current = 0;
    const slides = document.querySelectorAll('.hero-slide');
    const dots = document.querySelectorAll('.hero-dot');
    const total = slides.length;
    if (total <= 1) return;

    function showSlide(n) {
      slides.forEach(s => s.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      current = (n + total) % total;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    window.heroSlide = function(dir) { showSlide(current + dir); resetTimer(); };
    window.heroGoTo = function(i) { showSlide(i); resetTimer(); };

    let timer = setInterval(() => showSlide(current + 1), 5000);
    function resetTimer() { clearInterval(timer); timer = setInterval(() => showSlide(current + 1), 5000); }
  })();
  </script>

  <!-- Trending Now -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Trending <span class="accent">Now</span></h2>
      <a href="/movies" class="section-link">View All →</a>
    </div>
    <div class="content-row">
      <% trending.forEach(item => { %>
      <a href="/movies/<%= item.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= item.poster %>" alt="<%= item.title %>" loading="lazy">
          <span class="card-badge <%= item.badge === 'new' ? 'new' : item.premium ? 'premium' : '' %>"><%= item.badge === 'new' ? 'NEW' : item.premium ? '⭐ PREMIUM' : '' %></span>
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= item.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= item.rating %></span>
            <span class="dot"></span>
            <span><%= item.year %></span>
            <span class="dot"></span>
            <span><%= item.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>

  <% if (user && continueWatching.length > 0) { %>
  <!-- Continue Watching -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Continue <span class="accent">Watching</span></h2>
    </div>
    <div class="content-row">
      <% continueWatching.forEach(item => { %>
      <a href="/watch/<%= item.type === 'series' ? 'series' : 'movie' %>/<%= item.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= item.poster || '/placeholder.jpg' %>" alt="<%= item.title %>" loading="lazy">
          <div class="card-progress">
            <div class="progress-bar" style="width: <%= item.progress || 0 %>%"></div>
          </div>
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= item.title %></div>
          <div class="card-meta">
            <span><%= item.genre %></span>
            <span class="dot"></span>
            <span><%= item.progress || 0 %>% done</span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Top 10 -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Top 10 in <span class="accent">streamX</span></h2>
    </div>
    <div class="top10-list">
      <% top10.forEach((item, i) => { %>
      <a href="/movies/<%= item.id %>" class="top10-item">
        <span class="top10-number"><%= i + 1 %></span>
        <div class="top10-poster">
          <img src="<%= item.poster %>" alt="<%= item.title %>" loading="lazy">
        </div>
      </a>
      <% }) %>
    </div>
  </section>

  <!-- New Releases -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">New <span class="accent">Releases</span></h2>
      <a href="/movies?sort=year" class="section-link">View All →</a>
    </div>
    <div class="content-row">
      <% newReleases.forEach(item => { %>
      <a href="/movies/<%= item.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= item.poster %>" alt="<%= item.title %>" loading="lazy">
          <span class="card-badge new">NEW</span>
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= item.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= item.rating %></span>
            <span class="dot"></span>
            <span><%= item.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>

  <!-- Trending Series -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Trending <span class="accent">Series</span></h2>
      <a href="/series" class="section-link">View All →</a>
    </div>
    <div class="content-row">
      <% trendingSeries.forEach(item => { %>
      <a href="/series/<%= item.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= item.poster %>" alt="<%= item.title %>" loading="lazy">
          <span class="card-badge <%= item.premium ? 'premium' : item.badge === 'new' ? 'new' : '' %>"><%= item.premium ? '⭐ PREMIUM' : item.badge === 'new' ? 'NEW' : item.seasons + ' Seasons' %></span>
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= item.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= item.rating %></span>
            <span class="dot"></span>
            <span><%= item.seasons %> Season<%= item.seasons > 1 ? 's' : '' %></span>
            <span class="dot"></span>
            <span><%= item.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>

  <!-- Premium CTA -->
  <section class="section">
    <div class="premium-cta">
      <div class="premium-cta-content">
        <h2>Upgrade to <span class="accent">Premium</span></h2>
        <p>Get unlimited access to all movies, series, and exclusive originals in stunning 4K quality.</p>
        <a href="/pricing" class="btn btn-primary btn-lg">View Plans</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
