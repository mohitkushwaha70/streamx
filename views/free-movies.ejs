<%- include('partials/header', { pageTitle: title }) %>
<%- include('partials/navbar', { active: 'free-movies' }) %>

<style>
.free-hero { padding: 60px 24px 40px; text-align: center; background: linear-gradient(135deg, rgba(16,185,129,0.15) 0%, rgba(59,130,246,0.1) 100%); }
.free-hero h1 { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 8px; }
.free-hero p { color: var(--text-muted); font-size: 0.95rem; max-width: 500px; margin: 0 auto; }
.tab-bar { display: flex; gap: 8px; justify-content: center; margin: 24px auto; max-width: 400px; }
.tab-btn { flex: 1; padding: 12px 20px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: var(--text-muted); font-weight: 600; font-size: 0.85rem; cursor: pointer; text-decoration: none; text-align: center; transition: all 0.3s; }
.tab-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.tab-btn:hover { border-color: rgba(255,255,255,0.3); color: #fff; }
.filter-bar { display: flex; gap: 12px; justify-content: center; align-items: center; padding: 0 24px; margin-bottom: 24px; flex-wrap: wrap; }
.filter-bar input { padding: 10px 16px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #fff; font-size: 0.85rem; width: 300px; max-width: 100%; }
.filter-bar input::placeholder { color: var(--text-muted); }
.genre-pills { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; padding: 0 24px; margin-bottom: 32px; }
.genre-pill { padding: 6px 16px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: var(--text-muted); font-size: 0.8rem; text-decoration: none; transition: all 0.3s; }
.genre-pill.active, .genre-pill:hover { background: rgba(16,185,129,0.2); border-color: rgba(16,185,129,0.5); color: #10b981; }
.free-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; padding: 0 24px 60px; max-width: 1400px; margin: 0 auto; }
.free-card { border-radius: 12px; overflow: hidden; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); transition: all 0.3s; text-decoration: none; color: inherit; }
.free-card:hover { transform: translateY(-4px); border-color: rgba(16,185,129,0.4); }
.free-card .thumb { width: 100%; aspect-ratio: 16/9; overflow: hidden; position: relative; background: #111; }
.free-card .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
.free-card:hover .thumb img { transform: scale(1.05); }
.free-card .play-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.3); opacity: 0; transition: all 0.3s; }
.free-card:hover .play-overlay { opacity: 1; }
.free-card .play-circle { width: 56px; height: 56px; border-radius: 50%; background: rgba(16,185,129,0.9); display: flex; align-items: center; justify-content: center; }
.free-card .badge-free { position: absolute; top: 8px; left: 8px; background: rgba(16,185,129,0.9); color: #fff; font-size: 0.7rem; font-weight: 700; padding: 3px 10px; border-radius: 6px; }
.free-card .info { padding: 14px; }
.free-card .info h3 { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 6px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.free-card .info p { font-size: 0.75rem; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
.free-card .meta { display: flex; gap: 12px; margin-top: 8px; font-size: 0.75rem; color: var(--text-muted); }
.no-content { text-align: center; padding: 80px 24px; color: var(--text-muted); }
.no-content h3 { font-size: 1.2rem; margin-bottom: 8px; color: #fff; }
@media (max-width: 600px) {
  .free-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; padding: 0 16px 40px; }
  .free-card .info { padding: 10px; }
  .free-card .info h3 { font-size: 0.8rem; }
}
</style>

<section class="free-hero">
  <h1><%= tab === 'youtube' ? '▶' : '🎭' %> <%= title %></h1>
  <p><%= tab === 'youtube' ? 'YouTube pe available full movies — free me dekho!' : 'Archive.org ki public domain classics — legally free!' %></p>

  <div class="tab-bar">
    <a href="/free-movies?tab=archive" class="tab-btn <%= tab === 'archive' ? 'active' : '' %>">🎭 Public Domain</a>
    <a href="/free-movies?tab=youtube" class="tab-btn <%= tab === 'youtube' ? 'active' : '' %>">▶ YouTube</a>
  </div>
</section>

<div class="filter-bar">
  <form action="/free-movies" method="GET" style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;justify-content:center;width:100%;">
    <input type="hidden" name="tab" value="<%= tab %>">
    <input type="text" name="search" placeholder="Search movies..." value="<%= search %>">
    <button type="submit" class="btn btn-primary" style="padding: 10px 20px;">Search</button>
  </form>
</div>

<div class="genre-pills">
  <a href="/free-movies?tab=<%= tab %>" class="genre-pill <%= !genre ? 'active' : '' %>">All</a>
  <% genres.forEach(g => { %>
  <a href="/free-movies?tab=<%= tab %>&genre=<%= g %>" class="genre-pill <%= genre === g ? 'active' : '' %>"><%= g %></a>
  <% }) %>
</div>

<% if (movies.length === 0) { %>
<div class="no-content">
  <h3>No movies found</h3>
  <p>Try a different search or genre</p>
</div>
<% } else { %>
<div class="free-grid">
  <% movies.forEach(movie => { %>
  <a href="/free-movies/watch/<%= encodeURIComponent(movie.id) %>?source=<%= tab === 'youtube' ? 'youtube' : 'archive' %>&title=<%= encodeURIComponent(movie.title) %>" class="free-card">
    <div class="thumb">
      <img src="<%= movie.poster || movie.thumbnail || 'https://picsum.photos/seed/' + movie.id + '/400/225' %>" alt="<%= movie.title %>" loading="lazy" onerror="this.src='https://picsum.photos/seed/<%= movie.id %>/400/225'">
      <div class="play-overlay">
        <div class="play-circle">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </div>
      <span class="badge-free">FREE</span>
    </div>
    <div class="info">
      <h3><%= movie.title %></h3>
      <p><%= movie.description || '' %></p>
      <div class="meta">
        <% if (movie.year) { %><span><%= movie.year %></span><% } %>
        <% if (movie.genre) { %><span><%= movie.genre %></span><% } %>
        <% if (movie.runtime) { %><span><%= movie.runtime %></span><% } %>
        <% if (movie.channel) { %><span><%= movie.channel %></span><% } %>
        <% if (movie.downloads) { %><span><%= movie.downloads.toLocaleString() %> downloads</span><% } %>
      </div>
    </div>
  </a>
  <% }) %>
</div>
<% } %>

<%- include('partials/footer') %>
