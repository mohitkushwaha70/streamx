<%- include('../partials/header', { pageTitle: 'Analytics - STREAMX Admin' }) %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <div>
        <h1>Analytics</h1>
        <p style="color: var(--text-muted); font-size: 0.85rem;">Platform performance and content insights from TMDB</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></div>
        <div class="stat-info"><span class="stat-number"><%= totalViews.toLocaleString() %></span><span class="stat-label">Total Views</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg></div>
        <div class="stat-info"><span class="stat-number"><%= activeUsers %></span><span class="stat-label">Active Users</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <div class="stat-info"><span class="stat-number"><%= avgWatchTime %></span><span class="stat-label">Avg. Watch Time</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon gold"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
        <div class="stat-info"><span class="stat-number"><%= growthPercent %>%</span><span class="stat-label">Premium Ratio</span></div>
      </div>
    </div>

    <!-- Content Stats -->
    <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 20px;">
      <div class="stat-card">
        <div class="stat-icon blue">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= totalContent %></span>
          <span class="stat-label">Total Content</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= totalMovies %></span>
          <span class="stat-label">Movies</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= totalSeries %></span>
          <span class="stat-label">Series</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon gold">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number">★ <%= avgRating %></span>
          <span class="stat-label">Avg Rating</span>
        </div>
      </div>
    </div>

    <div class="admin-grid">
      <!-- Genre Breakdown -->
      <div class="admin-card">
        <div class="admin-card-header"><h3>Content by Genre</h3></div>
        <div style="padding: 20px;">
          <% if (genreBreakdown.length === 0) { %>
            <p style="color:#555;text-align:center;padding:20px;">No content available</p>
          <% } else { %>
            <% genreBreakdown.forEach(g => { %>
              <div class="genre-bar-row">
                <span class="genre-bar-name"><%= g.genre %></span>
                <div class="genre-bar-track">
                  <div class="genre-bar-fill" style="width: <%= g.percent %>%"></div>
                </div>
                <span class="genre-bar-count"><%= g.count %></span>
                <span class="genre-bar-pct"><%= g.percent %>%</span>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>

      <!-- Rating Distribution -->
      <div class="admin-card">
        <div class="admin-card-header"><h3>Rating Distribution</h3></div>
        <div style="padding: 20px;">
          <% const maxRating = Math.max(...Object.values(ratingDistribution), 1); %>
          <% Object.entries(ratingDistribution).forEach(([range, count]) => { %>
          <div class="rating-dist-row">
            <span class="rating-dist-label"><%= range %></span>
            <div class="rating-dist-bar-track">
              <div class="rating-dist-bar-fill" style="width: <%= (count / maxRating) * 100 %>%"></div>
            </div>
            <span class="rating-dist-count"><%= count %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Top Rated Content -->
    <div class="admin-card" style="margin-top: 20px;">
      <div class="admin-card-header"><h3>Top Rated Content</h3></div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead><tr><th>#</th><th>Title</th><th>Genre</th><th>Rating</th><th>Est. Views</th><th>Completion</th></tr></thead>
          <tbody>
            <% mostWatched.forEach((m, i) => { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= displayTitle(m.title) %></strong></td>
                <td><span class="table-badge"><%= m.genre %></span></td>
                <td style="color:#f59e0b;">★ <%= m.rating %></td>
                <td><%= m.views.toLocaleString() %></td>
                <td>
                  <div class="completion-bar">
                    <div class="completion-fill" style="width: <%= m.completion %>%"></div>
                    <span class="completion-text"><%= m.completion %>%</span>
                  </div>
                </td>
              </tr>
            <% }) %>
            <% if (mostWatched.length === 0) { %>
              <tr><td colspan="6" style="text-align:center;color:#555;">No content yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- User Growth Chart -->
    <div class="admin-card" style="margin-top: 20px;">
      <div class="admin-card-header"><h3>User Growth</h3></div>
      <div style="padding: 20px;">
        <% const maxGrowth = Math.max(...monthlyGrowth.map(m => m.users), 1); %>
        <div class="chart-bars" style="height: 180px;">
          <% monthlyGrowth.forEach(m => { %>
          <div class="chart-bar-col">
            <div class="chart-bar-wrapper">
              <div class="chart-bar blue-bar" style="height: <%= (m.users / maxGrowth) * 100 %>%">
                <span class="chart-bar-value"><%= m.users %></span>
              </div>
            </div>
            <span class="chart-bar-label"><%= m.month %></span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Platform Insights -->
    <div class="admin-grid" style="margin-top: 20px;">
      <div class="admin-card">
        <div class="admin-card-header"><h3>Platform Insights</h3></div>
        <div style="padding: 20px;">
          <div class="insight-row">
            <div class="insight-icon blue">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/></svg>
            </div>
            <div class="insight-content">
              <span class="insight-title">Movies vs Series</span>
              <span class="insight-value"><%= totalMovies %> movies, <%= totalSeries %> series</span>
            </div>
          </div>
          <div class="insight-row">
            <div class="insight-icon green">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>
            </div>
            <div class="insight-content">
              <span class="insight-title">Avg Rating</span>
              <span class="insight-value">★ <%= avgRating %> across all content</span>
            </div>
          </div>
          <div class="insight-row">
            <div class="insight-icon purple">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            </div>
            <div class="insight-content">
              <span class="insight-title">Genre Coverage</span>
              <span class="insight-value"><%= genreBreakdown.length %> genres available</span>
            </div>
          </div>
          <div class="insight-row">
            <div class="insight-icon gold">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            </div>
            <div class="insight-content">
              <span class="insight-title">User Engagement</span>
              <span class="insight-value"><%= activeUsers %> active users</span>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-card">
        <div class="admin-card-header"><h3>Top Genres</h3></div>
        <div style="padding: 20px;">
          <% topGenres.forEach((g, i) => { %>
          <div class="top-genre-row">
            <span class="top-genre-rank">#<%= i + 1 %></span>
            <span class="top-genre-name"><%= g.genre %></span>
            <div class="top-genre-bar-track">
              <div class="top-genre-bar-fill" style="width: <%= g.percent %>%"></div>
            </div>
            <span class="top-genre-count"><%= g.count %> titles</span>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>
</div>
