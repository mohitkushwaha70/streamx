<%- include('partials/header', { pageTitle: item.title }) %>
<%- include('partials/navbar', { active: type === 'movie' ? 'movies' : 'series' }) %>

<main class="main-content">
  <!-- Detail Hero -->
  <section class="detail-hero">
    <div class="hero-bg" style="background-image: url('<%= item.backdrop %>')"></div>
    <div class="hero-content detail-content">
      <div class="hero-badge">
        <% if (item.premium) { %>⭐ PREMIUM<% } else { %>🔥 <%= type === 'series' ? item.seasons + ' Season' + (item.seasons > 1 ? 's' : '') : item.duration %><% } %>
      </div>
      <h1 class="hero-title"><%= item.title %></h1>
      <div class="hero-meta">
        <span class="rating">★ <%= item.rating %></span>
        <span><%= item.year %></span>
        <span><%= item.genre %></span>
        <% if (item.cast) { %><span><%= item.cast %></span><% } %>
        <% if (item.director) { %><span>Dir: <%= item.director %></span><% } %>
      </div>
      <p class="hero-desc"><%= item.description %></p>
      <div class="hero-actions">
        <a href="/watch/<%= type %>/<%= item.id %>" class="btn btn-primary btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          Watch Now
        </a>
        <% if (user) { %>
        <form action="/watchlist/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(255,255,255,0.1);border:1.5px solid rgba(255,255,255,0.3);box-shadow:none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            Watchlist
          </button>
        </form>
        <form action="/watchlist/favorite/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(239,68,68,0.15);border:1.5px solid rgba(239,68,68,0.4);box-shadow:none;color:#ef4444;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Favorite
          </button>
        </form>
        <form action="/watchlist/saved/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(168,85,247,0.15);border:1.5px solid rgba(168,85,247,0.4);box-shadow:none;color:#a855f7;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/></svg>
            Save
          </button>
        </form>
        <a href="/download/<%= type %>/<%= item.id %>" class="btn btn-primary btn-lg" style="background:rgba(34,197,94,0.15);border:1.5px solid rgba(34,197,94,0.4);box-shadow:none;color:#22c55e;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
        <% } else { %>
        <button class="btn btn-primary btn-lg" style="background:rgba(255,255,255,0.1);border:1.5px solid rgba(255,255,255,0.3);box-shadow:none;" onclick="document.getElementById('authModal') && document.getElementById('authModal').classList.add('active')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          Watchlist
        </button>
        <a href="/download/<%= type %>/<%= item.id %>" class="btn btn-primary btn-lg" style="background:rgba(34,197,94,0.15);border:1.5px solid rgba(34,197,94,0.4);box-shadow:none;color:#22c55e;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download
        </a>
        <% } %>
      </div>
    </div>
  </section>

  <!-- Where to Watch -->
  <% 
    const hasSub = streaming && streaming.subscription && streaming.subscription.length > 0;
    const hasFree = streaming && streaming.free && streaming.free.length > 0;
    const hasRent = streaming && streaming.rent && streaming.rent.length > 0;
    const hasBuy = streaming && streaming.buy && streaming.buy.length > 0;
  %>
  <% if (hasSub || hasFree || hasRent || hasBuy) { %>
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Where to <span class="accent">Watch</span></h2>
    </div>
    <div style="padding: 0 24px;">
      <% if (hasSub) { %>
      <div style="margin-bottom: 20px;">
        <h3 style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Stream (Subscription)</h3>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <% streaming.subscription.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 180px;" onmouseover="this.style.borderColor='<%= getSourceColor(s.name) %>';this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.06)'">
            <% if (s.logo) { %>
            <img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 32px; height: 32px; border-radius: 6px; object-fit: contain;">
            <% } else { %>
            <span style="font-size: 1.5rem;"><%= getSourceIcon(s.name) %></span>
            <% } %>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;"><%= s.name %></div>
              <div style="font-size: 0.75rem; color: #4ade80;">Stream Now</div>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (hasFree) { %>
      <div style="margin-bottom: 20px;">
        <h3 style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Watch Free</h3>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <% streaming.free.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 180px;" onmouseover="this.style.borderColor='#4ade80';this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.06)'">
            <% if (s.logo) { %>
            <img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 32px; height: 32px; border-radius: 6px; object-fit: contain;">
            <% } else { %>
            <span style="font-size: 1.5rem;"><%= getSourceIcon(s.name) %></span>
            <% } %>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;"><%= s.name %></div>
              <div style="font-size: 0.75rem; color: #4ade80;">Free</div>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (hasRent) { %>
      <div style="margin-bottom: 20px;">
        <h3 style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Rent</h3>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <% streaming.rent.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 180px;" onmouseover="this.style.borderColor='#f59e0b';this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.06)'">
            <% if (s.logo) { %>
            <img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 32px; height: 32px; border-radius: 6px; object-fit: contain;">
            <% } else { %>
            <span style="font-size: 1.5rem;"><%= getSourceIcon(s.name) %></span>
            <% } %>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;"><%= s.name %></div>
              <div style="font-size: 0.75rem; color: #f59e0b;">Rent<%= s.price ? ' - ₹' + s.price : '' %></div>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (hasBuy) { %>
      <div style="margin-bottom: 20px;">
        <h3 style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px;">Buy</h3>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <% streaming.buy.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 20px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 180px;" onmouseover="this.style.borderColor='#3b82f6';this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.06)'">
            <% if (s.logo) { %>
            <img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 32px; height: 32px; border-radius: 6px; object-fit: contain;">
            <% } else { %>
            <span style="font-size: 1.5rem;"><%= getSourceIcon(s.name) %></span>
            <% } %>
            <div>
              <div style="font-weight: 600; font-size: 0.9rem;"><%= s.name %></div>
              <div style="font-size: 0.75rem; color: #3b82f6;">Buy<%= s.price ? ' - ₹' + s.price : '' %></div>
            </div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>
  </section>
  <% } %>

  <% if (item.episodes && item.episodes.length > 0) { %>
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Episodes</h2>
      <% if (item.seasonsList && item.seasonsList.length > 1) { %>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <% item.seasonsList.filter(s => s.season_number > 0).forEach(s => { %>
        <a href="/series/<%= item.id %>?season=<%= s.season_number %>" class="btn btn-sm btn-outline" style="<%= (typeof currentSeason !== 'undefined' && currentSeason === s.season_number) ? 'background:var(--accent);color:#fff;' : '' %>">
          Season <%= s.season_number %>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
    <div class="episodes-list">
      <% item.episodes.forEach(ep => { %>
      <a href="/watch/series/<%= item.id %>?ep=<%= ep.number %><%= typeof currentSeason !== 'undefined' ? '&season=' + currentSeason : '' %>" class="episode-card">
        <% if (ep.poster) { %>
        <div style="width:120px;height:68px;border-radius:6px;overflow:hidden;flex-shrink:0;">
          <img src="<%= ep.poster %>" alt="<%= ep.title %>" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
        </div>
        <% } %>
        <div class="ep-number"><%= ep.number %></div>
        <div class="ep-info">
          <h4><%= ep.title %></h4>
          <p><%= ep.description %></p>
        </div>
        <div class="ep-duration"><%= ep.duration %></div>
        <div class="ep-play">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Related -->
  <% if (related.length > 0) { %>
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">You May Also <span class="accent">Like</span></h2>
    </div>
    <div class="content-grid">
      <% related.forEach(r => { %>
      <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= r.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= r.rating %></span>
            <span class="dot"></span>
            <span><%= r.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>
