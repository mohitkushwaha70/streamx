/* ========================================
   COMMENTS (localStorage)
   ======================================== */
var CK='sx_comments_<%=item.id%>';
function loadComments(){
  try{var cs=JSON.parse(localStorage.getItem(CK)||'[]');}catch(e){var cs=[];}
  var el=document.getElementById('commentList');el.innerHTML='';
  document.getElementById('commentCount').textContent=cs.length>0?'('+cs.length+')':'';
  if(cs.length===0){el.innerHTML='<div class="sx-no-comments">Be the first to comment</div>';return;}
  cs.reverse().forEach(function(c,idx){
    el.innerHTML+='<div class="sx-comment"><div class="sx-comment-avatar" style="background:linear-gradient(135deg,'+(c.color||'var(--blue)')+')">'+c.name.charAt(0).toUpperCase()+'</div><div class="sx-comment-body"><div class="sx-comment-meta"><span class="sx-comment-name">'+c.name+'</span><span class="sx-comment-time">'+c.time+'</span></div><div class="sx-comment-text">'+c.text.replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</div><div class="sx-comment-actions"><button class="sx-comment-action" onclick="likeComment('+idx+')">&#128077; '+((c.likes)||0)+'</button><% if(user){ %><button class="sx-comment-action sx-comment-delete" onclick="deleteComment('+idx+')">Delete</button><%}%></div></div></div>';
  });
}
function postComment(){
  var inp=document.getElementById('commentInput');var text=inp.value.trim();if(!text)return;
  try{var cs=JSON.parse(localStorage.getItem(CK)||'[]');}catch(e){var cs=[];}
  var colors=['#ff003c','#3B82F6','#8B5CF6','#EC4899','#F59E0B','#10B981'];
  cs.push({name:'<%=user ? user.name.replace(/'/g,"\\'") : "Guest"%>',text:text,time:'Just now',likes:0,color:colors[Math.floor(Math.random()*colors.length)]});
  localStorage.setItem(CK,JSON.stringify(cs));inp.value='';loadComments();
}
function likeComment(idx){try{var cs=JSON.parse(localStorage.getItem(CK)||'[]');}catch(e){return;}var ri=cs.length-1-idx;if(cs[ri]){cs[ri].likes=(cs[ri].likes||0)+1;localStorage.setItem(CK,JSON.stringify(cs));loadComments();}}
function deleteComment(idx){try{var cs=JSON.parse(localStorage.getItem(CK)||'[]');}catch(e){return;}var ri=cs.length-1-idx;cs.splice(ri,1);localStorage.setItem(CK,JSON.stringify(cs));loadComments();}
loadComments();

/* ========================================
   ARTPLAYER INIT
