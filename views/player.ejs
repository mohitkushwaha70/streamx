<%- include('partials/header', { pageTitle: displayTitle(item.title) + ' - StreamX' }) %>
<%- include('partials/navbar', { active: '' }) %>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#050505;--bg2:#0a0a10;--bg3:#12121a;--bg4:#1a1a26;
  --text:#fff;--text2:rgba(255,255,255,.72);--text3:rgba(255,255,255,.40);
  --accent:#E50914;--accent-hover:#f6121d;
  --blue:#3b82f6;--gold:#f5c518;--green:#22c55e;--purple:#a855f7;
  --radius:16px;--radius-sm:10px;--max-w:1600px;--gap:28px;
  --ease:cubic-bezier(.4,0,.2,1);--ease-out:cubic-bezier(0,0,.2,1);
  --font:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;
}
.sx-watch{background:var(--bg);min-height:100vh;position:relative;overflow-x:hidden;font-family:var(--font);color:var(--text)}
.sx-backdrop{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:url('<%= item.backdrop || item.poster %>');background-size:cover;background-position:center 15%;filter:blur(80px) brightness(.08) saturate(1.3);transform:scale(1.3)}
.sx-backdrop::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(5,5,5,.2) 0%,rgba(5,5,5,.5) 40%,var(--bg) 100%)}
.sx-wrap{position:relative;z-index:1;max-width:var(--max-w);margin:0 auto;padding:0 var(--gap)}

@keyframes sxFadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes sxSlideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes sxScaleIn{from{opacity:0;transform:scale(.95)}to{opacity:1;transform:scale(1)}}
@keyframes sxPulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes art-loading{to{transform:rotate(360deg)}}
@keyframes sxSpin{to{transform:rotate(360deg)}}

/* ========================================
   PLAYER CONTAINER
   ======================================== */
.sx-hero{display:flex;gap:var(--gap);padding-top:20px;animation:sxFadeIn .5s var(--ease)}
.sx-player{flex:1;min-width:0;position:relative}
.sx-player-box{position:relative;width:100%;aspect-ratio:16/9;background:#000;border-radius:var(--radius);overflow:hidden;box-shadow:0 16px 80px rgba(0,0,0,.8);cursor:pointer}
#artplayer-app{width:100%;height:100%}
.art-top,.art-control-top,.art-settings,.art-info,.art-mask,.art-tip,.art-notice,.art-setting,.art-control-progress-tip,.art-bottom{display:none!important}
.art-state{position:absolute!important;top:50%!important;left:50%!important;transform:translate(-50%,-50%)!important;z-index:50!important;pointer-events:none!important}
.art-state svg{filter:drop-shadow(0 4px 20px rgba(0,0,0,.6))}

/* ========================================
   CONTROLS OVERLAY
   ======================================== */
.sx-controls{position:absolute;bottom:0;left:0;right:0;z-index:100;display:flex;flex-direction:column;opacity:0;transition:opacity .25s var(--ease);pointer-events:none}
.sx-player-box:hover .sx-controls,.sx-player-box.sx-visible .sx-controls{opacity:1;pointer-events:auto}
.sx-player-box.sx-visible .sx-skip-btn.show,.sx-player-box.sx-visible .sx-next-popup.show{opacity:1;pointer-events:auto}

/* Gradient scrim */
.sx-scrim{position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.9) 0%,rgba(0,0,0,.5) 30%,transparent 65%);pointer-events:none}

/* Mini progress (visible when controls hidden) */
.sx-mini-bar{position:absolute;bottom:0;left:0;right:0;height:3px;background:rgba(255,255,255,.08);z-index:99;cursor:pointer;border-radius:0 0 var(--radius) var(--radius);overflow:hidden;transition:opacity .25s}
.sx-player-box.sx-visible .sx-mini-bar{opacity:0}
.sx-mini-fill{height:100%;background:var(--accent);width:0;transition:width .3s linear}

/* ========================================
   PROGRESS BAR
   ======================================== */
.sx-progress-wrap{position:relative;padding:0 12px;pointer-events:auto;cursor:pointer}
.sx-progress{width:100%;height:4px;background:rgba(255,255,255,.15);border-radius:4px;position:relative;transition:height .15s var(--ease)}
.sx-progress-wrap:hover .sx-progress{height:6px}
.sx-progress-buffer{position:absolute;top:0;left:0;height:100%;background:rgba(255,255,255,.2);border-radius:4px;pointer-events:none;transition:width .4s linear}
.sx-progress-played{position:absolute;top:0;left:0;height:100%;background:var(--accent);border-radius:4px;pointer-events:none;transition:width .1s linear;box-shadow:0 0 8px rgba(229,9,20,.4)}
.sx-progress-handle{position:absolute;top:50%;width:14px;height:14px;background:var(--accent);border-radius:50%;transform:translate(-50%,-50%) scale(0);pointer-events:none;z-index:5;box-shadow:0 0 12px rgba(229,9,20,.5);transition:transform .12s var(--ease)}
.sx-progress-wrap:hover .sx-progress-handle{transform:translate(-50%,-50%) scale(1)}
.sx-progress-time{position:absolute;bottom:calc(100% + 10px);transform:translateX(-50%);padding:5px 10px;border-radius:8px;background:rgba(0,0,0,.9);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.06);box-shadow:0 8px 32px rgba(0,0,0,.6);display:none;pointer-events:none;z-index:10;font-size:.72rem;font-weight:600;color:#fff;font-variant-numeric:tabular-nums;white-space:nowrap}
.sx-progress-wrap:hover .sx-progress-time{display:block}

/* ========================================
   BOTTOM CONTROLS ROW
   ======================================== */
.sx-ctrl-row{display:flex;align-items:center;height:44px;padding:0 8px;pointer-events:auto;position:relative;z-index:101}
.sx-ctrl-btn{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border:none;background:none;color:rgba(255,255,255,.9);cursor:pointer;border-radius:10px;transition:background .15s,color .15s;position:relative;flex-shrink:0}
.sx-ctrl-btn:hover{background:rgba(255,255,255,.1);color:#fff}
.sx-ctrl-btn:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
.sx-ctrl-btn svg{width:22px;height:22px;fill:currentColor;flex-shrink:0}
.sx-ctrl-btn.sx-active svg{color:var(--accent)}
.sx-ctrl-spacer{flex:1;pointer-events:none}

/* Tooltip */
.sx-ctrl-btn[aria-label]{position:relative}
.sx-ctrl-btn[aria-label]::after{content:attr(aria-label);position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%) translateY(4px);background:rgba(0,0,0,.92);backdrop-filter:blur(12px);color:#fff;font-size:.68rem;font-weight:500;padding:5px 10px;border-radius:6px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .15s,transform .15s;border:1px solid rgba(255,255,255,.06);z-index:200}
.sx-ctrl-btn[aria-label]:hover::after{opacity:1;transform:translateX(-50%) translateY(0)}

/* Time display */
.sx-time-display{font-size:13px;font-weight:500;color:rgba(255,255,255,.8);padding:0 10px;white-space:nowrap;font-variant-numeric:tabular-nums;letter-spacing:.02em;user-select:none;cursor:default}

/* ========================================
   VOLUME CONTROL
   ======================================== */
.sx-volume-group{display:flex;align-items:center}
.sx-volume-slider{width:0;overflow:hidden;transition:width .25s var(--ease);display:flex;align-items:center}
.sx-volume-group:hover .sx-volume-slider,.sx-volume-group.sx-vol-active .sx-volume-slider{width:80px}
.sx-volume-track{width:100%;height:3px;background:rgba(255,255,255,.15);border-radius:3px;cursor:pointer;position:relative;transition:height .15s}
.sx-volume-track:hover{height:5px}
.sx-volume-fill{height:100%;background:var(--accent);border-radius:3px;width:70%}
.sx-volume-dot{width:12px;height:12px;background:#fff;border-radius:50%;position:absolute;top:50%;transform:translate(-50%,-50%);box-shadow:0 0 6px rgba(0,0,0,.5);opacity:0;transition:opacity .15s;left:70%}
.sx-volume-track:hover .sx-volume-dot{opacity:1}

/* ========================================
   SPEED / QUALITY POPUP MENUS
   ======================================== */
.sx-menu{position:absolute;bottom:52px;right:8px;z-index:300;background:rgba(12,12,20,.95);backdrop-filter:blur(40px) saturate(180%);border:1px solid rgba(255,255,255,.08);border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,.8);padding:6px 0;min-width:200px;display:none;animation:sxScaleIn .18s var(--ease)}
.sx-menu.open{display:block}
.sx-menu-header{display:flex;align-items:center;gap:8px;padding:10px 16px;color:rgba(255,255,255,.5);font-size:.72rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;cursor:pointer}
.sx-menu-header:hover{color:rgba(255,255,255,.7)}
.sx-menu-header svg{width:14px;height:14px}
.sx-menu-divider{height:1px;background:rgba(255,255,255,.06);margin:3px 12px}
.sx-menu-item{display:flex;align-items:center;justify-content:space-between;padding:9px 16px;color:rgba(255,255,255,.7);font-size:.82rem;cursor:pointer;transition:background .12s;user-select:none}
.sx-menu-item:hover{background:rgba(255,255,255,.05)}
.sx-menu-item.sx-active{color:var(--accent);font-weight:600}
.sx-menu-check{width:16px;height:16px;display:flex;align-items:center;justify-content:center}

/* ========================================
   SKIP / NEXT EPISODE
   ======================================== */
.sx-skip-btn{position:absolute;bottom:72px;right:20px;z-index:150;background:rgba(255,255,255,.08);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.1);color:#fff;padding:10px 28px;border-radius:10px;font-size:.85rem;font-weight:600;cursor:pointer;display:none;font-family:var(--font);transition:all .2s var(--ease);letter-spacing:.01em}
.sx-skip-btn:hover{background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.18)}
.sx-skip-btn.show{display:block;animation:sxSlideUp .25s var(--ease)}

.sx-next-popup{position:absolute;bottom:72px;right:20px;z-index:150;background:rgba(8,8,16,.94);backdrop-filter:blur(28px);border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:14px;display:none;gap:12px;width:340px;cursor:pointer;transition:border-color .2s}
.sx-next-popup:hover{border-color:rgba(229,9,20,.3)}
.sx-next-popup.show{display:flex;animation:sxSlideUp .25s var(--ease)}
.sx-np-thumb{width:128px;height:72px;border-radius:10px;overflow:hidden;flex-shrink:0;position:relative;background:var(--bg3)}
.sx-np-thumb img{width:100%;height:100%;object-fit:cover}
.sx-np-play-icon{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:36px;height:36px;background:rgba(0,0,0,.5);border-radius:50%;display:flex;align-items:center;justify-content:center;border:1px solid rgba(255,255,255,.15)}
.sx-np-play-icon svg{width:16px;height:16px;fill:#fff}
.sx-np-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center}
.sx-np-label{font-size:.6rem;color:var(--accent);font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
.sx-np-title{font-size:.85rem;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.sx-np-sub{font-size:.7rem;color:var(--text3)}
.sx-np-toggle{display:flex;align-items:center;gap:8px;margin-top:6px}
.sx-np-toggle label{font-size:.68rem;color:var(--text3);cursor:pointer}
.sx-toggle{width:36px;height:20px;border-radius:10px;position:relative;background:rgba(255,255,255,.12);transition:background .2s var(--ease);cursor:pointer;flex-shrink:0}
.sx-toggle.on{background:var(--accent)}
.sx-toggle::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform .2s var(--ease);box-shadow:0 1px 4px rgba(0,0,0,.3)}
.sx-toggle.on::after{transform:translateX(16px)}
.sx-np-close{position:absolute;top:8px;right:8px;cursor:pointer;opacity:.5;transition:opacity .15s}
.sx-np-close:hover{opacity:1}

/* ========================================
   NOTICE TOAST
   ======================================== */
.sx-toast{position:absolute;top:16px;left:50%;transform:translateX(-50%);z-index:200;background:rgba(0,0,0,.85);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:8px 20px;color:#fff;font-size:.8rem;font-weight:500;animation:sxSlideUp .2s var(--ease);pointer-events:none;box-shadow:0 4px 20px rgba(0,0,0,.4)}

/* ========================================
   SIDEBAR
   ======================================== */
.sx-sidebar{display:none!important}
.sx-sidebar::-webkit-scrollbar{width:4px}
.sx-sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.06);border-radius:2px}
.sx-side-section{background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.05);border-radius:14px;padding:16px;backdrop-filter:blur(12px)}
.sx-side-title{font-size:.82rem;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.sx-side-title svg{width:16px;height:16px;color:var(--accent)}
.sx-sc{display:flex;gap:10px;padding:8px;border-radius:10px;cursor:pointer;transition:background .2s;text-decoration:none;color:inherit}
.sx-sc:hover{background:rgba(255,255,255,.06)}
.sx-sc.active{background:rgba(229,9,20,.06)}
.sx-sc-thumb{width:100px;height:56px;border-radius:8px;overflow:hidden;flex-shrink:0;position:relative;background:var(--bg3)}
.sx-sc-thumb img{width:100%;height:100%;object-fit:cover}
.sx-sc-num{position:absolute;bottom:4px;left:4px;background:rgba(0,0,0,.85);color:#fff;font-size:.62rem;font-weight:700;padding:1px 6px;border-radius:3px}
.sx-sc-live{position:absolute;top:4px;right:4px;background:var(--accent);color:#fff;font-size:.58rem;font-weight:700;padding:1px 5px;border-radius:3px}
.sx-sc-info{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center}
.sx-sc-info h4{font-size:.82rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.sx-sc-info p{font-size:.72rem;color:var(--text3)}

/* ========================================
   INFO SECTION
   ======================================== */
.sx-info{padding:32px 0 0}
.sx-title{font-size:2.4rem;font-weight:800;color:#fff;line-height:1.15;margin-bottom:14px;letter-spacing:-.01em}
.sx-title .sx-ep{font-size:.55em;font-weight:500;color:var(--text3)}
.sx-badges{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.sx-badge{display:inline-flex;align-items:center;gap:4px;padding:4px 11px;border-radius:var(--radius-sm);font-size:.75rem;font-weight:600;background:rgba(255,255,255,.04);color:var(--text2);border:1px solid rgba(255,255,255,.05)}
.sx-badge.gold{color:var(--gold);background:rgba(245,197,24,.08);border-color:rgba(245,197,24,.12)}
.sx-badge.red{background:rgba(229,9,20,.08);color:#ff4455;border-color:rgba(229,9,20,.12)}
.sx-badge.blue{background:rgba(59,130,246,.07);color:#60a5fa;border-color:rgba(59,130,246,.1)}
.sx-badge.purple{background:rgba(168,85,247,.08);color:#c084fc;border-color:rgba(168,85,247,.1)}
.sx-badge.prem{background:linear-gradient(135deg,#f59e0b,#f97316);color:#000;border:none;font-weight:700}
.sx-badge.green{background:rgba(34,197,94,.08);color:var(--green);border-color:rgba(34,197,94,.1)}
.sx-desc{color:var(--text2);font-size:.92rem;line-height:1.75;max-width:820px;margin-bottom:10px;max-height:4.4em;overflow:hidden;transition:max-height .35s var(--ease)}
.sx-desc.open{max-height:600px}
.sx-desc-btn{color:var(--accent);cursor:pointer;font-size:.85rem;font-weight:500;background:none;border:none;padding:0;font-family:var(--font);margin-bottom:20px}

/* Action buttons */
.sx-acts{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:6px}
.sx-act{display:inline-flex;align-items:center;gap:7px;padding:11px 24px;border-radius:var(--radius-sm);font-size:.88rem;font-weight:600;cursor:pointer;border:none;transition:none;font-family:var(--font);color:#fff;text-decoration:none}
.sx-act.primary{background:var(--accent);box-shadow:0 4px 24px rgba(229,9,20,.3)}
.sx-act.primary:hover{transform:translateY(-2px);box-shadow:0 6px 32px rgba(229,9,20,.5)}
.sx-act.glass{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.07)}
.sx-act.glass:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.12);transform:translateY(-1px)}
.sx-like-count{font-size:11px;background:rgba(255,255,255,.1);padding:1px 6px;border-radius:10px;margin-left:2px;font-weight:600}
.sx-act svg{width:17px;height:17px;flex-shrink:0}

/* ========================================
   ABOUT SECTION
   ======================================== */
.sx-about{margin-top:32px;padding:28px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.04);border-radius:var(--radius);backdrop-filter:blur(8px)}
.sx-about h2{font-size:1.1rem;font-weight:700;color:#fff;margin-bottom:18px;display:flex;align-items:center;gap:8px}
.sx-about h2 svg{width:20px;height:20px;color:var(--accent)}
.sx-about-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0}
.sx-about-row{display:flex;flex-direction:column;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.03)}
.sx-about-label{font-size:.7rem;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.sx-about-val{font-size:.88rem;color:var(--text2);font-weight:500}

/* ========================================
   CAST SECTION
   ======================================== */
.sx-cast-section{margin-top:32px}
.sx-cast-scroll{display:flex;gap:20px;overflow-x:auto;padding-bottom:8px;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.05) transparent}
.sx-cast-scroll::-webkit-scrollbar{height:3px}
.sx-cast-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.05);border-radius:2px}
.sx-cast-item{display:flex;flex-direction:column;align-items:center;gap:8px;min-width:80px;transition:transform .2s}
.sx-cast-item:hover{transform:translateY(-3px)}
.sx-cast-avatar{width:64px;height:64px;border-radius:50%;overflow:hidden;border:2px solid rgba(255,255,255,.06);background:var(--bg3);transition:border-color .2s}
.sx-cast-item:hover .sx-cast-avatar{border-color:rgba(229,9,20,.25)}
.sx-cast-initial{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700;color:rgba(255,255,255,.5);background:linear-gradient(135deg,var(--bg3),var(--bg4))}
.sx-cast-name{font-size:.72rem;font-weight:600;color:var(--text2);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;width:80px}
.sx-cast-char{font-size:.65rem;color:var(--text3);text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;width:80px}

/* ========================================
   CONTENT SECTIONS
   ======================================== */
.sx-sections{padding:32px 0 20px}
.sx-sec{margin-bottom:36px}
.sx-sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.sx-sec-hdr h2{font-size:1.2rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px}
.sx-sec-hdr h2 svg{width:20px;height:20px;color:var(--accent)}
.sx-scroll{display:flex;gap:12px;overflow-x:auto;padding-bottom:6px;scroll-behavior:smooth;-webkit-overflow-scrolling:touch;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.05) transparent}
.sx-scroll::-webkit-scrollbar{height:3px}
.sx-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.05);border-radius:2px}
.sx-card{flex-shrink:0;text-decoration:none;color:inherit;transition:transform .3s var(--ease)}
.sx-card:hover{transform:scale(1.05) translateY(-4px);z-index:5}
.sx-card-post{position:relative;width:180px;height:264px;border-radius:14px;overflow:hidden;background:var(--bg3);box-shadow:0 4px 16px rgba(0,0,0,.3);transition:box-shadow .3s}
.sx-card:hover .sx-card-post{box-shadow:0 8px 40px rgba(0,0,0,.6),0 0 0 2px rgba(229,9,20,.12)}
.sx-card-post img{width:100%;height:100%;object-fit:cover;transition:transform .4s var(--ease)}
.sx-card:hover .sx-card-post img{transform:scale(1.08)}
.sx-card-glass{position:absolute;inset:0;background:linear-gradient(180deg,transparent 30%,rgba(0,0,0,.8) 100%);opacity:0;transition:opacity .3s}
.sx-card:hover .sx-card-glass{opacity:1}
.sx-card-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:48px;height:48px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;opacity:0;transition:all .3s var(--ease);box-shadow:0 4px 24px rgba(229,9,20,.4)}
.sx-card:hover .sx-card-play{opacity:1;transform:translate(-50%,-50%) scale(1.05)}
.sx-card-play svg{width:22px;height:22px;fill:#fff;margin-left:2px}
.sx-card-info{padding:8px 2px 0}
.sx-card-title{font-size:.82rem;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.sx-card-meta{font-size:.72rem;color:var(--text3);display:flex;align-items:center;gap:5px}
.sx-card-meta .sx-cr{color:var(--gold);font-weight:600}

/* ========================================
   COMMENTS
   ======================================== */


/* ========================================
   FOOTER (override for player dark bg)
   ======================================== */
.footer{position:relative;z-index:2;background:var(--bg2);border-top:1px solid rgba(255,255,255,.06)}
.footer-bottom{border-top:1px solid rgba(255,255,255,.06)}

/* ========================================
   RESPONSIVE
   ======================================== */
@media(max-width:1200px){.sx-sidebar{width:300px}.sx-card-post{width:160px;height:236px}}
@media(max-width:1024px){:root{--gap:20px}.sx-hero{flex-direction:column}.sx-sidebar{width:100%;max-height:none;position:static;flex-direction:row;flex-wrap:wrap;gap:12px}.sx-side-section{flex:1;min-width:250px}.sx-title{font-size:2rem}.sx-card-post{width:150px;height:222px}}
@media(max-width:768px){:root{--gap:14px}.sx-title{font-size:1.5rem}.sx-acts{gap:8px}.sx-act{padding:9px 16px;font-size:.82rem}.sx-card-post{width:130px;height:192px;border-radius:12px}.sx-ctrl-row{height:40px}.sx-ctrl-btn{width:32px;height:32px}.sx-ctrl-btn svg{width:20px;height:20px}.sx-time-display{font-size:11px;padding:0 6px}.sx-volume-slider{display:none!important}.sx-sidebar{flex-direction:column}.sx-side-section{min-width:auto}.sx-about-grid{grid-template-columns:1fr}}
@media(max-width:480px){.sx-title{font-size:1.3rem}.sx-act{padding:8px 12px;font-size:.78rem;border-radius:8px}.sx-card-post{width:115px;height:170px}.sx-badges{gap:5px}.sx-badge{padding:3px 7px;font-size:.7rem}.sx-about{padding:20px}.sx-ctrl-btn{width:30px;height:30px}.sx-ctrl-btn svg{width:18px;height:18px}.sx-next-popup{width:280px;padding:10px}.sx-np-thumb{width:100px;height:56px}}
</style>

<main class="sx-watch">
  <div class="sx-backdrop"></div>
  <div class="sx-wrap">

    <!-- ============ PLAYER HERO ============ -->
    <div class="sx-hero">
      <div class="sx-player">
        <div class="sx-player-box" id="pBox">
          <div id="artplayer-app"></div>

          <!-- Mini progress (visible when controls hidden) -->
          <div class="sx-mini-bar"><div class="sx-mini-fill" id="mFill"></div></div>

          <!-- Skip Intro / Recap -->
          <button class="sx-skip-btn" id="skipBtn" aria-label="Skip Intro">Skip Intro</button>

          <!-- Next Episode popup -->
          <div class="sx-next-popup" id="nextPop">
            <div class="sx-np-close" onclick="event.stopPropagation();document.getElementById('nextPop').classList.remove('show')">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </div>
            <div class="sx-np-thumb"><img id="npImg" src="" alt=""><div class="sx-np-play-icon"><svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div></div>
            <div class="sx-np-info">
              <div class="sx-np-label">Up Next</div>
              <div class="sx-np-title" id="npTitle"></div>
              <div class="sx-np-sub" id="npSub"></div>
              <div class="sx-np-sub" id="npTimer"></div>
              <div class="sx-np-toggle">
                <div class="sx-toggle on" id="autoPlayTog" onclick="event.stopPropagation();state.autoNext=!state.autoNext;this.classList.toggle('on')"></div>
                <label onclick="event.stopPropagation()">Auto Play</label>
              </div>
            </div>
          </div>

          <!-- Controls overlay -->
          <div class="sx-controls" id="controls">
            <div class="sx-scrim"></div>

            <!-- Progress bar -->
            <div class="sx-progress-wrap" id="progressWrap">
              <div class="sx-progress" id="progressBar">
                <div class="sx-progress-buffer" id="progressBuffer"></div>
                <div class="sx-progress-played" id="progressPlayed"></div>
                <div class="sx-progress-handle" id="progressHandle"></div>
              </div>
              <div class="sx-progress-time" id="progressTime">0:00</div>
            </div>

            <!-- Controls row -->
            <div class="sx-ctrl-row">
              <!-- Play / Pause -->
              <button class="sx-ctrl-btn" id="btnPlay" aria-label="Play (Space)">
                <svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
              </button>

              <!-- Rewind 10s -->
              <button class="sx-ctrl-btn" id="btnRewind" aria-label="Rewind 10s">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7.5" font-weight="700">10</text></svg>
              </button>

              <!-- Forward 10s -->
              <button class="sx-ctrl-btn" id="btnForward" aria-label="Forward 10s">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 11-2.13-9.36L23 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7.5" font-weight="700">10</text></svg>
              </button>

              <!-- Volume -->
              <div class="sx-volume-group" id="volumeGroup">
                <button class="sx-ctrl-btn" id="btnVolume" aria-label="Mute (M)">
                  <svg viewBox="0 0 24 24" fill="white"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 010 7.07" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
                </button>
                <div class="sx-volume-slider">
                  <div class="sx-volume-track" id="volumeTrack">
                    <div class="sx-volume-fill" id="volumeFill" style="width:70%"></div>
                    <div class="sx-volume-dot" id="volumeDot" style="left:70%"></div>
                  </div>
                </div>
              </div>

              <!-- Time -->
              <div class="sx-time-display"><span id="timeCurrent">0:00</span><span style="opacity:.35;margin:0 4px">/</span><span id="timeDuration">0:00</span></div>

              <div class="sx-ctrl-spacer"></div>

              <!-- Speed -->
              <button class="sx-ctrl-btn" id="btnSpeed" aria-label="Playback Speed">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </button>

              <!-- Quality -->
              <button class="sx-ctrl-btn" id="btnQuality" aria-label="Quality">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              </button>

              <!-- Fullscreen -->
              <button class="sx-ctrl-btn" id="btnFullscreen" aria-label="Fullscreen (F)">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/></svg>
              </button>
            </div>
          </div>

          <!-- Speed menu -->
          <div class="sx-menu" id="speedMenu">
            <div class="sx-menu-header" onclick="closeMenus()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
              Speed
            </div>
            <div class="sx-menu-divider"></div>
            <div id="speedOptions"></div>
          </div>

          <!-- Quality menu -->
          <div class="sx-menu" id="qualityMenu">
            <div class="sx-menu-header" onclick="closeMenus()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
              Quality
            </div>
            <div class="sx-menu-divider"></div>
            <div id="qualityOptions"></div>
          </div>
        </div>
      </div>

      <!-- SIDEBAR -->
      <div class="sx-sidebar" id="sxSidebar">
        <% if (episodes.length > 0) { %>
        <div class="sx-side-section">
          <div class="sx-side-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>Episodes</div>
          <% episodes.forEach(function(e) { %>
          <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= e.number %>" class="sx-sc <%= e.number === ep ? 'active' : '' %>">
            <div class="sx-sc-thumb">
              <img src="<%= e.poster || item.poster %>" alt="<%= e.title %>" loading="lazy">
              <span class="sx-sc-num">E<%= e.number %></span>
              <% if (e.number === ep) { %><span class="sx-sc-live">NOW</span><% } %>
            </div>
            <div class="sx-sc-info"><h4><%= e.title %></h4><p><%= e.duration %></p></div>
          </a>
          <% }) %>
        </div>
        <% } %>

        <% if (related.length > 0) { %>
        <div class="sx-side-section">
          <div class="sx-side-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>Recommended</div>
          <% related.slice(0,6).forEach(function(r) { %>
          <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="sx-sc">
            <div class="sx-sc-thumb"><img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy"></div>
            <div class="sx-sc-info"><h4><%= r.title %></h4><p>&#9733; <%= r.rating %> &bull; <%= r.genre %></p></div>
          </a>
          <% }) %>
        </div>
        <% } %>

        <div class="sx-side-section" id="cwSection" style="display:none">
          <div class="sx-side-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Continue Watching</div>
          <div id="cwList"></div>
        </div>
        <div class="sx-side-section" id="rwSection" style="display:none">
          <div class="sx-side-title"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Recently Added</div>
          <div id="rwList"></div>
        </div>
      </div>
    </div>

    <!-- ============ INFO ============ -->
    <div class="sx-info">
      <h1 class="sx-title"><%= displayTitle(item.title) %><% if (currentEpisode) { %> <span class="sx-ep">&mdash; E<%= currentEpisode.number %>: <%= currentEpisode.title %></span><% } %></h1>

      <div class="sx-badges">
        <% if (item.rating) { %><span class="sx-badge gold">&#9733; <%= item.rating %></span><% } %>
        <% if (item.year) { %><span class="sx-badge"><%= item.year %></span><% } %>
        <% if (item.language) { %><span class="sx-badge blue"><%= item.language.toUpperCase() %></span><% } %>
        <% if (item.premium) { %><span class="sx-badge prem">PREMIUM</span><% } %>
        <% if (item.genre) { %><span class="sx-badge green"><%= item.genre %></span><% } %>
        <% if (item.duration || (currentEpisode && currentEpisode.duration)) { %><span class="sx-badge"><%= currentEpisode ? currentEpisode.duration : item.duration %></span><% } %>
      </div>

      <div class="sx-desc" id="sxD"><%= currentEpisode ? currentEpisode.description : item.description %></div>
      <button class="sx-desc-btn" onclick="var d=document.getElementById('sxD');d.classList.toggle('open');this.textContent=d.classList.contains('open')?'Show Less':'Show More'">Show More</button>

      <div class="sx-acts" style="margin-top:8px">
        <% var _inList = (typeof userStatus !== 'undefined' && userStatus && userStatus.inWatchlist); %>
        <% var _ul = (typeof userStatus !== 'undefined' && userStatus && userStatus.userLike === 'like'); %>
        <% var _ud = (typeof userStatus !== 'undefined' && userStatus && userStatus.userLike === 'dislike'); %>
        <% var _lc = (typeof userStatus !== 'undefined' && userStatus && userStatus.likes) || 0; %>
        <% var _dc = (typeof userStatus !== 'undefined' && userStatus && userStatus.dislikes) || 0; %>
        <button id="myListBtn" class="sx-act glass" data-inlist="<%= _inList ? '1' : '0' %>">
          <svg id="myListIcon" viewBox="0 0 24 24" fill="<%= _inList ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2" width="17" height="17"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          <span id="myListText"><%= _inList ? 'In My List' : 'My List' %></span>
        </button>
        <button class="sx-act glass" id="likeBtn" data-active="<%= _ul ? '1' : '0' %>">
          <svg viewBox="0 0 24 24" fill="<%= _ul ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2" width="17" height="17"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
          <span>Like</span> <span class="sx-like-count" id="likeCount"><%= _lc %></span>
        </button>
        <button class="sx-act glass" id="unlikeBtn" data-active="<%= _ud ? '1' : '0' %>">
          <svg viewBox="0 0 24 24" fill="<%= _ud ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2" width="17" height="17"><path d="M10 15v4a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3zm7-13h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
          <span>Unlike</span> <span class="sx-like-count" id="dislikeCount"><%= _dc %></span>
        </button>
      </div>
    </div>

    <!-- ============ CAST ============ -->
    <% if (item.cast) { %>
    <div class="sx-cast-section">
      <div class="sx-sec-hdr"><h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Cast</h2></div>
      <div class="sx-cast-scroll" id="sxCast"></div>
    </div>
    <% } %>

    <!-- ============ CONTENT SECTIONS ============ -->
    <div class="sx-sections">
      <% if (related.length > 0) { %>
      <div class="sx-sec">
        <div class="sx-sec-hdr"><h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>More Like This</h2></div>
        <div class="sx-scroll">
          <% related.forEach(function(r) { %>
          <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="sx-card">
            <div class="sx-card-post"><img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy"><div class="sx-card-glass"></div><div class="sx-card-play"><svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div></div>
            <div class="sx-card-info"><div class="sx-card-title"><%= r.title %></div><div class="sx-card-meta"><span class="sx-cr">&#9733; <%= r.rating %></span>&bull;<%= r.genre %></div></div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>


      <% if (trending.length > 0) { %>
      <div class="sx-sec">
        <div class="sx-sec-hdr"><h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>Trending Now</h2></div>
        <div class="sx-scroll">
          <% trending.forEach(function(t) { %>
          <a href="/<%= t.seasons ? 'series' : 'movies' %>/<%= t.id %>" class="sx-card">
            <div class="sx-card-post"><img src="<%= t.poster %>" alt="<%= t.title %>" loading="lazy"><div class="sx-card-glass"></div><div class="sx-card-play"><svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div></div>
            <div class="sx-card-info"><div class="sx-card-title"><%= t.title %></div><div class="sx-card-meta"><span class="sx-cr">&#9733; <%= t.rating %></span>&bull;<%= t.genre %></div></div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="sx-sec" id="sxRecSec" style="display:none">
        <div class="sx-sec-hdr"><h2><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>You May Also Like</h2></div>
        <div class="sx-scroll" id="sxRecRow"></div>
      </div>
    </div>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.dashjs.org/latest/dash.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.min.js"></script>
<script>
(function(){
<%
  function getVideoMimeType(url){
    if(!url) return 'mp4';
    var l=url.toLowerCase();
    if(l.endsWith('.m3u8')||l.includes('.m3u8?')||l.includes('.m3u8&')) return 'm3u8';
    if(l.endsWith('.mpd')||l.includes('.mpd?')||l.includes('.mpd&')) return 'mpd';
    if(l.endsWith('.mkv')||l.includes('.mkv?')) return 'mkv';
    if(l.endsWith('.webm')||l.includes('.webm?')) return 'webm';
    return 'mp4';
  }
  var vSrc = currentEpisode ? (currentEpisode.videoUrl||currentEpisode.video_url||'') : (item.videoUrl||item.video_url||'');
  var vMime = getVideoMimeType(vSrc);
%>
var VURL='<%-vSrc%>',VTYPE='<%-vMime%>',art,hidetimer=null;
var bx=document.getElementById('pBox');

/* ========================================
   ICONS
   ======================================== */
var ICONS={
  play:'<svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>',
  pause:'<svg viewBox="0 0 24 24" fill="white"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>',
  volOn:'<svg viewBox="0 0 24 24" fill="white"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 010 7.07" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>',
  volOff:'<svg viewBox="0 0 24 24" fill="white"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="9" x2="23" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>',
  fsEnter:'<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/></svg>',
  fsExit:'<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M4 14h6v6m4-16h6v6M14 10l4-4m-4 4l4 4M10 14L6 18m4-4l-4-4"/></svg>'
};

/* ========================================
   UTILITIES
   ======================================== */
function formatTime(s){
  if(!s||!isFinite(s))return'0:00';
  var h=Math.floor(s/3600),m=Math.floor((s%3600)/60),sec=Math.floor(s%60);
  if(h)return h+':'+(m<10?'0':'')+m+':'+(sec<10?'0':'')+sec;
  return m+':'+(sec<10?'0':'')+sec;
}
function showToast(msg){
  var old=bx.querySelector('.sx-toast');if(old)old.remove();
  var el=document.createElement('div');el.className='sx-toast';el.textContent=msg;bx.appendChild(el);
  setTimeout(function(){if(el.parentNode)el.remove();},2200);
}

/* ========================================
   CONTROLS SHOW/HIDE (3 seconds)
   ======================================== */
function showControls(){
  bx.classList.add('sx-visible');
  clearTimeout(hidetimer);
  hidetimer=setTimeout(function(){
    bx.classList.remove('sx-visible');
    closeMenus();
  },3000);
}
bx.addEventListener('mousemove',showControls);
bx.addEventListener('mousedown',showControls);
bx.addEventListener('touchstart',showControls);

/* ========================================
   PLAY / PAUSE
   ======================================== */
function togglePlay(){if(art&&art.video){art.video.paused?art.video.play():art.video.pause();}}
document.getElementById('btnPlay').onclick=togglePlay;

/* Center click = play/pause handled by Artplayer natively */

/* ========================================
   REWIND / FORWARD
   ======================================== */
document.getElementById('btnRewind').onclick=function(){
  if(!art||!art.video)return;
  art.video.currentTime=Math.max(0,art.video.currentTime-10);
  showToast('-10s');showControls();
};
document.getElementById('btnForward').onclick=function(){
  if(!art||!art.video)return;
  art.video.currentTime=Math.min(art.video.duration||0,art.video.currentTime+10);
  showToast('+10s');showControls();
};

/* ========================================
   VOLUME
   ======================================== */
var volFill=document.getElementById('volumeFill'),volDot=document.getElementById('volumeDot'),volTrack=document.getElementById('volumeTrack');
function updateVolumeUI(){
  if(!art||!art.video)return;
  var v=art.video.muted?0:art.video.volume;
  document.getElementById('btnVolume').innerHTML=v===0?ICONS.volOff:ICONS.volOn;
  volFill.style.width=(v*100)+'%';volDot.style.left=(v*100)+'%';
}
document.getElementById('btnVolume').onclick=function(){
  if(!art||!art.video)return;art.video.muted=!art.video.muted;updateVolumeUI();showToast(art.video.muted?'Muted':'Unmuted');
};
var volDragging=false;
function setVolume(e){
  if(!volTrack||!art||!art.video)return;
  var r=volTrack.getBoundingClientRect(),p=Math.max(0,Math.min(1,(e.clientX-r.left)/r.width));
  art.video.volume=p;art.video.muted=p===0;updateVolumeUI();
}
volTrack.addEventListener('mousedown',function(e){volDragging=true;setVolume(e);});
document.addEventListener('mousemove',function(e){if(volDragging)setVolume(e);});
document.addEventListener('mouseup',function(){volDragging=false;});

/* ========================================
   PROGRESS BAR
   ======================================== */
var progressWrap=document.getElementById('progressWrap'),progressBar=document.getElementById('progressBar');
var progressPlayed=document.getElementById('progressPlayed'),progressHandle=document.getElementById('progressHandle');
var progressBuffer=document.getElementById('progressBuffer'),progressTimeEl=document.getElementById('progressTime');
var progressDragging=false;

function seekTo(e){
  if(!art||!art.video)return;
  var r=progressBar.getBoundingClientRect();
  art.video.currentTime=Math.max(0,Math.min(art.video.duration||0,((e.clientX-r.left)/r.width)*(art.video.duration||0)));
}
progressWrap.addEventListener('mousedown',function(e){progressDragging=true;seekTo(e);});
document.addEventListener('mousemove',function(e){if(progressDragging)seekTo(e);});
document.addEventListener('mouseup',function(){progressDragging=false;});

progressWrap.addEventListener('mousemove',function(e){
  var r=progressBar.getBoundingClientRect(),p=Math.max(0,Math.min(1,(e.clientX-r.left)/r.width));
  var dur=art&&art.video?art.video.duration:0;
  progressTimeEl.textContent=formatTime(p*dur);
  progressTimeEl.style.left=Math.max(40,Math.min(r.width-40,e.clientX-r.left))+'px';
});

/* ========================================
   FULLSCREEN
   ======================================== */
function toggleFullscreen(){
  if(!art||!art.video)return;
  if(document.fullscreenElement)document.exitFullscreen();
  else bx.requestFullscreen().catch(function(){showToast('Fullscreen not available');});
}
document.getElementById('btnFullscreen').onclick=toggleFullscreen;
document.addEventListener('fullscreenchange',function(){
  var b=document.getElementById('btnFullscreen');
  b.innerHTML=document.fullscreenElement?ICONS.fsExit:ICONS.fsEnter;
  b.setAttribute('aria-label',document.fullscreenElement?'Exit Fullscreen (F)':'Fullscreen (F)');
});

/* Single/Double click handled natively by Artplayer (play/pause + fullscreen) */

/* ========================================
   SPEED MENU
   ======================================== */
var state={speed:1,quality:'Auto',autoNext:true};
var speedMenu=document.getElementById('speedMenu'),qualityMenu=document.getElementById('qualityMenu');

function closeMenus(){speedMenu.classList.remove('open');qualityMenu.classList.remove('open');}

function buildSpeedMenu(){
  var el=document.getElementById('speedOptions');
  el.innerHTML='';
  var speeds=[0.25,0.5,0.75,1,1.25,1.5,1.75,2];
  speeds.forEach(function(s){
    var item=document.createElement('div');
    item.className='sx-menu-item'+(s===state.speed?' sx-active':'');
    item.innerHTML='<span>'+s+'x'+(s===1?' (Normal)':'')+'</span><span class="sx-menu-check">'+(s===state.speed?'<svg viewBox="0 0 24 24" fill="#E50914" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#E50914" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>':'')+'</span>';
    item.onclick=function(){
      state.speed=s;if(art&&art.video)art.video.playbackRate=s;
      closeMenus();showToast('Speed: '+s+'x');showControls();buildSpeedMenu();
    };
    el.appendChild(item);
  });
}
buildSpeedMenu();

document.getElementById('btnSpeed').onclick=function(e){
  e.stopPropagation();
  qualityMenu.classList.remove('open');
  speedMenu.classList.toggle('open');showControls();
};

function buildQualityMenu(){
  var el=document.getElementById('qualityOptions');
  el.innerHTML='';
  var qualities=['Auto','1080p','720p','480p'];
  qualities.forEach(function(q){
    var item=document.createElement('div');
    item.className='sx-menu-item'+(q===state.quality?' sx-active':'');
    item.innerHTML='<span>'+q+'</span><span class="sx-menu-check">'+(q===state.quality?'<svg viewBox="0 0 24 24" fill="#E50914" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#E50914" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>':'')+'</span>';
    item.onclick=function(){
      state.quality=q;
      closeMenus();showToast('Quality: '+q);showControls();buildQualityMenu();
    };
    el.appendChild(item);
  });
}
buildQualityMenu();

document.getElementById('btnQuality').onclick=function(e){
  e.stopPropagation();
  speedMenu.classList.remove('open');
  qualityMenu.classList.toggle('open');showControls();
};

/* Close menus on outside click */
document.addEventListener('click',function(e){
  if(!speedMenu.contains(e.target)&&!e.target.closest('#btnSpeed'))speedMenu.classList.remove('open');
  if(!qualityMenu.contains(e.target)&&!e.target.closest('#btnQuality'))qualityMenu.classList.remove('open');
});

/* ========================================
   SKIP INTRO / RECAP
   ======================================== */
function checkSkip(t){
  var b=document.getElementById('skipBtn');if(!b)return;
  if(t>=30&&t<=45){
    b.classList.add('show');b.textContent='Skip Intro';
    b.onclick=function(){if(art&&art.video){art.video.currentTime=45;b.classList.remove('show');}}
  }else if(art&&art.duration&&t>=art.duration-60&&t<art.duration-45){
    b.classList.add('show');b.textContent='Skip Recap';
    b.onclick=function(){if(art&&art.video){art.video.currentTime=art.duration-45;b.classList.remove('show');}}
  }else{b.classList.remove('show');}
}

/* ========================================
   NEXT EPISODE
   ======================================== */
var nextEpTimer=null;
var NX=(function(){
  <% if(episodes.length>0){ %>
    <% var nxEp=episodes.find(function(e){return e.number===ep+1}); %>
    <% if(nxEp){ %>
      return{poster:'<%=item.poster%>',title:'<%=nxEp.title.replace(/'/g,"\\'")%>',num:<%=nxEp.number%>,url:'/watch/<%=type%>/<%=item.id%>?ep=<%=nxEp.number%>'};
    <% } %>
  <% } %>
  return null;
})();

function showNextEpisode(){
  if(!NX)return;
  var p=document.getElementById('nextPop');
  document.getElementById('npImg').src=NX.poster;
  document.getElementById('npTitle').textContent=NX.title;
  document.getElementById('npSub').textContent='Episode '+NX.num;
  p.classList.add('show');
  p.onclick=function(e){if(!e.target.closest('.sx-np-close')&&!e.target.closest('.sx-np-toggle'))window.location.href=NX.url;};
  if(state.autoNext){
    var cd=10;document.getElementById('npTimer').textContent='Playing in '+cd+'s';
    nextEpTimer=setInterval(function(){
      cd--;document.getElementById('npTimer').textContent='Playing in '+cd+'s';
      if(cd<=0){clearInterval(nextEpTimer);window.location.href=NX.url;}
    },1000);
  }else{
    document.getElementById('npTimer').textContent='Autoplay is off';
  }
}

/* ========================================
   RESUME FROM LAST POSITION
   ======================================== */
function resumeKey(){return 'sx_r_<%=item.id%>'<%if(currentEpisode){%>+'_e<%=currentEpisode.number%>'<%}%>;}
function saveResume(t){try{localStorage.setItem(resumeKey(),Math.floor(t));}catch(e){}}
function loadResume(){try{var t=parseInt(localStorage.getItem(resumeKey()));return(t&&t>5)?t:0;}catch(e){return 0;}}
function clearResume(){try{localStorage.removeItem(resumeKey());}catch(e){}}

/* ========================================
   CAST RENDERING
   ======================================== */
<% if(item.cast){ %>
(function(){
  var names='<%=item.cast%>'.split(',').map(function(s){return s.trim()}).filter(Boolean);
  var el=document.getElementById('sxCast');if(!el)return;
  var colors=['#E50914','#3B82F6','#8B5CF6','#EC4899','#F59E0B','#10B981'];
  names.forEach(function(n,i){
    var init=n.split(' ').map(function(w){return w[0]}).join('').substring(0,2).toUpperCase();
    var c=colors[i%colors.length];
    el.innerHTML+='<div class="sx-cast-item"><div class="sx-cast-avatar"><div class="sx-cast-initial" style="background:linear-gradient(135deg,'+c+'33,'+c+'11)">'+init+'</div></div><div class="sx-cast-name">'+n+'</div><div class="sx-cast-char">Actor</div></div>';
  });
  if('<%=item.director%>'){var dir='<%=item.director%>';el.innerHTML+='<div class="sx-cast-item"><div class="sx-cast-avatar"><div class="sx-cast-initial" style="background:linear-gradient(135deg,#f5c51833,#f5c51811)">'+dir[0]+'</div></div><div class="sx-cast-name">'+dir+'</div><div class="sx-cast-char">Director</div></div>';}
})();
<%}%>

/* ========================================
   ARTPLAYER INIT
   ======================================== */
var pc={
  container:'#artplayer-app',url:VURL,type:VTYPE,
  poster:'<%=item.backdrop||item.poster%>',theme:'#E50914',
  volume:.7,muted:false,autoplay:false,pip:false,
  autoSize:false,autoMini:true,screenshot:false,setting:false,
  loop:false,flip:false,playbackRate:true,aspectRatio:false,
  fullscreen:true,fullscreenWeb:true,subtitleOffset:false,
  miniProgressBar:true,mutex:true,backdrop:true,playsInline:true,
  autoPlayback:true,airplay:true,hotkey:true,lock:true,
  lang:navigator.language.toLowerCase()==='zh-cn'?'zh-cn':'en',
  moreVideoAttr:{crossOrigin:'anonymous'},
  settings:[],controls:[],layers:[],
  contextmenu:[{html:'STREAMX',click:function(c){c.show=false}}],
  icons:{
    loading:'<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%"><div style="width:40px;height:40px;border:3px solid rgba(255,255,255,.1);border-top-color:#E50914;border-radius:50%;animation:art-loading .7s linear infinite"></div></div>',
    state:'<svg width="48" height="48" viewBox="0 0 24 24" fill="white" opacity=".85"><path d="M8 5v14l11-7z"/></svg>',
    indicator:'<svg width="16" height="16" viewBox="0 0 24 24" fill="#E50914"><circle cx="12" cy="12" r="10"/></svg>'
  }
};

if(VTYPE==='m3u8'||VTYPE==='mpd'){
  pc.customType={
    m3u8:function(vid,url){
      if(typeof Hls!=='undefined'&&Hls.isSupported()){
        var h=new Hls({enableWorker:true,lowLatencyMode:false});h.loadSource(url);h.attachMedia(vid);
        h.on(Hls.Events.MANIFEST_PARSED,function(){vid.play().catch(function(){});});
        h.on(Hls.Events.ERROR,function(e,d){if(d.fatal){if(d.type===Hls.ErrorTypes.NETWORK_ERROR){showToast('Network error...');h.startLoad();}else if(d.type===Hls.ErrorTypes.MEDIA_ERROR){showToast('Media error...');h.recoverMediaError();}else{showToast('Fatal error');h.destroy();}}});
      }else if(vid.canPlayType('application/vnd.apple.mpegurl')){vid.src=url;}else{showToast('HLS not supported');}
    },
    mpd:function(vid,url){
      if(typeof dashjs!=='undefined'){var dp=dashjs.MediaPlayer().create();dp.updateSettings({streaming:{abr:{autoSwitchBitrate:{video:true}}}});dp.initialize(vid,url,false);}else{showToast('DASH not loaded');}
    }
  };
}

art=new Artplayer(pc);showControls();

/* Resume */
var rt=loadResume();if(rt>5){art.on('video:loadedmetadata',function(){art.video.currentTime=rt;showToast('Resumed from '+formatTime(rt));});}

/* ========================================
   VIDEO EVENTS
   ======================================== */
art.on('video:play',function(){document.getElementById('btnPlay').innerHTML=ICONS.pause;});
art.on('video:pause',function(){document.getElementById('btnPlay').innerHTML=ICONS.play;});
art.on('video:ended',function(){document.getElementById('btnPlay').innerHTML=ICONS.play;clearResume();showNextEpisode();});

art.on('video:timeupdate',function(){
  if(!art.duration)return;
  var p=(art.currentTime/art.duration)*100;
  document.getElementById('timeCurrent').textContent=formatTime(art.currentTime);
  document.getElementById('timeDuration').textContent=formatTime(art.duration);
  progressPlayed.style.width=p+'%';
  progressHandle.style.left=p+'%';
  document.getElementById('mFill').style.width=p+'%';
  checkSkip(art.currentTime);
  saveResume(art.currentTime);
  /* Continue watching API every 25% */
  var pg=Math.floor(p);if(pg>0&&pg%25===0){
    fetch('/api/continue-watching',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contentId:<%=item.id%>,type:'<%=item.type%>',progress:pg,currentTime:Math.floor(art.currentTime)})}).catch(function(){});
  }
});

art.on('video:progress',function(){
  if(!art.video||!art.duration)return;
  var b=art.video.buffered;if(b&&b.length>0){var e=b.end(b.length-1);progressBuffer.style.width=(e/art.duration*100)+'%';}
});

art.on('video:waiting',function(){showToast('Buffering...');});
art.on('video:error',function(){showToast('Unable to play this video');});
art.on('video:volumechange',updateVolumeUI);

/* ========================================
   KEYBOARD SHORTCUTS
   ======================================== */
document.addEventListener('keydown',function(e){
  if(!art||!art.video)return;
  var tag=(e.target.tagName||'').toLowerCase();
  if(tag==='input'||tag==='textarea'||tag==='select')return;
  var key=e.key.toLowerCase();
  if(key===' '||key==='k'){e.preventDefault();togglePlay();showControls();}
  else if(key==='arrowleft'){e.preventDefault();art.video.currentTime=Math.max(0,art.video.currentTime-10);showToast('-10s');showControls();}
  else if(key==='arrowright'){e.preventDefault();art.video.currentTime=Math.min(art.video.duration||0,art.video.currentTime+10);showToast('+10s');showControls();}
  else if(key==='arrowup'){e.preventDefault();art.video.volume=Math.min(1,art.video.volume+.1);art.video.muted=false;updateVolumeUI();showControls();}
  else if(key==='arrowdown'){e.preventDefault();art.video.volume=Math.max(0,art.video.volume-.1);updateVolumeUI();showControls();}
  else if(key==='f'){e.preventDefault();toggleFullscreen();showControls();}
  else if(key==='m'){e.preventDefault();art.video.muted=!art.video.muted;updateVolumeUI();showToast(art.video.muted?'Muted':'Unmuted');showControls();}
  else if(key==='escape'){closeMenus();showControls();}
});

/* ========================================
   LOAD SIDE SECTIONS
   ======================================== */
function mkCard(it,type){
  return'<a href="/'+(type==='anime'?'anime':type==='series'?'series':'movies')+'/'+it.id+'" class="sx-sc">'+
    '<div class="sx-sc-thumb"><img src="'+(it.poster||'')+'" alt="'+(it.title||'')+'" loading="lazy"></div>'+
    '<div class="sx-sc-info"><h4>'+(it.title||'')+'</h4><p>&#9733; '+(it.rating||0)+' &bull; '+(it.genre||'')+'</p></div></a>';
}

fetch('/api/continue-watching').then(function(r){return r.json()}).then(function(d){
  if(d&&d.items&&d.items.length>0){
    document.getElementById('cwSection').style.display='block';
    var el=document.getElementById('cwList');
    d.items.forEach(function(it){
      el.innerHTML+='<a href="/'+(it.type==='series'||it.type==='anime'?'series':'movies')+'/'+it.content_id+'" class="sx-sc">'+
        '<div class="sx-sc-thumb"><img src="'+(it.poster||'')+'" alt="'+(it.title||'')+'" loading="lazy">'+
        '<div style="position:absolute;bottom:0;left:0;right:0;height:2px;background:rgba(255,255,255,.06)"><div style="height:100%;background:var(--accent);width:'+Math.min(it.progress||10,100)+'%"></div></div></div>'+
        '<div class="sx-sc-info"><h4>'+(it.title||'')+'</h4><p>'+(it.duration||'')+' &bull; '+(it.progress||0)+'% watched</p></div></a>';
    });
  }
}).catch(function(){});

fetch('/api/content?type=movie&limit=8&sort=recent').then(function(r){return r.json()}).then(function(d){
  if(d&&d.items&&d.items.length>0){
    document.getElementById('rwSection').style.display='block';
    var el=document.getElementById('rwList');
    d.items.forEach(function(it){el.innerHTML+=mkCard(it,'movie');});
  }
}).catch(function(){});

fetch('/api/content?type=<%=item.type%>&limit=8&exclude=<%=item.id%>').then(function(r){return r.json()}).then(function(d){
  if(d&&d.items&&d.items.length>0){
    document.getElementById('sxRecSec').style.display='block';
    var row=document.getElementById('sxRecRow');
    d.items.forEach(function(it){
      row.innerHTML+='<a href="/<%=item.type==="movie"?"movies":"series"%>/'+it.id+'" class="sx-card"><div class="sx-card-post"><img src="'+(it.poster||'')+'" alt="'+(it.title||'')+'" loading="lazy"><div class="sx-card-glass"></div><div class="sx-card-play"><svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div></div><div class="sx-card-info"><div class="sx-card-title">'+(it.title||'')+'</div><div class="sx-card-meta"><span class="sx-cr">&#9733; '+(it.rating||0)+'</span>&bull;'+(it.genre||'')+'</div></div></a>';
    });
  }
}).catch(function(){});

})();
</script>

<script>
(function(){
var _itemId=<%= item.id %>;
var _isLoggedIn=<%= user ? 'true' : 'false' %>;

/* My List */
var _inList=document.getElementById('myListBtn').getAttribute('data-inlist')==='1';
function updateMyListBtn(){
  var btn=document.getElementById('myListBtn');
  var icon=document.getElementById('myListIcon');
  var txt=document.getElementById('myListText');
  if(!btn)return;
  if(_inList){
    btn.style.cssText='background:rgba(34,197,94,0.15)!important;border-color:rgba(34,197,94,0.5)!important;color:#4ade80!important;';
    icon.setAttribute('fill','currentColor');
    txt.textContent='In My List';
  }else{
    btn.removeAttribute('style');
    icon.setAttribute('fill','none');
    txt.textContent='My List';
  }
}
document.getElementById('myListBtn').addEventListener('click',function(){
  if(!_isLoggedIn){window.location.href='/auth/login';return;}
  var prev=_inList;
  _inList=!_inList;
  updateMyListBtn();
  var url=_inList?'/watchlist/add':'/watchlist/remove';
  fetch(url,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({id:_itemId})}).then(function(r){return r.json();}).then(function(d){
    if(!d.ok){_inList=prev;updateMyListBtn();}
  }).catch(function(){_inList=prev;updateMyListBtn();});
});

/* Like / Unlike */
var _liked=document.getElementById('likeBtn').getAttribute('data-active')==='1';
var _unliked=document.getElementById('unlikeBtn').getAttribute('data-active')==='1';
var _likeCount=parseInt(document.getElementById('likeCount').textContent)||0;
var _dislikeCount=parseInt(document.getElementById('dislikeCount').textContent)||0;

function updateLikeUI(){
  var lBtn=document.getElementById('likeBtn');
  var uBtn=document.getElementById('unlikeBtn');
  if(_liked){lBtn.style.cssText='background:rgba(239,68,68,0.15)!important;border-color:rgba(239,68,68,0.5)!important;color:#ef4444!important;';lBtn.querySelector('svg').setAttribute('fill','currentColor');}
  else{lBtn.removeAttribute('style');lBtn.querySelector('svg').setAttribute('fill','none');}
  if(_unliked){uBtn.style.cssText='background:rgba(255,255,255,0.15)!important;border-color:rgba(255,255,255,0.5)!important;color:#ffffff!important;';uBtn.querySelector('svg').setAttribute('fill','currentColor');}
  else{uBtn.removeAttribute('style');uBtn.querySelector('svg').setAttribute('fill','none');}
  document.getElementById('likeCount').textContent=_likeCount;
  document.getElementById('dislikeCount').textContent=_dislikeCount;
}

document.getElementById('likeBtn').addEventListener('click',function(){
  if(!_isLoggedIn){window.location.href='/auth/login';return;}
  var wasLiked=_liked,wasUnliked=_unliked;
  var oldLC=_likeCount,oldDC=_dislikeCount;
  if(_liked){_liked=false;_likeCount=Math.max(0,_likeCount-1);}
  else{_liked=true;_likeCount++;if(_unliked){_unliked=false;_dislikeCount=Math.max(0,_dislikeCount-1);}}
  updateLikeUI();
  fetch('/api/like-toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contentId:_itemId,type:'like'})}).then(function(r){return r.json();}).then(function(d){_liked=d.userLike==='like';_unliked=d.userLike==='dislike';_likeCount=d.likes;_dislikeCount=d.dislikes;updateLikeUI();}).catch(function(){_liked=wasLiked;_unliked=wasUnliked;_likeCount=oldLC;_dislikeCount=oldDC;updateLikeUI();});
});

document.getElementById('unlikeBtn').addEventListener('click',function(){
  if(!_isLoggedIn){window.location.href='/auth/login';return;}
  var wasLiked=_liked,wasUnliked=_unliked;
  var oldLC=_likeCount,oldDC=_dislikeCount;
  if(_unliked){_unliked=false;_dislikeCount=Math.max(0,_dislikeCount-1);}
  else{_unliked=true;_dislikeCount++;if(_liked){_liked=false;_likeCount=Math.max(0,_likeCount-1);}}
  updateLikeUI();
  fetch('/api/like-toggle',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({contentId:_itemId,type:'dislike'})}).then(function(r){return r.json();}).then(function(d){_liked=d.userLike==='like';_unliked=d.userLike==='dislike';_likeCount=d.likes;_dislikeCount=d.dislikes;updateLikeUI();}).catch(function(){_liked=wasLiked;_unliked=wasUnliked;_likeCount=oldLC;_dislikeCount=oldDC;updateLikeUI();});
});

updateLikeUI();
})();
</script>

<%- include('partials/footer') %>
