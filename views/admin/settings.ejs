<%- include('../partials/header', { pageTitle: 'Settings - STREAMX Admin' }) %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Settings</h1>
    </div>

    <div class="admin-card" style="max-width: 600px;">
      <div class="admin-card-header">
        <h3>Admin Profile</h3>
      </div>
      <div class="admin-form">
        <div class="form-group">
          <label>Name</label>
          <input type="text" class="form-input" value="<%= admin.name %>" readonly style="opacity: 0.7;">
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" class="form-input" value="<%= admin.email %>" readonly style="opacity: 0.7;">
        </div>
        <div class="form-group">
          <label>Role</label>
          <input type="text" class="form-input" value="Administrator" readonly style="opacity: 0.7;">
        </div>
        <div class="form-group">
          <label>Plan</label>
          <input type="text" class="form-input" value="Premium Admin" readonly style="opacity: 0.7; color: #fbbf24;">
        </div>
      </div>
    </div>

    <div class="admin-card" style="max-width: 600px; margin-top: 24px;">
      <div class="admin-card-header">
        <h3>Platform Info</h3>
      </div>
      <div class="admin-form">
        <div class="form-group">
          <label>Platform</label>
          <input type="text" class="form-input" value="STREAMX" readonly style="opacity: 0.7;">
        </div>
        <div class="form-group">
          <label>Version</label>
          <input type="text" class="form-input" value="1.0.0" readonly style="opacity: 0.7;">
        </div>
        <div class="form-group">
          <label>Status</label>
          <input type="text" class="form-input" value="Active - Premium" readonly style="opacity: 0.7; color: var(--green);">
        </div>
      </div>
    </div>
  </main>
</div>


