generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PREMIUM
}

enum ContentType {
  MOVIE
  SERIES
  ANIME
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatar        String?
  role          Role      @default(USER)
  plan          Plan      @default(FREE)
  banned        Boolean   @default(false)
  watchTime     Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastActiveAt  DateTime? @map("last_active_at")

  history       History[]
  bookmarks     Bookmark[]
  watchLater    WatchLater[]
  subscription  Subscription?
  comments      Comment[]
  playbackPos   PlaybackPosition[]

  @@map("users")
}

model Content {
  id            String      @id @default(cuid())
  tmdbId        Int?        @unique @map("tmdb_id")
  title         String
  slug          String      @unique
  type          ContentType
  description   String      @default("")
  poster        String      @default("")
  banner        String      @default("")
  backdrop      String      @default("")
  trailerUrl    String?     @map("trailer_url")
  videoUrl      String?     @map("video_url")
  huggingFaceUrl String?    @map("hugging_face_url")
  genre         String      @default("")
  genres        String[]    @default([])
  language      String      @default("en")
  country       String      @default("")
  runtime       Int         @default(0)
  rating        Float       @default(0)
  releaseDate   DateTime?   @map("release_date")
  cast          String[]    @default([])
  director      String      @default("")
  seasons       Int         @default(0)
  episodesCount Int         @default(0) @map("episodes_count")
  featured      Boolean     @default(false)
  trending      Boolean     @default(false)
  published     Boolean     @default(false)
  viewCount     Int         @default(0) @map("view_count")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  episodes      Episode[]
  history       History[]
  bookmarks     Bookmark[]
  watchLater    WatchLater[]
  comments      Comment[]
  playbackPos   PlaybackPosition[]
  collectionItems CollectionItem[]

  @@index([type])
  @@index([genre])
  @@index([rating(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([title])
  @@index([published])
  @@map("content")
}

model Episode {
  id          String   @id @default(cuid())
  contentId   String   @map("content_id")
  season      Int      @default(1)
  number      Int
  title       String
  description String   @default("")
  poster      String?
  videoUrl    String?  @map("video_url")
  huggingFaceUrl String? @map("hugging_face_url")
  duration    Int      @default(0)
  rating      Float    @default(0)
  airDate     DateTime? @map("air_date")
  createdAt   DateTime @default(now()) @map("created_at")

  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, season, number])
  @@index([contentId])
  @@map("episodes")
}

model History {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  contentId   String   @map("content_id")
  progress    Float    @default(0)
  completed   Boolean  @default(false)
  watchedAt   DateTime @default(now()) @map("watched_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("history")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  contentId String   @map("content_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("bookmarks")
}

model WatchLater {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  contentId String   @map("content_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("watch_later")
}

model PlaybackPosition {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  contentId   String?  @map("content_id")
  episodeId   String?  @map("episode_id")
  position    Float    @default(0)
  duration    Float    @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
  @@map("playback_positions")
}

model Subscription {
  id            String             @id @default(cuid())
  userId        String             @unique @map("user_id")
  plan          Plan               @default(PREMIUM)
  status        SubscriptionStatus @default(ACTIVE)
  startDate     DateTime           @default(now()) @map("start_date")
  endDate       DateTime?          @map("end_date")
  amount        Float              @default(0)
  paymentMethod String             @default("") @map("payment_method")
  transactionId String?            @map("transaction_id")
  createdAt     DateTime           @default(now()) @map("created_at")

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Collection {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String           @default("")
  poster      String           @default("")
  featured    Boolean          @default(false)
  createdAt   DateTime         @default(now()) @map("created_at")

  items       CollectionItem[]

  @@map("collections")
}

model CollectionItem {
  id          String     @id @default(cuid())
  collectionId String    @map("collection_id")
  contentId   String     @map("content_id")
  order       Int        @default(0)

  collection  Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  content     Content    @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([collectionId, contentId])
  @@map("collection_items")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  contentId String   @map("content_id")
  text      String
  rating    Float?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @default("")

  @@map("settings")
}

model SyncLog {
  id        String   @id @default(cuid())
  status    String
  message   String
  filesFound Int      @default(0) @map("files_found")
  newFiles  Int      @default(0) @map("new_files")
  errors    Int      @default(0)
  duration  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("sync_logs")
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String?  @map("user_id")
  metadata  String?  @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
