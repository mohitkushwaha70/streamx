<%- include('partials/header', { pageTitle: 'Login with OTP' }) %>

<div class="auth-container">
  <div class="auth-box">
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px;">
      <img src="/images/favicon.svg" alt="" style="width:40px;height:40px;border-radius:10px;">
      <span style="font-weight:800;font-size:1.5rem;color:#fff;letter-spacing:-0.5px;">STREAM<span style="background:linear-gradient(135deg,#6c5ce7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">X</span></span>
    </div>
    <p class="subtitle">Login with a one-time password</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
    <% if (success) { %><div class="alert" style="background:#00c85322;color:#00c853;border:1px solid #00c85344;"><%= success %></div><% } %>

    <form method="POST" action="/auth/otp/send">
      <div class="form-group">
        <label>Email Address</label>
        <input type="email" name="email" class="form-input" placeholder="you@example.com" required
               value="<%= email || '' %>">
      </div>
      <button type="submit" class="btn btn-primary btn-lg">SEND OTP</button>
    </form>

    <div class="auth-footer">
      <a href="/auth/login" style="color: var(--accent);">← Back to Sign In</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
