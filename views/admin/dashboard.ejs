<%- include('../partials/header', { pageTitle: 'Admin Dashboard' }) %>

<div class="admin-layout">
  <aside class="admin-sidebar">
    <div class="admin-logo">
      <a href="/">
        <div class="logo-icon">▶</div>
        stream<span>X</span>
      </a>
      <span class="admin-badge">ADMIN</span>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="admin-nav-item active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/admin/movies" class="admin-nav-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/><line x1="17" y1="17" x2="22" y2="17"/></svg>
        Movies
      </a>
      <a href="/admin/series" class="admin-nav-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
        Series
      </a>
      <a href="/admin/users" class="admin-nav-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users
      </a>
      <div class="admin-nav-divider"></div>
      <a href="/" class="admin-nav-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        View Website
      </a>
      <a href="/auth/logout" class="admin-nav-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </a>
    </nav>
  </aside>

  <main class="admin-main">
    <div class="admin-header">
      <h1>Dashboard</h1>
      <div class="admin-header-right">
        <span>Welcome, <%= user.name %></span>
        <div class="avatar"><%= user.avatar %></div>
      </div>
    </div>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon blue">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= stats.totalMovies %></span>
          <span class="stat-label">Total Movies</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= stats.totalSeries %></span>
          <span class="stat-label">Total Series</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= stats.totalUsers %></span>
          <span class="stat-label">Total Users</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon gold">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <div class="stat-info">
          <span class="stat-number"><%= stats.premiumUsers %></span>
          <span class="stat-label">Premium Users</span>
        </div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="admin-grid">
      <!-- Recent Movies -->
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>Recent Movies</h3>
          <a href="/admin/movies" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>Title</th><th>Genre</th><th>Rating</th><th>Premium</th></tr>
            </thead>
            <tbody>
              <% movies.forEach(m => { %>
              <tr>
                <td><strong><%= m.title %></strong></td>
                <td><span class="table-badge"><%= m.genre %></span></td>
                <td>★ <%= m.rating %></td>
                <td><span class="plan-badge <%= m.premium ? 'premium' : 'free' %>"><%= m.premium ? 'Premium' : 'Free' %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Recent Users -->
      <div class="admin-card">
        <div class="admin-card-header">
          <h3>Recent Users</h3>
          <a href="/admin/users" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr><th>User</th><th>Email</th><th>Plan</th><th>Role</th></tr>
            </thead>
            <tbody>
              <% recentUsers.forEach(u => { %>
              <tr>
                <td>
                  <div class="user-cell">
                    <div class="avatar-sm"><%= u.avatar %></div>
                    <strong><%= u.name %></strong>
                  </div>
                </td>
                <td style="color: var(--text-muted)"><%= u.email %></td>
                <td><span class="plan-badge <%= u.plan %>"><%= u.plan %></span></td>
                <td><span class="table-badge"><%= u.role %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
