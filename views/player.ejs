<%- include('partials/header', { pageTitle: 'Watch - ' + displayTitle(item.title) }) %>
<%- include('partials/navbar', { active: '' }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.css">

<style>
/* ============================================================
   WATCH PAGE - Netflix/JioHotstar Cinematic Style
   ============================================================ */
.watch-page {
  padding: 0 !important;
  background: #000;
  min-height: 100vh;
}

/* Player container - full width */
.watch-player-wrap {
  position: relative;
  width: 100%;
  max-width: 1400px;
  margin: 0 auto;
  background: #000;
}

#artplayer-app {
  width: 100%;
  aspect-ratio: 16/9;
  background: #000;
  border-radius: 0;
  overflow: hidden;
  position: relative;
}

/* Hide all ArtPlayer default UI */
.art-top, .art-control-top, .art-settings, .art-info,
.art-mask, .art-tip, .art-notice, .art-setting,
.art-control-progress-tip { display: none !important; }
.art-state { position: absolute !important; top: 50% !important; left: 50% !important; transform: translate(-50%,-50%) !important; z-index: 50 !important; pointer-events: none !important; }
.art-state svg { filter: drop-shadow(0 2px 12px rgba(0,0,0,0.5)); }
.art-notice { display: none !important; }

/* ============================================================
   OVERLAY - TOP BAR (back + title)
   ============================================================ */
.wx-top-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 16px 20px;
  background: linear-gradient(to bottom, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 60%, transparent 100%);
  opacity: 0;
  transition: opacity 0.35s ease;
}
#artplayer-app:hover .wx-top-bar,
#artplayer-app.sx-controls-visible .wx-top-bar { opacity: 1; }

.wx-back {
  width: 40px; height: 40px;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  color: white;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s ease;
  flex-shrink: 0;
}
.wx-back:hover { background: rgba(255,255,255,0.18); transform: scale(1.06); }
.wx-back svg { width: 20px; height: 20px; }

.wx-title-group {
  flex: 1; min-width: 0;
  display: flex; align-items: center; gap: 10px;
}
.wx-ep-badge {
  background: rgba(59,130,246,0.2);
  color: #60a5fa;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}
.wx-title-text {
  color: white;
  font-size: 0.95rem;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.wx-top-right {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-shrink: 0;
}
.wx-top-btn {
  width: 36px; height: 36px;
  border-radius: 8px;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  color: white;
  cursor: pointer;
  transition: all 0.2s ease;
}
.wx-top-btn:hover { background: rgba(255,255,255,0.18); }
.wx-top-btn svg { width: 18px; height: 18px; }

/* ============================================================
   OVERLAY - BOTTOM BAR
   ============================================================ */
.wx-bottom-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  z-index: 100;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.6) 50%, transparent 100%);
  backdrop-filter: blur(18px) saturate(180%);
  -webkit-backdrop-filter: blur(18px) saturate(180%);
  opacity: 0;
  transition: opacity 0.35s ease;
  padding-bottom: 6px;
}
#artplayer-app:hover .wx-bottom-bar,
#artplayer-app.sx-controls-visible .wx-bottom-bar { opacity: 1; }

/* Progress bar */
.wx-progress-wrap {
  position: relative;
  padding: 14px 16px 4px 16px;
}
.wx-progress-track {
  position: relative;
  height: 4px;
  background: rgba(255,255,255,0.18);
  border-radius: 2px;
  overflow: visible;
  cursor: pointer;
  transition: height 0.2s ease, background 0.2s ease;
}
.wx-progress-wrap:hover .wx-progress-track { height: 6px; }

.wx-progress-buffered {
  position: absolute; top: 0; left: 0; height: 100%;
  background: rgba(255,255,255,0.2);
  border-radius: 2px;
  pointer-events: none;
}
.wx-progress-played {
  position: absolute; top: 0; left: 0; height: 100%;
  background: #3B82F6;
  border-radius: 2px;
  pointer-events: none;
}
.wx-progress-thumb {
  width: 14px; height: 14px;
  background: #3B82F6;
  border: 2.5px solid #fff;
  border-radius: 50%;
  position: absolute; top: 50%;
  transform: translateY(-50%) scale(0);
  pointer-events: none;
  z-index: 10;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  box-shadow: 0 0 12px rgba(59,130,246,0.6);
}
.wx-progress-wrap:hover .wx-progress-thumb { transform: translateY(-50%) scale(1); }

/* Hover thumbnail preview */
.wx-thumb-preview {
  position: absolute; bottom: calc(100% + 12px); transform: translateX(-50%);
  width: 160px; height: 90px;
  border-radius: 8px; overflow: hidden;
  background: #111;
  border: 2px solid rgba(255,255,255,0.12);
  box-shadow: 0 4px 24px rgba(0,0,0,0.7);
  display: none; pointer-events: none; z-index: 110;
}
.wx-progress-wrap:hover .wx-thumb-preview { display: block; }
.wx-thumb-preview img { width: 100%; height: 100%; object-fit: cover; }
.wx-thumb-preview .wx-thumb-time {
  position: absolute; bottom: 4px; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.85); padding: 2px 8px; border-radius: 4px;
  color: white; font-size: 0.7rem; font-weight: 600;
}

/* Controls row */
.wx-controls {
  display: flex;
  align-items: center;
  padding: 2px 12px;
  gap: 2px;
  height: 44px;
}
.wx-controls .wx-ctrl {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6px;
  cursor: pointer;
  color: #fff;
  opacity: 0.92;
  transition: opacity 0.2s ease, transform 0.15s ease, background 0.2s ease;
  border-radius: 8px;
  height: 34px;
  position: relative;
}
.wx-controls .wx-ctrl:hover {
  opacity: 1;
  background: rgba(255,255,255,0.1);
  transform: scale(1.06);
}
.wx-controls .wx-ctrl svg {
  width: 20px; height: 20px;
  fill: #fff;
  flex-shrink: 0;
}
.wx-controls .wx-spacer { flex: 1; pointer-events: none; }

/* Volume slider */
.wx-volume-wrap { display: flex; align-items: center; }
.wx-volume-slider {
  width: 0; overflow: hidden;
  transition: width 0.25s ease;
  display: flex; align-items: center;
}
.wx-volume-wrap:hover .wx-volume-slider { width: 80px; }
.wx-volume-slider .wx-vol-track {
  width: 100%; height: 3px;
  background: rgba(255,255,255,0.2);
  border-radius: 2px;
  position: relative; cursor: pointer;
}
.wx-volume-slider .wx-vol-fill {
  height: 100%;
  background: #3B82F6;
  border-radius: 2px;
}
.wx-volume-slider .wx-vol-thumb {
  width: 12px; height: 12px;
  background: #fff;
  border-radius: 50%;
  position: absolute; top: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 0 6px rgba(0,0,0,0.4);
}

/* Time display */
.wx-time {
  font-size: 13px; font-weight: 500;
  color: rgba(255,255,255,0.85);
  padding: 0 8px;
  white-space: nowrap;
  letter-spacing: 0.02em;
}

/* Settings popup */
.wx-settings-panel {
  position: absolute; bottom: 64px; right: 12px; z-index: 300;
  background: rgba(10,12,20,0.94);
  backdrop-filter: blur(28px) saturate(150%);
  -webkit-backdrop-filter: blur(28px) saturate(150%);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  box-shadow: 0 12px 48px rgba(0,0,0,0.65);
  padding: 8px 0;
  min-width: 280px; max-height: 65vh;
  overflow-y: auto;
  display: none;
}
.wx-settings-panel.open { display: block; animation: wxSlideUp 0.2s ease; }
@keyframes wxSlideUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

.wx-settings-panel::-webkit-scrollbar { width: 4px; }
.wx-settings-panel::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 2px; }

.wx-sp-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 20px;
  color: rgba(255,255,255,0.85); font-size: 0.85rem;
  cursor: pointer;
  transition: background 0.15s ease;
}
.wx-sp-item:hover { background: rgba(59,130,246,0.1); }
.wx-sp-item.active { color: #3B82F6; font-weight: 600; }
.wx-sp-item .wx-sp-label { font-weight: 500; }
.wx-sp-item .wx-sp-value {
  color: rgba(255,255,255,0.4); font-size: 0.8rem;
  display: flex; align-items: center; gap: 4px;
}
.wx-sp-item .wx-sp-value svg { width: 14px; height: 14px; fill: rgba(255,255,255,0.3); }
.wx-sp-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 4px 0; }

.wx-toggle {
  width: 36px; height: 20px; border-radius: 10px;
  position: relative;
  background: rgba(255,255,255,0.2);
  transition: background 0.2s ease;
  cursor: pointer;
}
.wx-toggle.on { background: #3B82F6; }
.wx-toggle::after {
  content: ''; position: absolute; top: 2px; left: 2px;
  width: 16px; height: 16px; border-radius: 50%;
  background: #fff;
  transition: transform 0.2s ease;
}
.wx-toggle.on::after { transform: translateX(16px); }

/* ============================================================
   OVERLAY - SKIP INTRO / RECAP BUTTONS
   ============================================================ */
.wx-skip-overlay {
  position: absolute;
  bottom: 100px; right: 20px;
  z-index: 180;
  display: none;
  animation: wxFadeIn 0.3s ease;
}
.wx-skip-overlay.visible { display: block; }
@keyframes wxFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.wx-skip-btn {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,0.15);
  color: white;
  padding: 10px 22px;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  font-family: inherit;
}
.wx-skip-btn:hover { background: rgba(255,255,255,0.22); transform: scale(1.04); }

/* ============================================================
   OVERLAY - NEXT EPISODE NOTIFICATION
   ============================================================ */
.wx-next-ep {
  position: absolute;
  bottom: 100px; right: 20px;
  z-index: 180;
  display: none;
  animation: wxFadeIn 0.3s ease;
}
.wx-next-ep.visible { display: block; }

.wx-next-card {
  background: rgba(10,12,20,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 14px;
  display: flex;
  gap: 12px;
  width: 320px;
  cursor: pointer;
  transition: all 0.2s ease;
}
.wx-next-card:hover { background: rgba(20,22,32,0.95); border-color: rgba(59,130,246,0.3); }

.wx-next-thumb {
  width: 120px; height: 68px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
  position: relative;
  background: #111;
}
.wx-next-thumb img { width: 100%; height: 100%; object-fit: cover; }
.wx-next-play {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  width: 32px; height: 32px;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.wx-next-play svg { width: 16px; height: 16px; fill: white; }

.wx-next-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.wx-next-label { font-size: 0.65rem; color: #3B82F6; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
.wx-next-title { font-size: 0.85rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 2px; }
.wx-next-ep-num { font-size: 0.75rem; color: rgba(255,255,255,0.5); }
.wx-next-timer { font-size: 0.7rem; color: rgba(255,255,255,0.4); margin-top: 4px; }

.wx-next-close {
  position: absolute; top: -8px; right: -8px;
  width: 24px; height: 24px;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: white;
  font-size: 0.7rem;
  transition: background 0.2s ease;
}
.wx-next-close:hover { background: rgba(255,255,255,0.3); }

/* ============================================================
   MINI PROGRESS BAR (visible when controls hidden)
   ============================================================ */
.wx-mini-progress {
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: rgba(255,255,255,0.12); z-index: 99;
  opacity: 1; transition: opacity 0.3s ease;
}
.wx-mini-progress-inner { height: 100%; background: #3B82F6; transition: width 0.3s linear; }
#artplayer-app.sx-controls-visible .wx-mini-progress { opacity: 0; }

/* ============================================================
   THEATER MODE OVERLAY
   ============================================================ */
.theater-overlay { display: none; position: fixed; inset: 0; background: #000; z-index: 9998; }
.theater-overlay.active { display: block; }
#artplayer-app.theater-mode {
  position: fixed !important; top: 0 !important; left: 0 !important;
  right: 0 !important; width: 100vw !important; height: 100vh !important;
  z-index: 9999 !important; aspect-ratio: unset !important; border-radius: 0 !important;
}
#artplayer-app.theater-mode .wx-bottom-bar { padding-bottom: 12px !important; }
#artplayer-app.theater-mode .wx-top-bar { padding: 20px !important; }
#artplayer-app.theater-mode .wx-mini-progress { height: 4px !important; }

/* ============================================================
   NOTIFICATION TOAST
   ============================================================ */
.wx-notice {
  position: absolute; top: 20px; right: 20px; z-index: 300;
  background: rgba(10,12,20,0.9);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  padding: 10px 18px;
  color: white; font-size: 0.85rem; font-weight: 500;
  animation: wxNoticeIn 0.3s ease;
  pointer-events: none;
}
@keyframes wxNoticeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

/* ============================================================
   CONTENT BELOW PLAYER
   ============================================================ */
.watch-content {
  max-width: 1200px;
  margin: 0 auto;
  padding: 24px 32px 60px;
}

/* Back row (mobile-visible, hidden on desktop where we have overlay) */
.watch-back-row {
  display: none;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}
.watch-back-link {
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  display: flex; align-items: center; gap: 6px;
  font-size: 0.85rem; font-weight: 500;
  transition: color 0.2s;
}
.watch-back-link:hover { color: #fff; }
.watch-back-link svg { width: 18px; height: 18px; }

/* Title + meta */
.watch-title-row { margin-bottom: 16px; }
.watch-title {
  font-size: 1.6rem; font-weight: 800; color: #fff;
  margin-bottom: 8px; line-height: 1.3;
}
.watch-meta {
  display: flex; align-items: center; gap: 14px;
  flex-wrap: wrap;
}
.watch-meta .rating { color: #f59e0b; font-weight: 700; font-size: 0.9rem; }
.watch-meta span { font-size: 0.85rem; color: rgba(255,255,255,0.5); }
.watch-meta .premium-badge {
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #000; padding: 3px 10px;
  border-radius: 20px; font-size: 0.75rem; font-weight: 700;
}
.watch-meta .quality-badge {
  background: rgba(59,130,246,0.15);
  color: #3B82F6; padding: 3px 10px;
  border-radius: 20px; font-size: 0.75rem; font-weight: 700;
  border: 1px solid rgba(59,130,246,0.3);
}

/* Actions row */
.watch-actions {
  display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 24px;
}
.watch-action-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  color: rgba(255,255,255,0.6);
  font-size: 0.8rem; font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
  font-family: inherit;
}
.watch-action-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
.watch-action-btn.liked { color: #ef4444; border-color: rgba(239,68,68,0.3); }
.watch-action-btn svg { flex-shrink: 0; }

/* Description */
.watch-desc {
  color: rgba(255,255,255,0.65);
  line-height: 1.7; font-size: 0.9rem;
  margin-bottom: 28px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.watch-desc.expanded {
  -webkit-line-clamp: unset;
}
.watch-desc-toggle {
  color: #3B82F6;
  cursor: pointer;
  font-size: 0.85rem;
  font-weight: 500;
  margin-top: 6px;
  display: inline-block;
}

/* Divider */
.watch-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 28px 0; }

/* Section header */
.watch-section-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 16px;
  cursor: pointer;
}
.watch-section-header h2 {
  font-size: 1.1rem; font-weight: 700; color: #fff;
  display: flex; align-items: center; gap: 8px;
}
.watch-section-header h2 svg { width: 20px; height: 20px; color: #3B82F6; }
.watch-section-toggle {
  color: rgba(255,255,255,0.4);
  font-size: 0.8rem;
  display: flex; align-items: center; gap: 4px;
  transition: color 0.2s;
}
.watch-section-header:hover .watch-section-toggle { color: rgba(255,255,255,0.7); }
.watch-section-body { transition: max-height 0.35s ease, opacity 0.25s ease; overflow: hidden; }
.watch-section-body.collapsed { max-height: 0; opacity: 0; }

/* Season tabs */
.watch-season-tabs { display: flex; gap: 8px; margin-bottom: 16px; overflow-x: auto; }
.watch-season-tab {
  padding: 6px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  color: rgba(255,255,255,0.5);
  font-size: 0.8rem; font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
  text-decoration: none;
}
.watch-season-tab.active { background: #3B82F6; color: #fff; border-color: #3B82F6; }
.watch-season-tab:hover { border-color: rgba(59,130,246,0.5); color: #fff; }

/* Episode cards */
.watch-episode-card {
  display: flex; gap: 14px;
  padding: 12px;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 10px;
  margin-bottom: 8px;
  transition: all 0.2s;
  cursor: pointer;
  text-decoration: none;
  color: inherit;
}
.watch-episode-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(59,130,246,0.3); }
.watch-episode-card.active { background: rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.3); }

.watch-ep-thumb {
  width: 160px; height: 90px;
  border-radius: 8px; overflow: hidden;
  flex-shrink: 0; position: relative;
  background: #111;
}
.watch-ep-thumb img { width: 100%; height: 100%; object-fit: cover; }
.watch-ep-num {
  position: absolute; bottom: 6px; left: 6px;
  background: rgba(0,0,0,0.8); color: #fff;
  font-size: 0.7rem; font-weight: 700;
  padding: 2px 8px; border-radius: 4px;
}
.watch-ep-now {
  position: absolute; top: 6px; right: 6px;
  background: #3B82F6; color: #fff;
  font-size: 0.65rem; font-weight: 700;
  padding: 2px 6px; border-radius: 4px;
}

.watch-ep-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.watch-ep-info h4 { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.watch-ep-info p { font-size: 0.8rem; color: rgba(255,255,255,0.45); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
.watch-ep-info .watch-ep-duration { font-size: 0.75rem; color: rgba(255,255,255,0.35); margin-top: 6px; }

/* Horizontal scroll recommendation cards */
.watch-rec-scroll {
  display: flex; gap: 14px;
  overflow-x: auto;
  padding-bottom: 8px;
}
.watch-rec-scroll::-webkit-scrollbar { height: 4px; }
.watch-rec-scroll::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

.watch-rec-card {
  min-width: 200px; flex-shrink: 0;
  text-decoration: none; color: inherit;
  transition: transform 0.2s;
}
.watch-rec-card:hover { transform: translateY(-2px); }

.watch-rec-thumb {
  width: 200px; height: 112px;
  border-radius: 8px; overflow: hidden;
  position: relative; background: #111;
}
.watch-rec-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
.watch-rec-card:hover .watch-rec-thumb img { transform: scale(1.05); }
.watch-rec-play {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  opacity: 0; transition: all 0.3s;
}
.watch-rec-card:hover .watch-rec-play { opacity: 1; }
.watch-rec-info { padding: 8px 0; }
.watch-rec-info h4 { font-size: 0.8rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.watch-rec-info p { font-size: 0.75rem; color: rgba(255,255,255,0.4); }

/* Where to watch streaming links */
.watch-streaming { display: flex; gap: 12px; flex-wrap: wrap; }
.watch-stream-link {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  text-decoration: none; color: #fff;
  transition: all 0.3s;
  min-width: 160px;
}
.watch-stream-link:hover { background: rgba(255,255,255,0.12); }
.watch-stream-link img { width: 28px; height: 28px; border-radius: 6px; object-fit: contain; }
.watch-stream-link .stream-name { font-weight: 600; font-size: 0.85rem; }
.watch-stream-link .stream-action { font-size: 0.7rem; }
.watch-stream-link .stream-action.free { color: #4ade80; }
.watch-stream-link .stream-action.rent { color: #f59e0b; }
.watch-stream-link .stream-action.buy { color: #3b82f6; }
.watch-stream-link .stream-action.stream { color: #4ade80; }

/* ============================================================
   SHARE MODAL
   ============================================================ */
.share-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; display: none; align-items: center; justify-content: center; }
.share-modal.active { display: flex; }
.share-box { background: #111; border: 1px solid #222; border-radius: 16px; padding: 28px; max-width: 420px; width: 90%; }
.share-box h3 { color: #fff; margin-bottom: 16px; font-size: 1.1rem; }
.share-link { display: flex; gap: 8px; margin-bottom: 16px; }
.share-link input { flex: 1; background: #1a1a1a; border: 1px solid #333; border-radius: 8px; padding: 10px 14px; color: #fff; font-size: 0.85rem; }
.share-link button { background: #3B82F6; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 600; cursor: pointer; }
.share-close { background: none; border: none; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 1.5rem; float: right; }

/* ============================================================
   SIDEBAR TOGGLE (desktop)
   ============================================================ */
.wx-sidebar-toggle {
  display: none;
  position: absolute;
  top: 16px; right: 16px;
  z-index: 200;
  width: 40px; height: 40px;
  border-radius: 10px;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border: 1px solid rgba(255,255,255,0.08);
  display: none;
  align-items: center; justify-content: center;
  color: white; cursor: pointer;
  transition: all 0.2s ease;
  opacity: 0;
}
#artplayer-app:hover .wx-sidebar-toggle,
#artplayer-app.sx-controls-visible .wx-sidebar-toggle { opacity: 1; }
.wx-sidebar-toggle:hover { background: rgba(59,130,246,0.6); }
.wx-sidebar-toggle svg { width: 20px; height: 20px; }

/* ============================================================
   SIDEBAR (desktop right panel, toggleable)
   ============================================================ */
.watch-sidebar {
  position: fixed;
  top: 0; right: 0; bottom: 0;
  width: 380px;
  background: #0a0a0f;
  border-left: 1px solid rgba(255,255,255,0.06);
  z-index: 9990;
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow-y: auto;
  display: none;
}
.watch-sidebar.open { transform: translateX(0); }
.watch-sidebar::-webkit-scrollbar { width: 4px; }
.watch-sidebar::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

.watch-sidebar-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 20px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  position: sticky; top: 0;
  background: #0a0a0f;
  z-index: 5;
}
.watch-sidebar-title {
  font-size: 0.95rem; font-weight: 700; color: #fff;
  display: flex; align-items: center; gap: 8px;
}
.watch-sidebar-title svg { color: #3B82F6; }
.watch-sidebar-close {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.08);
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,0.5);
  cursor: pointer;
  transition: all 0.2s;
}
.watch-sidebar-close:hover { background: rgba(255,255,255,0.12); color: #fff; }
.watch-sidebar-close svg { width: 16px; height: 16px; }

.watch-sidebar-content { padding: 12px 16px; }
.watch-sidebar-section { margin-bottom: 24px; }
.watch-sidebar-section-title {
  font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.4);
  text-transform: uppercase; letter-spacing: 0.1em;
  margin-bottom: 12px;
}

/* Sidebar episode card - compact */
.wx-side-ep {
  display: flex; gap: 10px;
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 6px;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none; color: inherit;
}
.wx-side-ep:hover { background: rgba(255,255,255,0.06); }
.wx-side-ep.active { background: rgba(59,130,246,0.1); }
.wx-side-ep-thumb {
  width: 100px; height: 56px;
  border-radius: 6px; overflow: hidden;
  flex-shrink: 0; position: relative;
  background: #111;
}
.wx-side-ep-thumb img { width: 100%; height: 100%; object-fit: cover; }
.wx-side-ep-num {
  position: absolute; bottom: 4px; left: 4px;
  background: rgba(0,0,0,0.8); color: #fff;
  font-size: 0.65rem; font-weight: 700;
  padding: 1px 6px; border-radius: 3px;
}
.wx-side-ep-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.wx-side-ep-info h4 { font-size: 0.8rem; font-weight: 600; color: #fff; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.wx-side-ep-info p { font-size: 0.7rem; color: rgba(255,255,255,0.35); }

/* Sidebar recommendation card - compact */
.wx-side-rec {
  display: flex; gap: 10px;
  padding: 10px;
  border-radius: 8px;
  margin-bottom: 6px;
  cursor: pointer;
  transition: background 0.2s;
  text-decoration: none; color: inherit;
}
.wx-side-rec:hover { background: rgba(255,255,255,0.06); }
.wx-side-rec-thumb {
  width: 80px; height: 45px;
  border-radius: 6px; overflow: hidden;
  flex-shrink: 0; background: #111;
}
.wx-side-rec-thumb img { width: 100%; height: 100%; object-fit: cover; }
.wx-side-rec-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.wx-side-rec-info h4 { font-size: 0.8rem; font-weight: 600; color: #fff; margin-bottom: 3px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.wx-side-rec-info p { font-size: 0.7rem; color: rgba(255,255,255,0.35); }

/* ============================================================
   LOADING SPINNER
   ============================================================ */
@keyframes art-loading { to { transform: rotate(360deg); } }

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (min-width: 1025px) {
  .watch-back-row { display: none !important; }
  .wx-sidebar-toggle { display: flex; }
  .watch-sidebar { display: block; }
  #artplayer-app { cursor: none; }
}

@media (max-width: 1024px) {
  .watch-content { padding: 20px 20px 48px; }
  .watch-back-row { display: flex; }
  .wx-title-text { font-size: 0.85rem; }
  .watch-title { font-size: 1.3rem; }
  .watch-ep-thumb { width: 120px; height: 68px; }
  .watch-rec-card { min-width: 170px; }
  .watch-rec-thumb { width: 170px; height: 96px; }
}

@media (max-width: 768px) {
  .watch-content { padding: 16px 16px 40px; }
  .wx-controls { padding: 2px 6px; gap: 0; height: 38px; }
  .wx-controls .wx-ctrl { padding: 0 4px; height: 30px; }
  .wx-controls .wx-ctrl svg { width: 18px; height: 18px; }
  .wx-time { font-size: 11px; padding: 0 4px; }
  .wx-progress-wrap { padding: 10px 10px 4px 10px; }
  .wx-progress-thumb { width: 12px; height: 12px; }
  .wx-bottom-bar { padding-bottom: 4px; }
  .wx-top-bar { padding: 10px 12px; }
  .wx-back { width: 36px; height: 36px; }
  .wx-title-text { font-size: 0.8rem; }
  .wx-settings-panel { right: 8px; min-width: 240px; }
  .watch-title { font-size: 1.15rem; }
  .watch-actions { gap: 6px; }
  .watch-action-btn { padding: 6px 10px; font-size: 0.75rem; }
  .watch-ep-thumb { width: 100px; height: 56px; }
  .watch-rec-card { min-width: 150px; }
  .watch-rec-thumb { width: 150px; height: 84px; }
  .wx-next-card { width: 280px; }
  .wx-next-thumb { width: 100px; height: 56px; }
}

@media (max-width: 480px) {
  .wx-controls .wx-ctrl { padding: 0 3px; height: 26px; }
  .wx-controls .wx-ctrl svg { width: 16px; height: 16px; }
  .wx-time { font-size: 10px; }
  .wx-volume-slider { display: none !important; }
  .wx-top-right { display: none; }
}
</style>

<main class="main-content watch-page">
  <div class="watch-player-wrap">
    <div id="artplayer-app"></div>
    <div class="theater-overlay" id="theaterOverlay" onclick="wxExitTheater()"></div>

    <!-- MINI PROGRESS BAR -->
    <div class="wx-mini-progress"><div class="wx-mini-progress-inner" id="wxMiniProgInner"></div></div>

    <!-- TOP BAR -->
    <div class="wx-top-bar">
      <a href="javascript:history.back()" class="wx-back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <div class="wx-title-group">
        <% if (currentEpisode) { %>
        <span class="wx-ep-badge">E<%= currentEpisode.number %></span>
        <% } %>
        <span class="wx-title-text"><%= displayTitle(item.title) %><% if (currentEpisode) { %> &mdash; <%= currentEpisode.title %><% } %></span>
      </div>
      <div class="wx-top-right">
        <div class="wx-top-btn" title="Theater Mode" onclick="wxToggleTheater()">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
        </div>
        <div class="wx-top-btn" title="Picture in Picture" onclick="wxPiP()">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><rect x="11" y="9" width="9" height="7" rx="1" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.5"/></svg>
        </div>
      </div>
    </div>

    <!-- BOTTOM BAR -->
    <div class="wx-bottom-bar">
      <div class="wx-progress-wrap">
        <div class="wx-progress-track" id="wxProgressTrack">
          <div class="wx-progress-buffered" id="wxBuffered"></div>
          <div class="wx-progress-played" id="wxPlayed"></div>
          <div class="wx-progress-thumb" id="wxThumb"></div>
        </div>
        <div class="wx-thumb-preview" id="wxThumbPreview">
          <img id="wxThumbImg" src="<%= item.backdrop || item.poster %>" style="display:none">
          <div class="wx-thumb-time" id="wxThumbTime">0:00</div>
        </div>
      </div>
      <div class="wx-controls" id="wxControls"></div>
    </div>

    <!-- SKIP INTRO / RECAP -->
    <div class="wx-skip-overlay" id="wxSkipOverlay">
      <button class="wx-skip-btn" id="wxSkipBtn" onclick="wxSkipAction()">Skip Intro</button>
    </div>

    <!-- NEXT EPISODE NOTIFICATION -->
    <div class="wx-next-ep" id="wxNextEp">
      <div class="wx-next-card" id="wxNextCard">
        <div class="wx-next-thumb" id="wxNextThumb">
          <img id="wxNextImg" src="" alt="">
          <div class="wx-next-play"><svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg></div>
        </div>
        <div class="wx-next-info">
          <div class="wx-next-label">Up Next</div>
          <div class="wx-next-title" id="wxNextTitle"></div>
          <div class="wx-next-ep-num" id="wxNextEpNum"></div>
          <div class="wx-next-timer" id="wxNextTimer"></div>
        </div>
      </div>
      <div class="wx-next-close" onclick="document.getElementById('wxNextEp').classList.remove('visible')">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </div>
    </div>

    <!-- SETTINGS PANEL -->
    <div class="wx-settings-panel" id="wxSettingsPanel"></div>
  </div>

  <!-- CONTENT BELOW PLAYER -->
  <div class="watch-content">
    <!-- Back link (mobile) -->
    <div class="watch-back-row">
      <a href="javascript:history.back()" class="watch-back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </a>
    </div>

    <!-- Title + Meta -->
    <div class="watch-title-row">
      <h1 class="watch-title"><%= displayTitle(item.title) %></h1>
      <div class="watch-meta">
        <span class="rating">&#9733; <%= item.rating %></span>
        <span><%= item.year %></span>
        <span><%= item.genre %></span>
        <% if (currentEpisode) { %><span><%= currentEpisode.duration %></span><% } else if (item.duration) { %><span><%= item.duration %></span><% } %>
        <% if (item.premium) { %><span class="premium-badge">PREMIUM</span><% } %>
        <span class="quality-badge">HD 1080p</span>
        <% if (item.cast) { %><span><%= item.cast %></span><% } %>
      </div>
    </div>

    <!-- Actions -->
    <div class="watch-actions">
      <button class="watch-action-btn" onclick="this.classList.toggle('liked')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
        Like
      </button>
      <button class="watch-action-btn" onclick="document.getElementById('shareModal').classList.add('active')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        Share
      </button>
      <form action="/watchlist/add" method="POST" style="display:inline">
        <input type="hidden" name="id" value="<%= item.id %>">
        <button type="submit" class="watch-action-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          Watchlist
        </button>
      </form>
      <a href="/download/<%= type %>/<%= item.id %>" class="watch-action-btn" style="text-decoration:none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download
      </a>
    </div>

    <!-- Description -->
    <div class="watch-desc" id="watchDesc"><%= currentEpisode ? currentEpisode.description : item.description %></div>
    <span class="watch-desc-toggle" id="watchDescToggle" onclick="toggleDesc()">Show more</span>

    <!-- Where to Watch -->
    <%
      const hasSub = streaming && streaming.subscription && streaming.subscription.length > 0;
      const hasFree = streaming && streaming.free && streaming.free.length > 0;
      const hasRent = streaming && streaming.rent && streaming.rent.length > 0;
      const hasBuy = streaming && streaming.buy && streaming.buy.length > 0;
    %>
    <% if (hasSub || hasFree || hasRent || hasBuy) { %>
    <div class="watch-divider"></div>
    <div class="watch-section-header" onclick="toggleSection('streamingSection')">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
        Where to Watch
      </h2>
      <span class="watch-section-toggle" id="streamingSectionToggle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </div>
    <div class="watch-section-body" id="streamingSection">
      <div class="watch-streaming">
        <% if (hasSub) { streaming.subscription.forEach(s => { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener" class="watch-stream-link">
          <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>"><% } else { %><span style="font-size:1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
          <div><div class="stream-name"><%= s.name %></div><div class="stream-action stream">Stream Now</div></div>
        </a>
        <% }) } %>
        <% if (hasFree) { streaming.free.forEach(s => { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener" class="watch-stream-link">
          <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>"><% } else { %><span style="font-size:1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
          <div><div class="stream-name"><%= s.name %></div><div class="stream-action free">Free</div></div>
        </a>
        <% }) } %>
        <% if (hasRent) { streaming.rent.forEach(s => { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener" class="watch-stream-link">
          <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>"><% } else { %><span style="font-size:1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
          <div><div class="stream-name"><%= s.name %></div><div class="stream-action rent">Rent</div></div>
        </a>
        <% }) } %>
        <% if (hasBuy) { streaming.buy.forEach(s => { %>
        <a href="<%= s.url %>" target="_blank" rel="noopener" class="watch-stream-link">
          <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>"><% } else { %><span style="font-size:1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
          <div><div class="stream-name"><%= s.name %></div><div class="stream-action buy">Buy</div></div>
        </a>
        <% }) } %>
      </div>
    </div>
    <% } %>

    <!-- Episodes (for series/anime) -->
    <% if (episodes.length > 0) { %>
    <div class="watch-divider"></div>
    <div class="watch-section-header" onclick="toggleSection('episodesSection')">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        Episodes
        <span style="font-size:0.75rem;font-weight:400;color:rgba(255,255,255,0.4);margin-left:4px;"><%= episodes.length %></span>
      </h2>
      <span class="watch-section-toggle" id="episodesSectionToggle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </div>
    <div class="watch-section-body" id="episodesSection">
      <% if (totalSeasons > 1) { %>
      <div class="watch-season-tabs">
        <% for (let s = 1; s <= totalSeasons; s++) { %>
        <a href="?season=<%= s %>&ep=1" class="watch-season-tab <%= s === currentSeason ? 'active' : '' %>">Season <%= s %></a>
        <% } %>
      </div>
      <% } %>
      <% episodes.forEach(e => { %>
      <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= e.number %>" class="watch-episode-card <%= e.number === ep ? 'active' : '' %>">
        <div class="watch-ep-thumb">
          <img src="<%= item.poster %>" alt="<%= e.title %>" loading="lazy">
          <span class="watch-ep-num">E<%= e.number %></span>
          <% if (e.number === ep) { %><span class="watch-ep-now">NOW</span><% } %>
        </div>
        <div class="watch-ep-info">
          <h4><%= e.title %></h4>
          <p><%= e.description %></p>
          <span class="watch-ep-duration"><%= e.duration %></span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <!-- More Like This -->
    <% if (related.length > 0) { %>
    <div class="watch-divider"></div>
    <div class="watch-section-header" onclick="toggleSection('relatedSection')">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        More Like This
      </h2>
      <span class="watch-section-toggle" id="relatedSectionToggle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </div>
    <div class="watch-section-body" id="relatedSection">
      <div class="watch-rec-scroll">
        <% related.forEach(r => { %>
        <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="watch-rec-card">
          <div class="watch-rec-thumb">
            <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
            <div class="watch-rec-play"><svg width="28" height="28" viewBox="0 0 24 24" fill="white" opacity="0.9"><path d="M8 5v14l11-7z"/></svg></div>
          </div>
          <div class="watch-rec-info"><h4><%= r.title %></h4><p>&#9733; <%= r.rating %> &bull; <%= r.genre %></p></div>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Trending -->
    <% if (trending.length > 0) { %>
    <div class="watch-divider"></div>
    <div class="watch-section-header" onclick="toggleSection('trendingSection')">
      <h2>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        Trending Now
      </h2>
      <span class="watch-section-toggle" id="trendingSectionToggle">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
    </div>
    <div class="watch-section-body" id="trendingSection">
      <div class="watch-rec-scroll">
        <% trending.forEach(t => { %>
        <a href="/<%= t.seasons ? 'series' : 'movies' %>/<%= t.id %>" class="watch-rec-card">
          <div class="watch-rec-thumb">
            <img src="<%= t.poster %>" alt="<%= t.title %>" loading="lazy">
            <div class="watch-rec-play"><svg width="28" height="28" viewBox="0 0 24 24" fill="white" opacity="0.9"><path d="M8 5v14l11-7z"/></svg></div>
          </div>
          <div class="watch-rec-info"><h4><%= t.title %></h4><p>&#9733; <%= t.rating %> &bull; <%= t.genre %></p></div>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>
  </div>
</main>

<!-- SIDEBAR (desktop right panel) -->
<div class="watch-sidebar" id="watchSidebar">
  <div class="watch-sidebar-header">
    <div class="watch-sidebar-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
      Up Next
    </div>
    <div class="watch-sidebar-close" onclick="closeSidebar()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </div>
  </div>
  <div class="watch-sidebar-content">
    <% if (episodes.length > 0) { %>
    <div class="watch-sidebar-section">
      <div class="watch-sidebar-section-title">Episodes</div>
      <% episodes.forEach(e => { %>
      <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= e.number %>" class="wx-side-ep <%= e.number === ep ? 'active' : '' %>">
        <div class="wx-side-ep-thumb">
          <img src="<%= item.poster %>" alt="<%= e.title %>" loading="lazy">
          <span class="wx-side-ep-num">E<%= e.number %></span>
        </div>
        <div class="wx-side-ep-info">
          <h4><%= e.title %></h4>
          <p><%= e.duration %></p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <% if (related.length > 0) { %>
    <div class="watch-sidebar-section">
      <div class="watch-sidebar-section-title">More Like This</div>
      <% related.slice(0, 8).forEach(r => { %>
      <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="wx-side-rec">
        <div class="wx-side-rec-thumb">
          <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
        </div>
        <div class="wx-side-rec-info">
          <h4><%= r.title %></h4>
          <p>&#9733; <%= r.rating %> &bull; <%= r.genre %></p>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<!-- SHARE MODAL -->
<div class="share-modal" id="shareModal">
  <div class="share-box">
    <button class="share-close" onclick="document.getElementById('shareModal').classList.remove('active')">&times;</button>
    <h3>Share</h3>
    <div class="share-link">
      <input type="text" value="<%= shareUrl %>" id="shareUrlInput" readonly>
      <button onclick="navigator.clipboard.writeText(document.getElementById('shareUrlInput').value).then(function(){ showNoticeGlobal('Link copied!'); })">Copy</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.dashjs.org/latest/dash.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.min.js"></script>
<script>
(function() {
  <%
    function getVideoMimeType(url) {
      if (!url) return 'mp4';
      const lower = url.toLowerCase();
      if (lower.endsWith('.m3u8') || lower.includes('.m3u8?') || lower.includes('.m3u8&')) return 'm3u8';
      if (lower.endsWith('.mpd') || lower.includes('.mpd?') || lower.includes('.mpd&')) return 'mpd';
      if (lower.endsWith('.mkv') || lower.includes('.mkv?')) return 'mkv';
      if (lower.endsWith('.webm') || lower.includes('.webm?')) return 'webm';
      if (lower.endsWith('.ogg') || lower.includes('.ogg?')) return 'ogg';
      return 'mp4';
    }
    const videoSrc = currentEpisode ? (currentEpisode.videoUrl || currentEpisode.video_url || '') : (item.videoUrl || item.video_url || '');
    const videoMime = getVideoMimeType(videoSrc);
  %>

  var videoUrl = '<%= videoSrc %>';
  var videoType = '<%= videoMime %>';
  var art;
  var container = document.getElementById('artplayer-app');
  var hideTimer = null;
  var CONTINUE_WATCH_INTERVAL = 25;

  /* ===== SVG ICON LIBRARY ===== */
  var IC = {
    play: '<svg viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>',
    pause: '<svg viewBox="0 0 24 24" fill="white"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>',
    volOn: '<svg viewBox="0 0 24 24" fill="white"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 010 7.07" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>',
    volOff: '<svg viewBox="0 0 24 24" fill="white"><path d="M11 5L6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/><line x1="17" y1="9" x2="23" y2="15" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>',
    rw10: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 102.13-9.36L1 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7.5" font-weight="700">10</text></svg>',
    fw10: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 11-2.13-9.36L23 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7.5" font-weight="700">10</text></svg>',
    sub: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="6" y1="16" x2="14" y2="16"/></svg>',
    audio: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>',
    quality: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    speed: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    settings: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>',
    pip: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><rect x="11" y="9" width="9" height="7" rx="1" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.5"/></svg>',
    fs: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M8 3H5a2 2 0 00-2 2v3m18 0V5a2 2 0 00-2-2h-3m0 18h3a2 2 0 002-2v-3M3 16v3a2 2 0 002 2h3"/></svg>',
    fsExit: '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M4 14h6v6m4-16h6v6M14 10l4-4m-4 4l4 4M10 14L6 18m4-4l-4-4"/></svg>',
    chev: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>'
  };

  /* ===== UTILITY ===== */
  function fmt(s) {
    if (!s || !isFinite(s)) return '0:00';
    var h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = Math.floor(s % 60);
    if (h > 0) return h + ':' + (m < 10 ? '0' : '') + m + ':' + (sec < 10 ? '0' : '') + sec;
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }

  function notice(msg) {
    var old = container.querySelector('.wx-notice');
    if (old) old.remove();
    var n = document.createElement('div');
    n.className = 'wx-notice';
    n.textContent = msg;
    container.appendChild(n);
    setTimeout(function() { if (n.parentNode) n.remove(); }, 2000);
  }

  window.showNoticeGlobal = function(msg) {
    var n = document.createElement('div');
    n.className = 'wx-notice';
    n.textContent = msg;
    n.style.cssText = 'position:fixed;top:20px;right:20px;z-index:10000;';
    document.body.appendChild(n);
    setTimeout(function() { if (n.parentNode) n.remove(); }, 2000);
  };

  /* ===== CONTROLS AUTO-HIDE ===== */
  function showControls() {
    container.classList.add('sx-controls-visible');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(function() {
      container.classList.remove('sx-controls-visible');
      var sp = document.getElementById('wxSettingsPanel');
      if (sp) sp.classList.remove('open');
    }, 3000);
  }
  container.addEventListener('mousemove', showControls);
  container.addEventListener('mousedown', showControls);
  container.addEventListener('touchstart', showControls);

  /* ===== BUILD CONTROLS ===== */
  var controlsEl = document.getElementById('wxControls');

  function buildControls() {
    controlsEl.innerHTML = '';

    /* Play/Pause */
    var playBtn = mkCtrl(IC.play, 'sxPlayBtn');
    playBtn.onclick = function() { art && art.video && art.video.paused ? art.video.play() : art.video.pause(); };
    controlsEl.appendChild(playBtn);

    /* Rewind 10s */
    var rw = mkCtrl(IC.rw10, null, 'Replay 10s');
    rw.onclick = function() { if (art && art.video) { art.video.currentTime = Math.max(0, art.video.currentTime - 10); notice('-10s'); } };
    controlsEl.appendChild(rw);

    /* Forward 10s */
    var fw = mkCtrl(IC.fw10, null, 'Forward 10s');
    fw.onclick = function() { if (art && art.video) { art.video.currentTime = Math.min(art.video.duration || 0, art.video.currentTime + 10); notice('+10s'); } };
    controlsEl.appendChild(fw);

    /* Volume */
    var volWrap = document.createElement('div');
    volWrap.className = 'wx-ctrl wx-volume-wrap';
    var volIcon = document.createElement('div');
    volIcon.id = 'wxVolIcon';
    volIcon.innerHTML = IC.volOn;
    volIcon.style.cursor = 'pointer';
    volIcon.onclick = function() { if (!art || !art.video) return; art.video.muted = !art.video.muted; updateVol(); };
    volWrap.appendChild(volIcon);
    var volSlider = document.createElement('div');
    volSlider.className = 'wx-volume-slider';
    volSlider.innerHTML = '<div class="wx-vol-track" id="wxVolTrack"><div class="wx-vol-fill" id="wxVolFill" style="width:70%"></div><div class="wx-vol-thumb" id="wxVolThumb" style="left:70%"></div></div>';
    volWrap.appendChild(volSlider);
    var volDrag = false;
    function setVol(e) {
      var t = document.getElementById('wxVolTrack');
      if (!t || !art || !art.video) return;
      var r = t.getBoundingClientRect();
      var p = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
      art.video.volume = p; art.video.muted = p === 0; updateVol();
    }
    volSlider.addEventListener('mousedown', function(e) { volDrag = true; setVol(e); });
    document.addEventListener('mousemove', function(e) { if (volDrag) setVol(e); });
    document.addEventListener('mouseup', function() { volDrag = false; });
    controlsEl.appendChild(volWrap);

    /* Time */
    var timeEl = document.createElement('div');
    timeEl.className = 'wx-time';
    timeEl.id = 'wxTimeDisplay';
    timeEl.textContent = '0:00 / 0:00';
    controlsEl.appendChild(timeEl);

    /* Spacer */
    var spacer = document.createElement('div');
    spacer.className = 'wx-spacer';
    controlsEl.appendChild(spacer);

    /* Subtitle */
    controlsEl.appendChild(mkCtrl(IC.sub, null, 'Subtitles', function() { notice('No subtitles available'); }));

    /* Audio */
    controlsEl.appendChild(mkCtrl(IC.audio, null, 'Audio', function() { notice('Audio: Default'); }));

    /* Quality */
    controlsEl.appendChild(mkCtrl(IC.quality, null, 'Quality', function(e) { e.stopPropagation(); openSettingsSub('quality'); }));

    /* Speed */
    controlsEl.appendChild(mkCtrl(IC.speed, null, 'Speed', function(e) { e.stopPropagation(); openSettingsSub('speed'); }));

    /* Settings */
    var setBtn = mkCtrl(IC.settings, 'wxSettingsBtn', 'Settings', function(e) { e.stopPropagation(); toggleSettings(); });
    controlsEl.appendChild(setBtn);

    /* PiP */
    controlsEl.appendChild(mkCtrl(IC.pip, null, 'Picture in Picture', wxPiP));

    /* Fullscreen */
    var fsBtn = mkCtrl(IC.fs, 'wxFsBtn', 'Fullscreen', function() {
      if (!art || !art.video) return;
      if (document.fullscreenElement) document.exitFullscreen();
      else container.requestFullscreen().catch(function() { notice('Fullscreen not available'); });
    });
    controlsEl.appendChild(fsBtn);
  }

  function mkCtrl(svg, id, title, onclick) {
    var d = document.createElement('div');
    d.className = 'wx-ctrl';
    if (id) d.id = id;
    if (title) d.title = title;
    d.innerHTML = svg;
    if (onclick) d.onclick = onclick;
    return d;
  }

  /* ===== VOLUME UI ===== */
  function updateVol() {
    if (!art || !art.video) return;
    var vol = art.video.muted ? 0 : art.video.volume;
    var icon = document.getElementById('wxVolIcon');
    if (icon) icon.innerHTML = vol === 0 ? IC.volOff : IC.volOn;
    var fill = document.getElementById('wxVolFill');
    var thumb = document.getElementById('wxVolThumb');
    if (fill) fill.style.width = (vol * 100) + '%';
    if (thumb) thumb.style.left = (vol * 100) + '%';
  }

  /* ===== PROGRESS BAR ===== */
  function setupProgress() {
    var track = document.getElementById('wxProgressTrack');
    if (!track) return;

    track.addEventListener('click', function(e) {
      if (!art || !art.video) return;
      var r = track.getBoundingClientRect();
      art.video.currentTime = ((e.clientX - r.left) / r.width) * art.video.duration;
    });

    var thumbPreview = document.getElementById('wxThumbPreview');
    var thumbTime = document.getElementById('wxThumbTime');
    var thumbImg = document.getElementById('wxThumbImg');
    var thumbEl = document.getElementById('wxThumb');
    var playedEl = document.getElementById('wxPlayed');

    track.addEventListener('mousemove', function(e) {
      var r = track.getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width));
      var time = pct * (art && art.video ? art.video.duration : 0);
      if (thumbEl) thumbEl.style.left = (pct * 100) + '%';
      if (playedEl) playedEl.style.width = (pct * 100) + '%';
      if (thumbPreview) {
        var px = Math.max(80, Math.min(r.width - 80, e.clientX - r.left));
        thumbPreview.style.left = px + 'px';
        thumbPreview.style.display = 'block';
      }
      if (thumbTime) thumbTime.textContent = fmt(time);
      if (thumbImg) thumbImg.style.display = 'block';
    });

    track.addEventListener('mouseleave', function() {
      if (thumbPreview) thumbPreview.style.display = 'none';
    });
  }

  /* ===== DOUBLE-CLICK SEEK ===== */
  var lastClickTime = 0;
  container.addEventListener('click', function(e) {
    if (e.target.closest('.wx-controls') || e.target.closest('.wx-top-bar') || e.target.closest('.wx-settings-panel')) return;
    var now = Date.now();
    if (now - lastClickTime < 300) {
      var r = container.getBoundingClientRect();
      var x = e.clientX - r.left;
      if (x < r.width / 3) {
        if (art && art.video) { art.video.currentTime = Math.max(0, art.video.currentTime - 10); notice('-10s'); }
      } else {
        if (art && art.video) { art.video.currentTime = Math.min(art.video.duration || 0, art.video.currentTime + 10); notice('+10s'); }
      }
      lastClickTime = 0;
    } else {
      lastClickTime = now;
    }
  });

  /* ===== SETTINGS PANEL ===== */
  var settingsView = 'main';
  var ss = { quality: 'Auto', speed: 1, subtitle: 'Off', audio: 'Default', autoPlayNext: true, skipIntro: false, skipOutro: false };
  var settingsPanel = document.getElementById('wxSettingsPanel');

  function toggleSettings() {
    if (settingsPanel.classList.contains('open')) { settingsPanel.classList.remove('open'); }
    else { settingsView = 'main'; renderSettings(); settingsPanel.classList.add('open'); }
  }
  function openSettingsSub(v) { settingsView = v; renderSettings(); settingsPanel.classList.add('open'); }

  function renderSettings() {
    settingsPanel.innerHTML = '';
    if (settingsView === 'main') renderMain();
    else if (settingsView === 'quality') renderQuality();
    else if (settingsView === 'speed') renderSpeed();
    else if (settingsView === 'subtitle-opts') renderSubOpts();
    else if (settingsView === 'audio-opts') renderAudioOpts();
  }

  function renderMain() {
    addSI('Video Quality', ss.quality, function() { openSettingsSub('quality'); });
    settingsPanel.appendChild(mkDiv());
    addSI('Playback Speed', ss.speed + 'x', function() { openSettingsSub('speed'); });
    settingsPanel.appendChild(mkDiv());
    addSI('Subtitle', ss.subtitle, function() { openSettingsSub('subtitle-opts'); });
    settingsPanel.appendChild(mkDiv());
    addSI('Audio Language', ss.audio, function() { openSettingsSub('audio-opts'); });
    settingsPanel.appendChild(mkDiv());

    /* Auto Play Next */
    var ap = document.createElement('div');
    ap.className = 'wx-sp-item';
    ap.innerHTML = '<span class="wx-sp-label">Auto Play Next</span><div class="wx-toggle ' + (ss.autoPlayNext ? 'on' : '') + '"></div>';
    ap.onclick = function() { ss.autoPlayNext = !ss.autoPlayNext; renderSettings(); notice('Auto Play: ' + (ss.autoPlayNext ? 'On' : 'Off')); };
    settingsPanel.appendChild(ap);
    settingsPanel.appendChild(mkDiv());

    /* Skip Intro */
    var si = document.createElement('div');
    si.className = 'wx-sp-item';
    si.innerHTML = '<span class="wx-sp-label">Skip Intro</span><div class="wx-toggle ' + (ss.skipIntro ? 'on' : '') + '"></div>';
    si.onclick = function() { ss.skipIntro = !ss.skipIntro; renderSettings(); notice('Skip Intro: ' + (ss.skipIntro ? 'On' : 'Off')); };
    settingsPanel.appendChild(si);
    settingsPanel.appendChild(mkDiv());

    /* Skip Outro */
    var so = document.createElement('div');
    so.className = 'wx-sp-item';
    so.innerHTML = '<span class="wx-sp-label">Skip Outro</span><div class="wx-toggle ' + (ss.skipOutro ? 'on' : '') + '"></div>';
    so.onclick = function() { ss.skipOutro = !ss.skipOutro; renderSettings(); notice('Skip Outro: ' + (ss.skipOutro ? 'On' : 'Off')); };
    settingsPanel.appendChild(so);
  }

  function renderQuality() {
    addBackHeader('Quality');
    settingsPanel.appendChild(mkDiv());
    ['Auto', '4K', '1080p', '720p', '480p', '360p'].forEach(function(q) {
      var item = document.createElement('div');
      item.className = 'wx-sp-item' + (q === ss.quality ? ' active' : '');
      var check = q === ss.quality ? '<svg viewBox="0 0 24 24" fill="#3B82F6" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '';
      item.innerHTML = '<span class="wx-sp-label">' + q + '</span><span class="wx-sp-value">' + check + '</span>';
      item.onclick = function() { ss.quality = q; settingsView = 'main'; renderSettings(); notice('Quality: ' + q); };
      settingsPanel.appendChild(item);
    });
  }

  function renderSpeed() {
    addBackHeader('Playback Speed');
    settingsPanel.appendChild(mkDiv());
    [0.25, 0.5, 0.75, 1, 1.25, 1.5, 1.75, 2].forEach(function(s) {
      var item = document.createElement('div');
      item.className = 'wx-sp-item' + (s === ss.speed ? ' active' : '');
      var check = s === ss.speed ? '<svg viewBox="0 0 24 24" fill="#3B82F6" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '';
      item.innerHTML = '<span class="wx-sp-label">' + s + 'x' + (s === 1 ? ' (Normal)' : '') + '</span><span class="wx-sp-value">' + check + '</span>';
      item.onclick = function() { ss.speed = s; if (art && art.video) art.video.playbackRate = s; settingsView = 'main'; renderSettings(); notice('Speed: ' + s + 'x'); };
      settingsPanel.appendChild(item);
    });
  }

  function renderSubOpts() {
    addBackHeader('Subtitle');
    settingsPanel.appendChild(mkDiv());
    ['Off', 'English', 'Hindi', 'Spanish', 'Japanese'].forEach(function(lang) {
      var item = document.createElement('div');
      item.className = 'wx-sp-item' + (lang === ss.subtitle ? ' active' : '');
      var check = lang === ss.subtitle ? '<svg viewBox="0 0 24 24" fill="#3B82F6" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '';
      item.innerHTML = '<span class="wx-sp-label">' + lang + '</span><span class="wx-sp-value">' + check + '</span>';
      item.onclick = function() { ss.subtitle = lang; settingsView = 'main'; renderSettings(); notice('Subtitle: ' + lang); };
      settingsPanel.appendChild(item);
    });
  }

  function renderAudioOpts() {
    addBackHeader('Audio Language');
    settingsPanel.appendChild(mkDiv());
    ['Default', 'English', 'Hindi', 'Japanese'].forEach(function(a) {
      var item = document.createElement('div');
      item.className = 'wx-sp-item' + (a === ss.audio ? ' active' : '');
      var check = a === ss.audio ? '<svg viewBox="0 0 24 24" fill="#3B82F6" width="16" height="16"><polyline points="20 6 9 17 4 12" fill="none" stroke="#3B82F6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' : '';
      item.innerHTML = '<span class="wx-sp-label">' + a + '</span><span class="wx-sp-value">' + check + '</span>';
      item.onclick = function() { ss.audio = a; settingsView = 'main'; renderSettings(); notice('Audio: ' + a); };
      settingsPanel.appendChild(item);
    });
  }

  function addSI(label, value, onClick) {
    var item = document.createElement('div');
    item.className = 'wx-sp-item';
    item.innerHTML = '<span class="wx-sp-label">' + label + '</span><span class="wx-sp-value">' + value + ' ' + IC.chev + '</span>';
    item.onclick = onClick;
    settingsPanel.appendChild(item);
  }

  function addBackHeader(title) {
    var h = document.createElement('div');
    h.className = 'wx-sp-item';
    h.innerHTML = '<span class="wx-sp-label" style="display:flex;align-items:center;gap:8px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="16" height="16"><polyline points="15 18 9 12 15 6"/></svg>' + title + '</span>';
    h.onclick = function() { settingsView = 'main'; renderSettings(); };
    settingsPanel.appendChild(h);
  }

  function mkDiv() { var d = document.createElement('div'); d.className = 'wx-sp-divider'; return d; }

  /* Close settings on outside click */
  document.addEventListener('click', function(e) {
    if (settingsPanel.classList.contains('open') && !settingsPanel.contains(e.target) && !e.target.closest('#wxSettingsBtn')) {
      settingsPanel.classList.remove('open');
    }
  });

  /* ===== THEATER MODE ===== */
  window.wxToggleTheater = function() {
    var is = container.classList.toggle('theater-mode');
    document.getElementById('theaterOverlay').classList.toggle('active', is);
    notice(is ? 'Theater Mode' : 'Normal Mode');
  };
  window.wxExitTheater = function() {
    container.classList.remove('theater-mode');
    document.getElementById('theaterOverlay').classList.remove('active');
  };

  /* ===== PiP ===== */
  window.wxPiP = function() {
    if (!art || !art.video) return;
    if (document.pictureInPictureElement) document.exitPictureInPicture();
    else if (document.pictureInPictureEnabled) art.video.requestPictureInPicture().catch(function() { notice('PiP not available'); });
    else notice('PiP not supported');
  };

  /* ===== FULLSCREEN LISTENERS ===== */
  document.addEventListener('fullscreenchange', function() {
    var btn = document.getElementById('wxFsBtn');
    if (btn) btn.innerHTML = document.fullscreenElement ? IC.fsExit : IC.fs;
  });

  /* ===== SKIP INTRO LOGIC ===== */
  var skipTimer = null;
  function checkSkipIntro(time) {
    /* Show skip intro at 30s for 15s (configurable) */
    var overlay = document.getElementById('wxSkipOverlay');
    var btn = document.getElementById('wxSkipBtn');
    if (!overlay || !btn) return;
    if (ss.skipIntro && time >= 30 && time <= 45) {
      overlay.classList.add('visible');
      btn.textContent = 'Skip Intro';
      btn.onclick = function() { if (art && art.video) { art.video.currentTime = 45; overlay.classList.remove('visible'); } };
    } else if (ss.skipOutro && time >= art.duration - 60 && time < art.duration - 45) {
      overlay.classList.add('visible');
      btn.textContent = 'Skip Recap';
      btn.onclick = function() { if (art && art.video) { art.video.currentTime = art.duration - 45; overlay.classList.remove('visible'); } };
    } else {
      overlay.classList.remove('visible');
    }
  }

  /* ===== NEXT EPISODE LOGIC ===== */
  var nextEpTimer = null;
  function showNextEpisode() {
    <% if (episodes.length > 0) { %>
      <% const nextEp = episodes.find(e => e.number === ep + 1); %>
      <% if (nextEp) { %>
        var epOverlay = document.getElementById('wxNextEp');
        var nextImg = document.getElementById('wxNextImg');
        var nextTitle = document.getElementById('wxNextTitle');
        var nextEpNum = document.getElementById('wxNextEpNum');
        var nextTimer = document.getElementById('wxNextTimer');
        var nextCard = document.getElementById('wxNextCard');

        if (nextImg) nextImg.src = '<%= item.poster %>';
        if (nextTitle) nextTitle.textContent = '<%= nextEp.title %>';
        if (nextEpNum) nextEpNum.textContent = 'Episode <%= nextEp.number %>';
        if (nextCard) nextCard.onclick = function() { window.location.href = '/watch/<%= type %>/<%= item.id %>?ep=<%= nextEp.number %>'; };
        epOverlay.classList.add('visible');

        var countdown = 10;
        if (nextTimer) nextTimer.textContent = 'Playing in ' + countdown + 's...';
        nextEpTimer = setInterval(function() {
          countdown--;
          if (nextTimer) nextTimer.textContent = 'Playing in ' + countdown + 's...';
          if (countdown <= 0) {
            clearInterval(nextEpTimer);
            window.location.href = '/watch/<%= type %>/<%= item.id %>?ep=<%= nextEp.number %>';
          }
        }, 1000);
      <% } %>
    <% } %>
  }

  /* ===== RESUME FROM LAST POSITION ===== */
  function getResumeKey() {
    return 'wx_resume_' + '<%= item.id %>' + <% if (currentEpisode) { %> '_ep<%= currentEpisode.number %>' <% } else { %> '' <% } %>;
  }

  function saveResume(time) {
    try { localStorage.setItem(getResumeKey(), Math.floor(time)); } catch(e) {}
  }

  function loadResume() {
    try {
      var t = parseInt(localStorage.getItem(getResumeKey()));
      return (t && t > 5) ? t : 0;
    } catch(e) { return 0; }
  }

  function clearResume() {
    try { localStorage.removeItem(getResumeKey()); } catch(e) {}
  }

  /* ===== ARTPLAYER CONFIG ===== */
  var playerConfig = {
    container: '#artplayer-app',
    url: videoUrl,
    type: videoType,
    poster: '<%= item.backdrop || item.poster %>',
    theme: '#3B82F6',
    volume: 0.7,
    muted: false,
    autoplay: false,
    pip: false,
    autoSize: false,
    autoMini: true,
    screenshot: false,
    setting: false,
    loop: false,
    flip: false,
    playbackRate: false,
    aspectRatio: false,
    fullscreen: false,
    fullscreenWeb: false,
    subtitleOffset: false,
    miniProgressBar: false,
    mutex: true,
    backdrop: true,
    playsInline: true,
    autoPlayback: true,
    airplay: false,
    hotkey: true,
    lock: true,
    lang: navigator.language.toLowerCase() === 'zh-cn' ? 'zh-cn' : 'en',
    moreVideoAttr: { crossOrigin: 'anonymous' },
    settings: [],
    controls: [],
    layers: [],
    contextmenu: [
      { html: 'STREAMX Player', click: function(ctx) { ctx.show = false; } },
      { html: 'Space=Play/Pause | \u2190/\u2192=\u00b110s | \u2191/\u2193=Volume | F=Fullscreen | M=Mute | T=Theater | P=PiP | Double-click=Seek', click: function(ctx) { ctx.show = false; } }
    ],
    icons: {
      loading: '<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;"><div style="width:44px;height:44px;border:3px solid rgba(255,255,255,0.15);border-top-color:#3B82F6;border-radius:50%;animation:art-loading 0.8s linear infinite;"></div></div>',
      state: '<svg width="56" height="56" viewBox="0 0 24 24" fill="white" opacity="0.85"><path d="M8 5v14l11-7z"/></svg>',
      indicator: '<svg width="16" height="16" viewBox="0 0 24 24" fill="#3B82F6"><circle cx="12" cy="12" r="10"/></svg>'
    }
  };

  /* ===== HLS / DASH Custom Type ===== */
  if (videoType === 'm3u8' || videoType === 'mpd') {
    playerConfig.customType = {
      m3u8: function(video, url) {
        if (typeof Hls !== 'undefined' && Hls.isSupported()) {
          var hls = new Hls({ enableWorker: true, lowLatencyMode: false });
          hls.loadSource(url);
          hls.attachMedia(video);
          hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play().catch(function(){}); });
          hls.on(Hls.Events.ERROR, function(event, data) {
            if (data.fatal) {
              if (data.type === Hls.ErrorTypes.NETWORK_ERROR) { notice('Network error \u2014 reconnecting...'); hls.startLoad(); }
              else if (data.type === Hls.ErrorTypes.MEDIA_ERROR) { notice('Media error \u2014 recovering...'); hls.recoverMediaError(); }
              else { notice('Fatal stream error'); hls.destroy(); }
            }
          });
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = url;
        } else {
          notice('HLS not supported in this browser');
        }
      },
      mpd: function(video, url) {
        if (typeof dashjs !== 'undefined') {
          var dp = dashjs.MediaPlayer().create();
          dp.updateSettings({ streaming: { abr: { autoSwitchBitrate: { video: true } } } });
          dp.initialize(video, url, false);
        } else {
          notice('DASH player not loaded');
        }
      }
    };
  }

  /* ===== CREATE PLAYER ===== */
  art = new Artplayer(playerConfig);
  buildControls();
  setupProgress();
  showControls();

  /* Hide ArtPlayer default bottom bar */
  var artBottom = container.querySelector('.art-bottom');
  if (artBottom) artBottom.style.display = 'none';

  /* Resume from last position */
  var resumeTime = loadResume();
  if (resumeTime > 5) {
    art.on('video:loadedmetadata', function() {
      art.video.currentTime = resumeTime;
      notice('Resumed from ' + fmt(resumeTime));
    });
  }

  /* ===== VIDEO EVENT HANDLERS ===== */
  art.on('video:play', function() {
    var btn = document.getElementById('wxPlayBtn');
    if (btn) btn.innerHTML = IC.pause;
  });
  art.on('video:pause', function() {
    var btn = document.getElementById('wxPlayBtn');
    if (btn) btn.innerHTML = IC.play;
  });
  art.on('video:ended', function() {
    var btn = document.getElementById('wxPlayBtn');
    if (btn) btn.innerHTML = IC.play;
    clearResume();
    showNextEpisode();
  });

  /* Time & progress update */
  art.on('video:timeupdate', function() {
    if (!art.duration) return;
    var pct = (art.currentTime / art.duration) * 100;

    var td = document.getElementById('wxTimeDisplay');
    if (td) td.textContent = fmt(art.currentTime) + ' / ' + fmt(art.duration);

    var played = document.getElementById('wxPlayed');
    if (played) played.style.width = pct + '%';

    var thumb = document.getElementById('wxThumb');
    if (thumb) thumb.style.left = pct + '%';

    var mini = document.getElementById('wxMiniProgInner');
    if (mini) mini.style.width = pct + '%';

    /* Skip intro check */
    checkSkipIntro(art.currentTime);

    /* Save resume position */
    saveResume(art.currentTime);

    /* Continue watching API (every 25%) */
    var progress = Math.floor(pct);
    if (progress > 0 && progress % CONTINUE_WATCH_INTERVAL === 0) {
      fetch('/api/continue-watching', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contentId: <%= item.id %>,
          type: '<%= item.type %>',
          progress: progress,
          currentTime: Math.floor(art.currentTime)
        })
      }).catch(function() {});
    }
  });

  /* Buffered progress */
  art.on('video:progress', function() {
    if (!art.video || !art.duration) return;
    var buff = art.video.buffered;
    if (buff && buff.length > 0) {
      var end = buff.end(buff.length - 1);
      var pct = (end / art.duration) * 100;
      var bufEl = document.getElementById('wxBuffered');
      if (bufEl) bufEl.style.width = pct + '%';
    }
  });

  /* Loading state */
  art.on('video:waiting', function() { notice('Buffering...'); });
  art.on('video:error', function() { notice('Unable to play this video.'); });

  /* Volume init */
  art.on('video:volumechange', updateVol);

  /* ===== KEYBOARD SHORTCUTS ===== */
  document.addEventListener('keydown', function(e) {
    if (!art || !art.video) return;
    var tag = (e.target.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
    switch (e.key.toLowerCase()) {
      case ' ':
      case 'k':
        e.preventDefault();
        art.video.paused ? art.video.play() : art.video.pause();
        break;
      case 'arrowleft':
        e.preventDefault();
        art.video.currentTime = Math.max(0, art.video.currentTime - 10);
        notice('-10s');
        break;
      case 'arrowright':
        e.preventDefault();
        art.video.currentTime = Math.min(art.video.duration || 0, art.video.currentTime + 10);
        notice('+10s');
        break;
      case 'arrowup':
        e.preventDefault();
        art.video.volume = Math.min(1, art.video.volume + 0.1);
        art.video.muted = false;
        updateVol();
        break;
      case 'arrowdown':
        e.preventDefault();
        art.video.volume = Math.max(0, art.video.volume - 0.1);
        updateVol();
        break;
      case 'f':
        e.preventDefault();
        if (document.fullscreenElement) document.exitFullscreen();
        else container.requestFullscreen();
        break;
      case 'm':
        e.preventDefault();
        art.video.muted = !art.video.muted;
        updateVol();
        notice(art.video.muted ? 'Muted' : 'Unmuted');
        break;
      case 'p':
        e.preventDefault();
        window.wxPiP();
        break;
      case 't':
        e.preventDefault();
        window.wxToggleTheater();
        break;
      case 'escape':
        window.wxExitTheater();
        closeSidebar();
        if (settingsPanel.classList.contains('open')) settingsPanel.classList.remove('open');
        break;
    }
  });

  /* ===== SIDEBAR ===== */
  window.openSidebar = function() { document.getElementById('watchSidebar').classList.add('open'); };
  window.closeSidebar = function() { document.getElementById('watchSidebar').classList.remove('open'); };

  /* ===== COLLAPSIBLE SECTIONS ===== */
  window.toggleSection = function(id) {
    var el = document.getElementById(id);
    var toggle = document.getElementById(id + 'Toggle');
    if (!el) return;
    if (el.classList.contains('collapsed')) {
      el.classList.remove('collapsed');
      el.style.maxHeight = el.scrollHeight + 'px';
      el.style.opacity = '1';
      setTimeout(function() { el.style.maxHeight = 'none'; }, 350);
    } else {
      el.style.maxHeight = el.scrollHeight + 'px';
      requestAnimationFrame(function() {
        el.classList.add('collapsed');
        el.style.maxHeight = '0';
        el.style.opacity = '0';
      });
    }
  };

  /* ===== DESCRIPTION TOGGLE ===== */
  window.toggleDesc = function() {
    var desc = document.getElementById('watchDesc');
    var btn = document.getElementById('watchDescToggle');
    if (!desc) return;
    if (desc.classList.contains('expanded')) {
      desc.classList.remove('expanded');
      btn.textContent = 'Show more';
    } else {
      desc.classList.add('expanded');
      btn.textContent = 'Show less';
    }
  };

})();
</script>
