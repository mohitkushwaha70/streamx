<%- include('../partials/header', { pageTitle: 'Upload Content' }) %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Upload Content</h1>
      <p style="color:#888;margin-top:4px;">Add movies, series, or anime directly</p>
    </div>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

    <div class="admin-card" style="max-width:700px;">
      <h3 style="margin-bottom:16px;">Add New Content</h3>
      <form method="POST" action="/admin/upload">
        <div class="form-group" style="margin-bottom:14px;">
          <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Title *</label>
          <input type="text" name="title" required placeholder="Movie / Series title"
            style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
        </div>

        <div style="display:flex;gap:12px;margin-bottom:14px;">
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Type</label>
            <select name="type" style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
              <option value="movie">Movie</option>
              <option value="series">Series</option>
              <option value="anime">Anime</option>
            </select>
          </div>
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Genre</label>
            <input type="text" name="genre" placeholder="Action, Drama..."
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
        </div>

        <div style="display:flex;gap:12px;margin-bottom:14px;">
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Year</label>
            <input type="number" name="year" value="2024" placeholder="2024"
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Rating</label>
            <input type="number" name="rating" step="0.1" min="0" max="10" value="7.0" placeholder="7.0"
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Duration</label>
            <input type="text" name="duration" placeholder="2h 15m"
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
        </div>

        <div class="form-group" style="margin-bottom:14px;">
          <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Video URL *</label>
          <input type="url" name="videoUrl" required placeholder="https://huggingface.co/... or YouTube URL"
            style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
        </div>

        <div class="form-group" style="margin-bottom:14px;">
          <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Video Type</label>
          <select name="videoType" style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
            <option value="auto">Auto-detect</option>
            <option value="mp4">MP4</option>
            <option value="youtube">YouTube</option>
          </select>
        </div>

        <div class="form-group" style="margin-bottom:14px;">
          <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Description</label>
          <textarea name="description" rows="3" placeholder="Short description..."
            style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;"></textarea>
        </div>

        <div style="display:flex;gap:12px;margin-bottom:14px;">
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Poster URL</label>
            <input type="url" name="poster" placeholder="https://... (auto-generates if empty)"
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
          <div class="form-group" style="flex:1;">
            <label style="display:block;color:#ccc;margin-bottom:4px;font-size:13px;">Backdrop URL</label>
            <input type="url" name="backdrop" placeholder="https://... (auto-generates if empty)"
              style="width:100%;padding:10px;background:#1a1a2e;border:1px solid #333;color:#fff;border-radius:6px;">
          </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;padding:12px;font-size:15px;">
          Save to Website
        </button>
      </form>
    </div>

    <% if (uploadedMovies && uploadedMovies.length > 0) { %>
    <div class="admin-card" style="margin-top:20px;">
      <h3 style="margin-bottom:16px;">All Content (<%= uploadedMovies.length %>)</h3>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr><th>#</th><th>Title</th><th>Type</th><th>Genre</th><th>Year</th><th>Rating</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% uploadedMovies.forEach((m, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <div class="user-cell">
                  <% if (m.poster) { %><img src="<%= m.poster %>" class="table-thumb" alt="<%= m.title %>"><% } %>
                  <div>
                    <strong><%= m.title %></strong>
                  </div>
                </div>
              </td>
              <td><span class="table-badge"><%= m.type %></span></td>
              <td><span class="table-badge"><%= m.genre %></span></td>
              <td><%= m.year %></td>
              <td>★ <%= m.rating %></td>
              <td>
                <div class="action-btns">
                  <a href="/watch/<%= m.type %>/<%= m.id %>" class="btn-icon-sm" title="Watch" target="_blank">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </a>
                  <a href="/admin/upload/delete/<%= m.id %>" class="btn-icon-sm danger" title="Remove" onclick="return confirm('Remove this content?')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </a>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>
  </main>
</div>
