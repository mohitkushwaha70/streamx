<%- include('partials/header', { pageTitle: 'Series' }) %>
<%- include('partials/navbar', { active: 'series' }) %>

<main class="main-content page-content">
  <div class="page-header">
    <h1>Series</h1>
    <p>Explore <%= series.length %> binge-worthy series</p>
  </div>

  <div class="section">
    <div class="filter-bar">
      <div class="genre-grid">
        <a href="/series" class="genre-chip <%= !currentGenre ? 'active' : '' %>">All</a>
        <% genres.forEach(g => { %>
        <a href="/series?genre=<%= g %>" class="genre-chip <%= currentGenre === g ? 'active' : '' %>"><%= g %></a>
        <% }) %>
      </div>
    </div>

    <div class="content-grid">
      <% series.forEach(item => { %>
      <a href="/series/<%= item.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= item.poster %>" alt="<%= item.title %>" loading="lazy">
          <% if (item.premium) { %><span class="card-badge premium">⭐ PREMIUM</span><% } %>
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= item.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= item.rating %></span>
            <span class="dot"></span>
            <span><%= item.seasons %> Season<%= item.seasons > 1 ? 's' : '' %></span>
            <span class="dot"></span>
            <span><%= item.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
