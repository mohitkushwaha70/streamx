<%- include('partials/header', { pageTitle: item.title }) %>
<%- include('partials/navbar', { active: type === 'movie' ? 'movies' : 'series' }) %>

<main class="main-content">
  <!-- Detail Hero -->
  <section class="detail-hero">
    <div class="hero-bg" style="background-image: url('<%= item.backdrop %>')"></div>
    <div class="hero-content detail-content">
      <div class="hero-badge">
        <% if (item.premium) { %>⭐ PREMIUM<% } else { %>🔥 <%= type === 'series' ? item.seasons + ' Season' + (item.seasons > 1 ? 's' : '') : item.duration %><% } %>
      </div>
      <h1 class="hero-title"><%= item.title %></h1>
      <div class="hero-meta">
        <span class="rating">★ <%= item.rating %></span>
        <span><%= item.year %></span>
        <span><%= item.genre %></span>
        <% if (item.cast) { %><span><%= item.cast %></span><% } %>
        <% if (item.director) { %><span>Dir: <%= item.director %></span><% } %>
      </div>
      <p class="hero-desc"><%= item.description %></p>
      <div class="hero-actions">
        <a href="/watch/<%= type %>/<%= item.id %>" class="btn btn-primary btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          Watch Now
        </a>
        <% if (user) { %>
        <form action="/watchlist/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(255,255,255,0.1);border:1.5px solid rgba(255,255,255,0.3);box-shadow:none;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
            Watchlist
          </button>
        </form>
        <form action="/watchlist/favorite/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(239,68,68,0.15);border:1.5px solid rgba(239,68,68,0.4);box-shadow:none;color:#ef4444;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            Favorite
          </button>
        </form>
        <form action="/watchlist/saved/add" method="POST" style="display:inline">
          <input type="hidden" name="id" value="<%= item.id %>">
          <button type="submit" class="btn btn-primary btn-lg" style="background:rgba(168,85,247,0.15);border:1.5px solid rgba(168,85,247,0.4);box-shadow:none;color:#a855f7;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/></svg>
            Save
          </button>
        </form>
        <% } else { %>
        <button class="btn btn-primary btn-lg" style="background:rgba(255,255,255,0.1);border:1.5px solid rgba(255,255,255,0.3);box-shadow:none;" onclick="document.getElementById('authModal') && document.getElementById('authModal').classList.add('active')">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          Watchlist
        </button>
        <% } %>
      </div>
    </div>
  </section>

  <% if (item.episodes && item.episodes.length > 0) { %>
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Episodes</h2>
      <% if (item.seasonsList && item.seasonsList.length > 1) { %>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <% item.seasonsList.filter(s => s.season_number > 0).forEach(s => { %>
        <a href="/series/<%= item.id %>?season=<%= s.season_number %>" class="btn btn-sm btn-outline" style="<%= (typeof currentSeason !== 'undefined' && currentSeason === s.season_number) ? 'background:var(--accent);color:#fff;' : '' %>">
          Season <%= s.season_number %>
        </a>
        <% }) %>
      </div>
      <% } %>
    </div>
    <div class="episodes-list">
      <% item.episodes.forEach(ep => { %>
      <a href="/watch/series/<%= item.id %>?ep=<%= ep.number %><%= typeof currentSeason !== 'undefined' ? '&season=' + currentSeason : '' %>" class="episode-card">
        <% if (ep.poster) { %>
        <div style="width:120px;height:68px;border-radius:6px;overflow:hidden;flex-shrink:0;">
          <img src="<%= ep.poster %>" alt="<%= ep.title %>" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
        </div>
        <% } %>
        <div class="ep-number"><%= ep.number %></div>
        <div class="ep-info">
          <h4><%= ep.title %></h4>
          <p><%= ep.description %></p>
        </div>
        <div class="ep-duration"><%= ep.duration %></div>
        <div class="ep-play">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Related -->
  <% if (related.length > 0) { %>
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">You May Also <span class="accent">Like</span></h2>
    </div>
    <div class="content-grid">
      <% related.forEach(r => { %>
      <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="content-card">
        <div class="card-image">
          <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
          <div class="card-overlay">
            <div class="play-btn">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
        </div>
        <div class="card-info">
          <div class="card-title"><%= r.title %></div>
          <div class="card-meta">
            <span class="rating">★ <%= r.rating %></span>
            <span class="dot"></span>
            <span><%= r.genre %></span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>
