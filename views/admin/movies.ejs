<%- include('../partials/header', { pageTitle: 'Manage Movies' }) %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <h1>Manage Movies</h1>
      <a href="/admin/movies/add" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Movie
      </a>
    </div>

    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

    <div class="admin-card">
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr><th>#</th><th>Movie</th><th>Genre</th><th>Year</th><th>Rating</th><th>Premium</th><th>Actions</th></tr>
          </thead>
          <tbody>
            <% movies.forEach((m, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <div class="user-cell">
                  <img src="<%= m.poster %>" class="table-thumb" alt="<%= m.title %>">
                  <strong><%= m.title %></strong>
                </div>
              </td>
              <td><span class="table-badge"><%= m.genre %></span></td>
              <td><%= m.year %></td>
              <td>★ <%= m.rating %></td>
              <td><span class="plan-badge <%= m.premium ? 'premium' : 'free' %>"><%= m.premium ? 'Premium' : 'Free' %></span></td>
              <td>
                <div class="action-btns">
                  <a href="/admin/movies/edit/<%= m.id %>" class="btn-icon-sm" title="Edit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                  </a>
                  <a href="/watch/movie/<%= m.id %>" class="btn-icon-sm" title="Watch" target="_blank">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </a>
                  <a href="/admin/movies/delete/<%= m.id %>" class="btn-icon-sm danger" title="Delete" onclick="return confirm('Delete this movie?')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  </a>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/footer') %>
