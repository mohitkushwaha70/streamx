<%- include('../partials/header', { pageTitle: 'Payments - STREAMX Admin' }) %>

<div class="admin-layout">
  <%- include('../partials/admin-sidebar') %>
  <main class="admin-main">
    <div class="admin-header">
      <div>
        <h1>Payments & Revenue</h1>
        <p style="color:#555;font-size:0.85rem;">Track all payments and revenue</p>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon gold"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
        <div class="stat-info"><span class="stat-number">₹48.5L</span><span class="stat-label">Total Revenue</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon green"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
        <div class="stat-info"><span class="stat-number">₹4.2L</span><span class="stat-label">This Month</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon blue"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg></div>
        <div class="stat-info"><span class="stat-number">142</span><span class="stat-label">Transactions</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
        <div class="stat-info"><span class="stat-number">₹2,999</span><span class="stat-label">Avg. Transaction</span></div>
      </div>
    </div>

    <div class="admin-card">
      <div class="admin-card-header">
        <h3>Recent Transactions</h3>
      </div>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead><tr><th>User</th><th>Plan</th><th>Amount</th><th>Method</th><th>Date</th><th>Status</th></tr></thead>
          <tbody>
            <tr><td><div class="user-cell"><div class="avatar-sm">A</div><strong>Admin</strong></div></td><td>Premium Yearly</td><td style="color:#22c55e">₹2,999</td><td>UPI</td><td>Jul 11, 2026</td><td><span class="plan-badge premium">Paid</span></td></tr>
            <tr><td><div class="user-cell"><div class="avatar-sm">M</div><strong>Mohit</strong></div></td><td>Premium Monthly</td><td style="color:#22c55e">₹299</td><td>Card</td><td>Jul 10, 2026</td><td><span class="plan-badge premium">Paid</span></td></tr>
            <tr><td><div class="user-cell"><div class="avatar-sm">A</div><strong>Amit Singh</strong></div></td><td>Premium Yearly</td><td style="color:#22c55e">₹2,999</td><td>UPI</td><td>Jul 9, 2026</td><td><span class="plan-badge premium">Paid</span></td></tr>
            <tr><td><div class="user-cell"><div class="avatar-sm">R</div><strong>Rahul Kumar</strong></div></td><td>Free</td><td style="color:#666">₹0</td><td>-</td><td>Jul 8, 2026</td><td><span class="plan-badge free">Free</span></td></tr>
            <tr><td><div class="user-cell"><div class="avatar-sm">P</div><strong>Priya Sharma</strong></div></td><td>Free</td><td style="color:#666">₹0</td><td>-</td><td>Jul 7, 2026</td><td><span class="plan-badge free">Free</span></td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="admin-grid" style="margin-top: 20px;">
      <div class="admin-card">
        <div class="admin-card-header"><h3>Revenue by Plan</h3></div>
        <div class="admin-form" style="padding: 20px;">
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #1a1a1a;">
            <span style="color:#ccc;font-size:0.85rem;">Premium Monthly (₹299/mo)</span>
            <span style="color:#22c55e;font-weight:700;">₹1.8L</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #1a1a1a;">
            <span style="color:#ccc;font-size:0.85rem;">Premium Yearly (₹2,999/yr)</span>
            <span style="color:#22c55e;font-weight:700;">₹30.5L</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;">
            <span style="color:#ccc;font-size:0.85rem;">Free Users</span>
            <span style="color:#666;font-weight:700;">₹0</span>
          </div>
        </div>
      </div>
      <div class="admin-card">
        <div class="admin-card-header"><h3>Payment Methods</h3></div>
        <div class="admin-form" style="padding: 20px;">
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #1a1a1a;">
            <span style="color:#ccc;font-size:0.85rem;">UPI</span>
            <span style="color:#3b82f6;font-weight:700;">68%</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #1a1a1a;">
            <span style="color:#ccc;font-size:0.85rem;">Credit/Debit Card</span>
            <span style="color:#3b82f6;font-weight:700;">24%</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;">
            <span style="color:#ccc;font-size:0.85rem;">Net Banking</span>
            <span style="color:#3b82f6;font-weight:700;">8%</span>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
