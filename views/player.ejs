<script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
<script src="https://cdn.dashjs.org/latest/dash.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.min.js"></script>
<script>
(function() {
  <%
    function getVideoMimeType(url) {
      if (!url) return 'mp4';
      const lower = url.toLowerCase();
      if (lower.endsWith('.m3u8') || lower.includes('.m3u8?') || lower.includes('.m3u8&')) return 'm3u8';
      if (lower.endsWith('.mpd') || lower.includes('.mpd?') || lower.includes('.mpd&')) return 'mpd';
      if (lower.endsWith('.mkv') || lower.includes('.mkv?')) return 'mkv';
      if (lower.endsWith('.webm') || lower.includes('.webm?')) return 'webm';
      if (lower.endsWith('.ogg') || lower.includes('.ogg?')) return 'ogg';
      return 'mp4';
    }
    const videoSrc = currentEpisode ? (currentEpisode.videoUrl || currentEpisode.video_url || '') : (item.videoUrl || item.video_url || '');
    const videoMime = getVideoMimeType(videoSrc);
  %>

  var videoUrl = '<%= videoSrc %>';
  var videoType = '<%= videoMime %>';
  var art;

  var container = document.getElementById('artplayer-app');
  var hideTimer = null;

  /* ===== Controls auto-hide ===== */
  function showControls() {
    container.classList.add('art-show-controls');
    clearTimeout(hideTimer);
    hideTimer = setTimeout(function() {
      container.classList.remove('art-show-controls');
      document.getElementById('settingsPanel').classList.remove('show');
    }, 3000);
  }
  container.addEventListener('mousemove', showControls);
  container.addEventListener('mousedown', showControls);
  container.addEventListener('touchstart', showControls);

  /* ===== Utility: notice toast ===== */
  function showNotice(msg) {
    var n = document.createElement('div');
    n.className = 'art-notice-show';
    n.textContent = msg;
    container.appendChild(n);
    setTimeout(function() { n.remove(); }, 2000);
  }

  /* ===== Utility: format time ===== */
  function fmtTime(s) {
    if (!s || !isFinite(s)) return '0:00';
    var h = Math.floor(s / 3600);
    var m = Math.floor((s % 3600) / 60);
    var sec = Math.floor(s % 60);
    if (h > 0) return h + ':' + (m < 10 ? '0' : '') + m + ':' + (sec < 10 ? '0' : '') + sec;
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }

  /* ===== Back button (top-left only) ===== */
  var backBtn = document.createElement('a');
  backBtn.className = 'art-back-btn';
  backBtn.href = document.referrer || '/';
  backBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>';
  container.appendChild(backBtn);

  /* ===== Episode title layer ===== */
  var epTitle = document.createElement('div');
  epTitle.className = 'art-episode-title';
  epTitle.innerHTML = '<%= item.title %>'<% if (currentEpisode) { %> + ' — E<%= currentEpisode.number %>: <%= currentEpisode.title %>'<% } %>;
  container.appendChild(epTitle);

  /* ===== Mini progress (when controls hidden) ===== */
  var miniProg = document.createElement('div');
  miniProg.className = 'art-mini-progress';
  miniProg.innerHTML = '<div class="art-mini-progress-inner" id="miniProgInner"></div>';
  container.appendChild(miniProg);

  /* ===== Thumbnail preview element ===== */
  var thumbPreview = document.createElement('div');
  thumbPreview.className = 'art-progress-hover-preview';
  thumbPreview.innerHTML = '<img id="hpImg" src="<%= item.backdrop || item.poster %>" style="display:none"><div class="hp-time" id="hpTime">0:00</div>';
  container.appendChild(thumbPreview);

  /* ===== Custom settings panel ===== */
  var settingsPanel = document.createElement('div');
  settingsPanel.id = 'settingsPanel';
  settingsPanel.className = 'art-settings-panel';
  container.appendChild(settingsPanel);

  function buildSettings() {
    settingsPanel.innerHTML = '';

    /* Video Quality */
    settingsPanel.innerHTML += '<div class="sp-title">Video Quality</div>';
    var qualities = ['Auto','1440p','1080p','720p','480p','360p'];
    qualities.forEach(function(q) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (q === 'Auto' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + q + '</span><span class="sp-value">' + (q === 'Auto' ? 'Recommended' : '') + '</span>';
      div.onclick = function() {
        settingsPanel.querySelectorAll('.sp-item').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Quality: ' + q);
      };
      settingsPanel.appendChild(div);
    });

    /* Playback Speed */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Playback Speed</div>';
    var speeds = [0.25, 0.5, 0.75, 1, 1.25, 1.5, 1.75, 2];
    speeds.forEach(function(s) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (s === 1 ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + s + 'x</span>' + (s === 1 ? '<span class="sp-value">Normal</span>' : '');
      div.onclick = function() {
        if (art && art.video) art.video.playbackRate = s;
        settingsPanel.querySelectorAll('[data-section="speed"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Speed: ' + s + 'x');
      };
      div.setAttribute('data-section', 'speed');
      settingsPanel.appendChild(div);
    });

    /* Subtitle Language */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Subtitle Language</div>';
    ['Off', 'English', 'Hindi', 'Spanish', 'Japanese'].forEach(function(lang) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (lang === 'Off' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + lang + '</span>';
      div.onclick = function() {
        settingsPanel.querySelectorAll('[data-section="subtitle-lang"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Subtitle: ' + lang);
      };
      div.setAttribute('data-section', 'subtitle-lang');
      settingsPanel.appendChild(div);
    });

    /* Subtitle Size */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Subtitle Size</div>';
    ['Small', 'Medium', 'Large'].forEach(function(sz) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (sz === 'Medium' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + sz + '</span>';
      div.onclick = function() {
        var size = sz === 'Small' ? '14px' : sz === 'Large' ? '24px' : '18px';
        document.querySelectorAll('video').forEach(function(v) { var s = v.querySelector('.art-subtitle'); if (s) s.style.fontSize = size; });
        settingsPanel.querySelectorAll('[data-section="sub-size"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Subtitle size: ' + sz);
      };
      div.setAttribute('data-section', 'sub-size');
      settingsPanel.appendChild(div);
    });

    /* Subtitle Color */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Subtitle Color</div>';
    ['White', 'Yellow', 'Cyan', 'Green'].forEach(function(c) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (c === 'White' ? ' active' : '');
      div.innerHTML = '<span class="sp-label" style="color:' + c.toLowerCase() + '">' + c + '</span>';
      div.onclick = function() {
        settingsPanel.querySelectorAll('[data-section="sub-color"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Subtitle color: ' + c);
      };
      div.setAttribute('data-section', 'sub-color');
      settingsPanel.appendChild(div);
    });

    /* Subtitle Background */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Subtitle Background</div>';
    ['None', 'Dark', 'Semi'].forEach(function(bg) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (bg === 'Dark' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + bg + '</span>';
      div.onclick = function() {
        settingsPanel.querySelectorAll('[data-section="sub-bg"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Subtitle BG: ' + bg);
      };
      div.setAttribute('data-section', 'sub-bg');
      settingsPanel.appendChild(div);
    });

    /* Audio Track */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Audio Track</div>';
    ['Default', 'English 5.1', 'Hindi', 'Commentary'].forEach(function(a) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (a === 'Default' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + a + '</span>';
      div.onclick = function() {
        settingsPanel.querySelectorAll('[data-section="audio"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Audio: ' + a);
      };
      div.setAttribute('data-section', 'audio');
      settingsPanel.appendChild(div);
    });

    /* Aspect Ratio */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Aspect Ratio</div>';
    ['Default', '16:9', '4:3', '1:1', 'Fill'].forEach(function(r) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (r === 'Default' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + r + '</span>';
      div.onclick = function() {
        if (art && art.video) {
          art.video.style.objectFit = r === 'Fill' ? 'fill' : 'contain';
          art.video.style.aspectRatio = r === 'Default' ? '' : r;
        }
        settingsPanel.querySelectorAll('[data-section="aspect"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Aspect: ' + r);
      };
      div.setAttribute('data-section', 'aspect');
      settingsPanel.appendChild(div);
    });

    /* Flip */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Flip</div>';
    ['Normal', 'Horizontal', 'Vertical'].forEach(function(f) {
      var div = document.createElement('div');
      div.className = 'sp-item' + (f === 'Normal' ? ' active' : '');
      div.innerHTML = '<span class="sp-label">' + f + '</span>';
      div.onclick = function() {
        if (art && art.video) {
          art.video.style.transform = f === 'Horizontal' ? 'scaleX(-1)' : f === 'Vertical' ? 'scaleY(-1)' : '';
        }
        settingsPanel.querySelectorAll('[data-section="flip"]').forEach(function(el) { el.classList.remove('active'); });
        div.classList.add('active');
        showNotice('Flip: ' + f);
      };
      div.setAttribute('data-section', 'flip');
      settingsPanel.appendChild(div);
    });

    /* Brightness / Contrast / Saturation sliders */
    settingsPanel.innerHTML += '<div class="sp-divider"></div>';
    var sliders = [
      { label: 'Brightness', min: 0.2, max: 2, val: 1, filter: 'brightness' },
      { label: 'Contrast', min: 0.2, max: 2, val: 1, filter: 'contrast' },
      { label: 'Saturation', min: 0, max: 2, val: 1, filter: 'saturate' }
    ];
    sliders.forEach(function(sl) {
      var row = document.createElement('div');
      row.className = 'sp-slider-row';
      row.innerHTML = '<label>' + sl.label + '</label><input type="range" min="' + sl.min + '" max="' + sl.max + '" step="0.1" value="' + sl.val + '"><span class="sp-slider-val">' + Math.round(sl.val * 100) + '%</span>';
      row.querySelector('input').oninput = function() {
        if (art && art.video) {
          var filters = [];
          var prev = art.video.style.filter || '';
          var re = new RegExp(sl.filter + '\\([^)]*\\)');
          art.video.style.filter = prev.replace(re, '') + ' ' + sl.filter + '(' + this.value + ')';
        }
        row.querySelector('.sp-slider-val').textContent = Math.round(this.value * 100) + '%';
      };
      settingsPanel.appendChild(row);
    });

    /* Playback Resume */
    settingsPanel.innerHTML += '<div class="sp-divider"></div><div class="sp-title">Playback</div>';
    var resumeItem = document.createElement('div');
    resumeItem.className = 'sp-item active';
    resumeItem.innerHTML = '<span class="sp-label">Resume Playback</span><span class="sp-value">On</span>';
    resumeItem.onclick = function() {
      var isActive = resumeItem.classList.contains('active');
      resumeItem.classList.toggle('active');
      resumeItem.querySelector('.sp-value').textContent = isActive ? 'Off' : 'On';
      showNotice('Resume: ' + (isActive ? 'Off' : 'On'));
    };
    settingsPanel.appendChild(resumeItem);

    /* Skip Intro */
    var skipIntro = document.createElement('div');
    skipIntro.className = 'sp-item';
    skipIntro.innerHTML = '<span class="sp-label">Skip Intro</span><span class="sp-value">0:00</span>';
    skipIntro.onclick = function() { showNotice('No intro detected'); };
    settingsPanel.appendChild(skipIntro);

    /* Skip Outro */
    var skipOutro = document.createElement('div');
    skipOutro.className = 'sp-item';
    skipOutro.innerHTML = '<span class="sp-label">Skip Outro</span><span class="sp-value">0:00</span>';
    skipOutro.onclick = function() { showNotice('No outro detected'); };
    settingsPanel.appendChild(skipOutro);
  }

  function toggleSettings(e) {
    if (e) e.stopPropagation();
    var sp = document.getElementById('settingsPanel');
    if (sp.classList.contains('show')) { sp.classList.remove('show'); }
    else { buildSettings(); sp.classList.add('show'); }
  }

  /* ===== Theater mode ===== */
  window.toggleTheater = function() {
    var isTheater = container.classList.toggle('theater-mode');
    var overlay = document.getElementById('theaterOverlay');
    if (overlay) overlay.classList.toggle('active', isTheater);
    showNotice(isTheater ? 'Theater Mode' : 'Normal Mode');
  };
  window.exitTheater = function() {
    container.classList.remove('theater-mode');
    var overlay = document.getElementById('theaterOverlay');
    if (overlay) overlay.classList.remove('active');
  };

  /* ===== ArtPlayer Config ===== */
  var playerConfig = {
    container: '#artplayer-app',
    url: videoUrl,
    type: videoType,
    poster: '<%= item.backdrop || item.poster %>',
    theme: '#3B82F6',
    volume: 0.7,
    isLive: false,
    muted: false,
    autoplay: false,
    pip: true,
    autoSize: false,
    autoMini: true,
    screenshot: true,
    setting: false,
    loop: false,
    flip: false,
    playbackRate: false,
    aspectRatio: false,
    fullscreen: true,
    fullscreenWeb: true,
    subtitleOffset: true,
    miniProgressBar: false,
    mutex: true,
    backdrop: true,
    playsInline: true,
    autoPlayback: true,
    airplay: true,
    hotkey: true,
    lock: true,
    lang: navigator.language.toLowerCase() === 'zh-cn' ? 'zh-cn' : 'en',
    moreVideoAttr: {
      crossOrigin: 'anonymous',
    },
    settings: [],
    controls: [
      /* --- Bottom Right --- */
      {
        name: 'theater-btn',
        position: 'right',
        index: 22,
        html: '<div title="Theater Mode" style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;cursor:pointer;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background=\'rgba(255,255,255,0.12)\'" onmouseout="this.style.background=\'transparent\'"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8h20"/></svg></div>',
        click: function() { toggleTheater(); }
      },
      {
        name: 'settings-btn',
        position: 'right',
        index: 20,
        html: '<div class="art-quality-badge" title="Settings">Settings</div>',
        click: function(e) { toggleSettings(e); }
      },
      {
        name: 'download-btn',
        position: 'right',
        index: 18,
        html: '<a href="/download/<%= type %>/<%= item.id %>" title="Download" style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;cursor:pointer;border-radius:8px;text-decoration:none;transition:all 0.2s;" onmouseover="this.style.background=\'rgba(255,255,255,0.12)\'" onmouseout="this.style.background=\'transparent\'"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg></a>',
        click: function() {}
      },
      {
        name: 'screenshot-btn',
        position: 'right',
        index: 16,
        html: '<div title="Screenshot" style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;cursor:pointer;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background=\'rgba(255,255,255,0.12)\'" onmouseout="this.style.background=\'transparent\'"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg></div>',
        click: function() {
          if (art && art.video) {
            var c = document.createElement('canvas');
            c.width = art.video.videoWidth; c.height = art.video.videoHeight;
            c.getContext('2d').drawImage(art.video, 0, 0);
            var a = document.createElement('a');
            a.download = 'streamx-screenshot-' + Date.now() + '.png';
            a.href = c.toDataURL('image/png');
            a.click();
            showNotice('Screenshot saved!');
          }
        }
      },
      {
        name: 'pip-btn',
        position: 'right',
        index: 14,
        html: '<div title="Picture in Picture" style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;cursor:pointer;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background=\'rgba(255,255,255,0.12)\'" onmouseout="this.style.background=\'transparent\'"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><rect x="2" y="3" width="20" height="14" rx="2"/><rect x="11" y="9" width="9" height="7" rx="1" fill="rgba(255,255,255,0.15)" stroke="white" stroke-width="1.5"/></svg></div>',
        click: function() {
          if (art && art.video) {
            if (document.pictureInPictureElement) { document.exitPictureInPicture(); }
            else if (document.pictureInPictureEnabled) { art.video.requestPictureInPicture().catch(function() { showNotice('PiP not available'); }); }
            else { showNotice('PiP not supported'); }
          }
        }
      },
      {
        name: 'watchlist-btn',
        position: 'right',
        index: 10,
        html: '<div title="Add to Watchlist" style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;cursor:pointer;border-radius:8px;transition:all 0.2s;" onmouseover="this.style.background=\'rgba(255,255,255,0.12)\'" onmouseout="this.style.background=\'transparent\'"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></div>',
        click: function() {
          var btn = document.querySelector('form[action="/watchlist/add"] button');
          if (btn) btn.click();
          showNotice('Added to Watchlist');
        }
      }
    ],
    layers: [],
    contextmenu: [
      { html: 'STREAMX Player — v2.0', click: function(ctx) { ctx.show = false; } },
      {
        html: 'Keyboard Shortcuts',
        click: function(ctx) {
          showNotice('Space=Play/Pause | ←/→=±10s | ↑/↓=Volume | F=Fullscreen | M=Mute | P=PiP | S=Screenshot | T=Theater');
          ctx.show = false;
        }
      }
    ],
    icons: {
      loading: '<div style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;"><div style="width:44px;height:44px;border:3px solid rgba(255,255,255,0.15);border-top-color:#3B82F6;border-radius:50%;animation:art-loading 0.8s linear infinite;"></div></div>',
      state: '<svg width="56" height="56" viewBox="0 0 24 24" fill="white" opacity="0.85" style="filter:drop-shadow(0 2px 12px rgba(0,0,0,0.5))"><path d="M8 5v14l11-7z"/></svg>',
      indicator: '<svg width="16" height="16" viewBox="0 0 24 24" fill="#3B82F6"><circle cx="12" cy="12" r="10"/></svg>'
    }
  };

  /* ===== HLS / DASH Custom Type ===== */
  if (videoType === 'm3u8' || videoType === 'mpd') {
    playerConfig.customType = {
      m3u8: function(video, url) {
        if (typeof Hls !== 'undefined' && Hls.isSupported()) {
          var hls = new Hls({ enableWorker: true, lowLatencyMode: false });
          hls.loadSource(url);
          hls.attachMedia(video);
          hls.on(Hls.Events.MANIFEST_PARSED, function() { video.play().catch(function(){}); });
          hls.on(Hls.Events.ERROR, function(event, data) {
            if (data.fatal) {
              if (data.type === Hls.ErrorTypes.NETWORK_ERROR) {
                showNotice('Network error — reconnecting...');
                hls.startLoad();
              } else if (data.type === Hls.ErrorTypes.MEDIA_ERROR) {
                showNotice('Media error — recovering...');
                hls.recoverMediaError();
              } else {
                showNotice('Fatal stream error');
                hls.destroy();
              }
            }
          });
        } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = url;
        } else {
          showNotice('HLS not supported in this browser');
        }
      },
      mpd: function(video, url) {
        if (typeof dashjs !== 'undefined') {
          var dp = dashjs.MediaPlayer().create();
          dp.updateSettings({ streaming: { abr: { autoSwitchBitrate: { video: true } } } });
          dp.initialize(video, url, false);
        } else {
          showNotice('DASH player not loaded');
        }
      }
    };
  }

  /* ===== Create Player ===== */
  art = new Artplayer(playerConfig);
  showControls();

  /* ===== Add Replay 10s / Forward 10s after player creates controls ===== */
  function addRewindForward() {
    var controlsEl = container.querySelector('.art-controls');
    if (!controlsEl) return;

    /* Replay 10s — insert before play button area (left side) */
    var rewindBtn = document.createElement('div');
    rewindBtn.className = 'art-control art-ctrl-rewind';
    rewindBtn.title = 'Replay 10s';
    rewindBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7" font-weight="700">10</text></svg>';
    rewindBtn.onclick = function() { if (art && art.video) { art.video.currentTime = Math.max(0, art.video.currentTime - 10); showNotice('-10s'); } };

    var forwardBtn = document.createElement('div');
    forwardBtn.className = 'art-control art-ctrl-forward';
    forwardBtn.title = 'Forward 10s';
    forwardBtn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.13-9.36L23 10"/><text x="12" y="16" text-anchor="middle" fill="white" stroke="none" font-size="7" font-weight="700">10</text></svg>';
    forwardBtn.onclick = function() { if (art && art.video) { art.video.currentTime = Math.min(art.video.duration || 0, art.video.currentTime + 10); showNotice('+10s'); } };

    /* Insert rewind/forward after first control (play button) */
    var firstCtrl = controlsEl.querySelector('.art-control');
    if (firstCtrl && firstCtrl.nextSibling) {
      controlsEl.insertBefore(rewindBtn, firstCtrl.nextSibling);
      controlsEl.insertBefore(forwardBtn, rewindBtn.nextSibling);
    } else {
      controlsEl.appendChild(rewindBtn);
      controlsEl.appendChild(forwardBtn);
    }
  }
  setTimeout(addRewindForward, 100);

  /* ===== Custom keyboard shortcuts ===== */
  document.addEventListener('keydown', function(e) {
    if (!art || !art.video) return;
    var tag = (e.target.tagName || '').toLowerCase();
    if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
    switch (e.key.toLowerCase()) {
      case 't': e.preventDefault(); toggleTheater(); break;
      case 'arrowleft': e.preventDefault(); art.video.currentTime = Math.max(0, art.video.currentTime - 10); showNotice('-10s'); break;
      case 'arrowright': e.preventDefault(); art.video.currentTime = Math.min(art.video.duration || 0, art.video.currentTime + 10); showNotice('+10s'); break;
    }
  });

  /* ===== Progress hover: time tooltip + thumbnail preview ===== */
  var progressEl = null;
  function setupProgressHover() {
    progressEl = container.querySelector('.art-progress');
    if (!progressEl) return;
    var hpTime = document.getElementById('hpTime');
    var hpImg = document.getElementById('hpImg');

    progressEl.addEventListener('mousemove', function(e) {
      var rect = progressEl.querySelector('.art-control-progress').getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      var time = pct * (art && art.video ? art.video.duration : 0);
      if (hpTime) hpTime.textContent = fmtTime(time);
      if (hpImg && hpImg.src) hpImg.style.display = 'block';
    });
  }
  setTimeout(setupProgressHover, 200);

  /* ===== Video event handlers ===== */
  art.on('video:error', function() {
    showNotice('Unable to play this video. Check the source URL.');
  });

  art.on('video:waiting', function() {
    showNotice('Buffering...');
  });

  /* ===== Progress tracking ===== */
  art.on('video:timeupdate', function() {
    if (!art.duration) return;
    var pct = (art.currentTime / art.duration) * 100;
    var miniInner = document.getElementById('miniProgInner');
    if (miniInner) miniInner.style.width = pct + '%';

    var progress = Math.floor(pct);
    if (progress > 0 && progress % 25 === 0) {
      fetch('/api/continue-watching', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contentId: <%= item.id %>,
          type: '<%= item.type %>',
          progress: progress,
          currentTime: Math.floor(art.currentTime)
        })
      }).catch(function() {});
    }
  });

  /* ===== Auto-play next episode ===== */
  art.on('video:ended', function() {
    var nextCard = document.querySelector('.episode-card.active + .episode-card');
    if (nextCard) {
      showNotice('Next episode in 5 seconds...');
      setTimeout(function() { window.location.href = nextCard.href; }, 5000);
    }
  });

  /* ===== Close panels on click outside ===== */
  document.addEventListener('click', function(e) {
    var sp = document.getElementById('settingsPanel');
    if (sp && sp.classList.contains('show') && !sp.contains(e.target) && !e.target.closest('[data-name="settings-btn"]')) {
      sp.classList.remove('show');
    }
  });

  /* ===== Escape exits theater mode ===== */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') exitTheater();
  });

})();
</script>
