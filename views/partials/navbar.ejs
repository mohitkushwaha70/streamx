<nav class="navbar" id="navbar">
  <a href="/" class="nav-logo">STREAM<span>X</span></a>
  <div class="nav-links" id="navLinks">
    <a href="/" class="<%= typeof active !== 'undefined' && active === 'home' ? 'active' : '' %>">Home</a>
    <a href="/movies" class="<%= typeof active !== 'undefined' && active === 'movies' ? 'active' : '' %>">Movies</a>
    <a href="/series" class="<%= typeof active !== 'undefined' && active === 'series' ? 'active' : '' %>">Series</a>
    <a href="/anime" class="<%= typeof active !== 'undefined' && active === 'anime' ? 'active' : '' %>">Anime</a>
    <a href="/free-movies" class="<%= typeof active !== 'undefined' && active === 'free-movies' ? 'active' : '' %>">Free</a>
    <a href="/pricing" class="<%= typeof active !== 'undefined' && active === 'pricing' ? 'active' : '' %>">Premium</a>
  </div>
  <div class="nav-right">
    <form class="nav-search" action="/search" method="GET" id="searchForm">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" name="q" placeholder="Search..." value="<%= typeof query !== 'undefined' ? query : '' %>" id="searchInput">
      <button type="button" class="voice-btn" id="voiceBtn" title="Voice Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      </button>
    </form>
    <% if (user) { %>
      <div class="nav-user">
        <div class="avatar"><%= user.avatar %></div>
      </div>
      <div class="dropdown-menu" id="userMenu">
        <div class="dropdown-header">
          <div class="avatar-lg"><%= user.avatar %></div>
          <div>
            <strong><%= user.name %></strong><br>
            <span class="plan-badge <%= user.plan %>"><%= user.plan %></span>
          </div>
        </div>
        <a href="/profile"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> My Profile</a>
        <a href="/watchlist"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> My Watchlist</a>
        <a href="/profile#favorites"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg> Favorites</a>
        <a href="/profile#saved"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/></svg> Saved</a>
        <div class="dropdown-divider"></div>
        <% if (user.role === 'admin') { %><a href="/admin"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> Admin Panel</a><div class="dropdown-divider"></div><% } %>
        <a href="/auth/logout" class="logout-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg> Sign Out</a>
      </div>
    <% } else { %>
      <button class="btn btn-primary btn-sm" onclick="document.getElementById('authModal').classList.add('active')">Get Started</button>
    <% } %>
    <button class="hamburger" onclick="toggleNav()">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<% if (!user) { %>
<div class="modal-overlay" id="authModal">
  <div class="modal auth-modal">
    <button class="modal-close" onclick="document.getElementById('authModal').classList.remove('active')">&times;</button>
    <div class="auth-modal-inner">
      <div class="auth-modal-logo">STREAM<span>X</span></div>
      <p class="auth-modal-sub">Start watching now</p>
      <a href="/auth/google" class="google-btn">
        <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
        Continue with Google
      </a>
      <div class="divider">or</div>
      <a href="/auth/login" class="btn btn-primary btn-lg btn-full">SIGN IN</a>
      <a href="/auth/register" class="btn btn-outline btn-lg btn-full">SIGN UP</a>
      <p class="auth-modal-footer">By continuing, you agree to our Terms & Privacy Policy.</p>
    </div>
  </div>
</div>
<% } %>
