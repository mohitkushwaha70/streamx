<%- include('partials/header', { pageTitle: 'Verify Email' }) %>

<div class="auth-container">
  <div class="auth-box">
    <div style="display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:8px;">
      <img src="/images/favicon.svg" alt="" style="width:40px;height:40px;border-radius:10px;">
      <span style="font-weight:800;font-size:1.5rem;color:#fff;letter-spacing:-0.5px;">STREAM<span style="background:linear-gradient(135deg,#6c5ce7,#ec4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">X</span></span>
    </div>
    <p class="subtitle">Enter the 6-digit code sent to</p>
    <p style="color: var(--accent); font-weight: 600; margin-bottom: 20px; word-break: break-all;"><%= email %></p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form method="POST" action="/auth/register/verify">
      <div class="form-group">
        <label>OTP Code</label>
        <input type="text" name="code" class="form-input" placeholder="000000"
               maxlength="6" pattern="[0-9]{6}" inputmode="numeric"
               autocomplete="one-time-code" required
               style="text-align:center;font-size:24px;letter-spacing:8px;font-family:monospace;">
      </div>
      <button type="submit" class="btn btn-primary btn-lg">VERIFY & CREATE ACCOUNT</button>
    </form>

    <div class="auth-footer" style="margin-top:16px;">
      <form method="POST" action="/auth/otp/send" style="display:inline;">
        <input type="hidden" name="email" value="<%= email %>">
        <button type="submit" class="btn btn-outline" style="font-size:13px; padding:8px 16px;">
          Resend OTP
        </button>
      </form>
    </div>

    <div class="auth-footer" style="margin-top:12px;">
      <a href="/auth/register" style="color: var(--accent);">← Back to Register</a>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const input = document.querySelector('input[name="code"]');
  if (input) input.focus();
});
</script>

<%- include('partials/footer') %>
