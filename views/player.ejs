<%- include('partials/header', { pageTitle: 'Watch - ' + item.title }) %>
<%- include('partials/navbar', { active: '' }) %>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/artplayer/dist/artplayer.css">

<style>
.player-page { padding: 0 !important; background: #000; }
.player-main { display: flex; gap: 0; max-width: 1600px; margin: 0 auto; }
.player-left { flex: 1; min-width: 0; }

/* Theater Mode */
#artplayer-app.theater-mode { position: fixed !important; top: 0 !important; left: 0 !important; right: 0 !important; width: 100vw !important; height: 100vh !important; z-index: 9999 !important; aspect-ratio: unset !important; border-radius: 0 !important; }
#artplayer-app.theater-mode .art-bottom { padding-bottom: 16px !important; }
#artplayer-app.theater-mode .art-back-btn { top: 20px !important; left: 20px !important; }
#artplayer-app.theater-mode .art-episode-title { bottom: 100px !important; }
#artplayer-app.theater-mode .art-mini-progress { height: 4px !important; }

.player-right { width: 380px; flex-shrink: 0; padding: 16px; background: #0a0a0f; border-left: 1px solid #1a1a1a; max-height: calc(100vh - 60px); overflow-y: auto; position: sticky; top: 60px; }
.player-right::-webkit-scrollbar { width: 4px; }
.player-right::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
.player-right-title { font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.player-right-title svg { color: #3B82F6; }

#artplayer-app { width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 0; overflow: hidden; position: relative; }

/* === HIDE ALL TOP CONTROLS === */
.art-top, .art-control-top, .art-settings, .art-info, .art-mask, .art-notice, .art-tip { display: none !important; }

/* === BACK BUTTON (top-left) === */
.art-back-btn {
  position: absolute; top: 16px; left: 16px; z-index: 200;
  width: 40px; height: 40px; border-radius: 12px;
  background: rgba(0,0,0,0.5); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1); cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.35s ease, transform 0.2s ease;
  color: white; text-decoration: none;
}
#artplayer-app:hover .art-back-btn, #artplayer-app.art-show-controls .art-back-btn { opacity: 1; }
.art-back-btn:hover { background: rgba(59,130,246,0.6); transform: scale(1.1); border-color: rgba(59,130,246,0.5); }

/* === EPISODE TITLE LAYER === */
.art-episode-title {
  position: absolute; bottom: 80px; left: 16px; z-index: 150;
  background: rgba(0,0,0,0.6); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  padding: 8px 16px; border-radius: 10px;
  color: white; font-size: 0.85rem; font-weight: 600;
  pointer-events: none; opacity: 0; transition: opacity 0.35s ease;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
#artplayer-app:hover .art-episode-title, #artplayer-app.art-show-controls .art-episode-title { opacity: 1; }

/* === MINI PROGRESS (when controls hidden) === */
.art-mini-progress {
  position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
  background: rgba(255,255,255,0.15); z-index: 99;
  opacity: 1; transition: opacity 0.3s ease;
}
.art-mini-progress-inner { height: 100%; background: #3B82F6; transition: width 0.3s linear; }
#artplayer-app.art-show-controls .art-mini-progress { opacity: 0; }

/* === BOTTOM CONTROL BAR === */
.art-bottom {
  position: absolute !important; bottom: 0 !important; left: 0 !important; right: 0 !important;
  z-index: 100 !important; padding: 0 !important; margin: 0 !important;
  background: linear-gradient(to top, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.7) 50%, transparent 100%) !important;
  backdrop-filter: blur(16px) saturate(180%) !important; -webkit-backdrop-filter: blur(16px) saturate(180%) !important;
  opacity: 0; transition: opacity 0.35s ease !important; padding-bottom: 8px !important;
}
#artplayer-app:hover .art-bottom, #artplayer-app.art-show-controls .art-bottom { opacity: 1 !important; }

/* === PROGRESS BAR === */
.art-progress {
  position: relative !important; padding: 10px 16px 4px 16px !important;
  height: auto !important; margin-bottom: 0 !important;
}
.art-progress .art-control-progress {
  position: relative !important; height: 3px !important;
  background: rgba(255,255,255,0.2) !important; border-radius: 2px !important;
  overflow: visible !important; transition: height 0.2s ease, background 0.2s ease !important;
  cursor: pointer !important;
}
.art-progress:hover .art-control-progress { height: 6px !important; }
.art-progress .art-control-progress-inner {
  height: 100% !important; background: #3B82F6 !important;
  border-radius: 2px !important; position: relative !important; transition: background 0.2s ease !important;
}
.art-progress .art-progress-loaded {
  background: rgba(255,255,255,0.25) !important; height: 100% !important; border-radius: 2px !important;
}
.art-progress .art-indicator {
  width: 14px !important; height: 14px !important;
  background: #3B82F6 !important; border: 2.5px solid #fff !important;
  border-radius: 50% !important; position: absolute !important; top: 50% !important;
  transform: translateY(-50%) scale(0) !important;
  transition: transform 0.15s ease, box-shadow 0.15s ease !important;
  box-shadow: 0 0 10px rgba(59,130,246,0.6) !important; z-index: 10 !important;
}
.art-progress:hover .art-indicator { transform: translateY(-50%) scale(1) !important; }

/* Progress tooltip (time preview) */
.art-progress-tooltip {
  position: absolute; bottom: 100%; transform: translateX(-50%);
  background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
  padding: 4px 8px; color: white; font-size: 0.75rem; font-weight: 600;
  pointer-events: none; white-space: nowrap; display: none;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.art-progress:hover .art-progress-tooltip { display: block; }

/* Thumbnail preview on progress hover */
.art-progress-hover-preview {
  position: absolute; bottom: calc(100% + 8px); transform: translateX(-50%);
  width: 160px; height: 90px; border-radius: 8px; overflow: hidden;
  background: #111; border: 2px solid rgba(255,255,255,0.15);
  box-shadow: 0 4px 20px rgba(0,0,0,0.6);
  display: none; pointer-events: none; z-index: 10;
}
.art-progress:hover .art-progress-hover-preview { display: block; }
.art-progress-hover-preview img { width: 100%; height: 100%; object-fit: cover; }
.art-progress-hover-preview .hp-time {
  position: absolute; bottom: 4px; left: 50%; transform: translateX(-50%);
  background: rgba(0,0,0,0.8); padding: 2px 6px; border-radius: 4px;
  color: white; font-size: 0.7rem; font-weight: 600;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* Theater mode overlay */
.theater-overlay {
  display: none; position: fixed; inset: 0; background: #000; z-index: 9998;
}
.theater-overlay.active { display: block; }

/* Subtitle dropdown in controls */
.art-subtitle-dropdown {
  position: absolute; bottom: 50px; right: 0; z-index: 300;
  background: rgba(10,12,20,0.94); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.08); border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5); padding: 6px 0; min-width: 140px;
  display: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.art-subtitle-dropdown.show { display: block; animation: settingsSlideUp 0.15s ease; }
.art-subtitle-dropdown .sd-item {
  padding: 8px 16px; color: rgba(255,255,255,0.8); font-size: 0.8rem;
  cursor: pointer; transition: background 0.15s;
}
.art-subtitle-dropdown .sd-item:hover { background: rgba(59,130,246,0.1); }
.art-subtitle-dropdown .sd-item.active { color: #3B82F6; font-weight: 600; }
.art-subtitle-dropdown .sd-title {
  padding: 8px 16px 4px; color: rgba(255,255,255,0.4); font-size: 0.65rem;
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
}

/* === CONTROLS ROW === */
.art-controls {
  display: flex !important; align-items: center !important;
  padding: 4px 12px 2px 12px !important; gap: 2px !important; height: 44px !important;
}
.art-controls .art-control {
  display: flex !important; align-items: center !important; justify-content: center !important;
  padding: 0 6px !important; cursor: pointer !important; color: #fff !important;
  opacity: 0.9 !important; transition: opacity 0.2s ease, transform 0.15s ease, background 0.2s ease !important;
  border-radius: 8px !important; height: 34px !important; position: relative !important;
}
.art-controls .art-control:hover {
  opacity: 1 !important; background: rgba(255,255,255,0.12) !important; transform: scale(1.08) !important;
}
.art-controls .art-control svg { width: 20px !important; height: 20px !important; fill: #fff !important; }
.art-controls .art-spacer { flex: 1 !important; }

/* Time display */
.art-time {
  font-size: 13px !important; font-weight: 500 !important;
  color: rgba(255,255,255,0.85) !important; padding: 0 8px !important;
  white-space: nowrap !important; letter-spacing: 0.02em !important;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif !important;
}

/* Volume slider */
.art-volume-wrap { display: flex !important; align-items: center !important; gap: 0 !important; }
.art-volume-wrap .art-volume-panel {
  width: 0; overflow: hidden; transition: width 0.2s ease; display: flex; align-items: center;
}
.art-volume-wrap:hover .art-volume-panel { width: 80px; }
.art-volume-wrap .art-control-progress { height: 3px !important; background: rgba(255,255,255,0.2) !important; border-radius: 2px !important; flex: 1; }
.art-volume-wrap .art-control-progress-inner { background: #3B82F6 !important; border-radius: 2px !important; }

/* Quality badge */
.art-quality-badge {
  font-size: 0.65rem; font-weight: 700; color: #3B82F6;
  padding: 2px 6px; border: 1px solid rgba(59,130,246,0.4); border-radius: 4px;
  cursor: pointer; transition: all 0.2s; letter-spacing: 0.03em;
}
.art-quality-badge:hover { background: rgba(59,130,246,0.15); border-color: rgba(59,130,246,0.6); }

/* === CUSTOM SETTINGS PANEL === */
.art-settings-panel {
  position: absolute; bottom: 60px; right: 12px; z-index: 300;
  background: rgba(10,12,20,0.94); backdrop-filter: blur(24px) saturate(150%);
  -webkit-backdrop-filter: blur(24px) saturate(150%);
  border: 1px solid rgba(255,255,255,0.08); border-radius: 16px;
  box-shadow: 0 12px 48px rgba(0,0,0,0.6); padding: 8px 0;
  min-width: 260px; max-height: 70vh; overflow-y: auto;
  display: none; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.art-settings-panel.show { display: block; animation: settingsSlideUp 0.2s ease; }
@keyframes settingsSlideUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.art-settings-panel::-webkit-scrollbar { width: 4px; }
.art-settings-panel::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }

.art-settings-panel .sp-title {
  padding: 12px 18px 8px; color: rgba(255,255,255,0.5); font-size: 0.7rem;
  font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;
}
.art-settings-panel .sp-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 10px 18px; color: rgba(255,255,255,0.85); font-size: 0.85rem;
  cursor: pointer; transition: background 0.15s ease;
}
.art-settings-panel .sp-item:hover { background: rgba(59,130,246,0.1); }
.art-settings-panel .sp-item.active { color: #3B82F6; }
.art-settings-panel .sp-item .sp-label { font-weight: 500; }
.art-settings-panel .sp-item .sp-value { color: rgba(255,255,255,0.5); font-size: 0.8rem; }
.art-settings-panel .sp-divider { height: 1px; background: rgba(255,255,255,0.06); margin: 4px 0; }

/* Slider row inside settings */
.art-settings-panel .sp-slider-row {
  padding: 10px 18px; display: flex; align-items: center; gap: 10px;
}
.art-settings-panel .sp-slider-row label {
  color: rgba(255,255,255,0.6); font-size: 0.8rem; min-width: 60px; font-weight: 500;
}
.art-settings-panel .sp-slider-row input[type="range"] {
  flex: 1; -webkit-appearance: none; appearance: none; height: 3px;
  background: rgba(255,255,255,0.2); border-radius: 2px; outline: none;
}
.art-settings-panel .sp-slider-row input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none; width: 14px; height: 14px; background: #3B82F6;
  border-radius: 50%; cursor: pointer; border: 2px solid white;
}
.art-settings-panel .sp-slider-row .sp-slider-val {
  color: rgba(255,255,255,0.5); font-size: 0.75rem; min-width: 30px; text-align: right;
}

/* Sub-menu inside settings */
.art-settings-submenu {
  position: absolute; bottom: 0; left: 100%; z-index: 310;
  background: rgba(10,12,20,0.94); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.08); border-radius: 14px;
  box-shadow: 0 12px 48px rgba(0,0,0,0.6); padding: 8px 0;
  min-width: 180px; display: none;
}
.art-settings-submenu.show { display: block; }
.art-settings-submenu .sp-item { font-size: 0.8rem; padding: 8px 16px; }

/* Context menu */
.art-contextmenus {
  background: rgba(10,12,20,0.94) !important; backdrop-filter: blur(20px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(20px) saturate(150%) !important;
  border: 1px solid rgba(255,255,255,0.08) !important; border-radius: 12px !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
}
.art-contextmenu { padding: 8px 16px !important; color: rgba(255,255,255,0.85) !important; font-size: 13px !important; }
.art-contextmenu:hover { background: rgba(59,130,246,0.15) !important; }

/* Loading spinner */
@keyframes art-loading { to { transform: rotate(360deg); } }
@keyframes art-loading-pulse { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }

/* Center state icon */
.art-state { position: absolute !important; top: 50% !important; left: 50% !important; transform: translate(-50%,-50%) !important; z-index: 50 !important; pointer-events: none !important; }

/* Notice */
.art-notice { display: none !important; }
.art-notice-show {
  display: block !important; position: absolute; top: 20px; right: 20px; z-index: 300;
  background: rgba(10,12,20,0.9); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.1); border-radius: 10px;
  padding: 10px 18px; color: white; font-size: 0.85rem; font-weight: 500;
  animation: noticeIn 0.3s ease;
}
@keyframes noticeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

/* Video info */
.video-info { padding: 20px 24px; }
.video-info h1 { font-size: 1.4rem; font-weight: 800; color: #fff; margin-bottom: 8px; }
.video-meta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; }
.video-meta .rating { color: #f59e0b; font-weight: 700; font-size: 0.9rem; }
.video-meta span { font-size: 0.85rem; color: var(--text-muted); }
.video-meta .premium-badge { background: linear-gradient(135deg, #f59e0b, #f97316); color: #000; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }
.video-meta .quality-badge { background: rgba(59,130,246,0.15); color: #3B82F6; padding: 3px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; border: 1px solid rgba(59,130,246,0.3); }
.video-desc { color: var(--text-secondary); line-height: 1.7; font-size: 0.9rem; margin-bottom: 16px; }
.video-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.video-actions .action-btn { display: flex; align-items: center; gap: 6px; padding: 8px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; color: var(--text-secondary); font-size: 0.8rem; cursor: pointer; transition: all 0.2s; }
.video-actions .action-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
.video-actions .action-btn.liked { color: #ef4444; border-color: rgba(239,68,68,0.3); }
.video-actions .action-btn svg { flex-shrink: 0; }

.episodes-section { padding: 20px 24px; border-top: 1px solid #1a1a1a; }
.episodes-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
.episodes-header h2 { font-size: 1.1rem; font-weight: 700; color: #fff; }
.season-tabs { display: flex; gap: 8px; margin-bottom: 16px; overflow-x: auto; }
.season-tab { padding: 6px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; color: var(--text-muted); font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: var(--transition); white-space: nowrap; text-decoration: none; }
.season-tab.active { background: #3B82F6; color: #fff; border-color: #3B82F6; }
.season-tab:hover { border-color: rgba(59,130,246,0.5); color: #fff; }
.episode-card { display: flex; gap: 14px; padding: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; margin-bottom: 8px; transition: all 0.2s; cursor: pointer; text-decoration: none; color: inherit; }
.episode-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(59,130,246,0.3); }
.episode-card.active { background: rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.3); }
.episode-thumb { width: 160px; height: 90px; border-radius: 8px; overflow: hidden; flex-shrink: 0; position: relative; background: #111; }
.episode-thumb img { width: 100%; height: 100%; object-fit: cover; }
.episode-thumb .ep-num { position: absolute; bottom: 6px; left: 6px; background: rgba(0,0,0,0.8); color: #fff; font-size: 0.7rem; font-weight: 700; padding: 2px 8px; border-radius: 4px; }
.episode-thumb .ep-now { position: absolute; top: 6px; right: 6px; background: #3B82F6; color: #fff; font-size: 0.65rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; }
.episode-info { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
.episode-info h4 { font-size: 0.9rem; font-weight: 600; color: #fff; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.episode-info p { font-size: 0.8rem; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
.episode-info .ep-duration { font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; }

.recommended-section { padding: 20px 24px; border-top: 1px solid #1a1a1a; }
.rec-scroll { display: flex; gap: 14px; overflow-x: auto; padding-bottom: 8px; }
.rec-scroll::-webkit-scrollbar { height: 4px; }
.rec-scroll::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
.rec-card { min-width: 200px; flex-shrink: 0; text-decoration: none; color: inherit; }
.rec-card .rec-thumb { width: 200px; height: 112px; border-radius: 8px; overflow: hidden; position: relative; background: #111; }
.rec-card .rec-thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
.rec-card:hover .rec-thumb img { transform: scale(1.05); }
.rec-card .rec-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); opacity: 0; transition: all 0.3s; }
.rec-card:hover .rec-play { opacity: 1; }
.rec-card .rec-info { padding: 8px 0; }
.rec-card .rec-info h4 { font-size: 0.8rem; font-weight: 600; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.rec-card .rec-info p { font-size: 0.75rem; color: var(--text-muted); }

.share-modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 1000; display: none; align-items: center; justify-content: center; }
.share-modal.active { display: flex; }
.share-box { background: #111; border: 1px solid #222; border-radius: 16px; padding: 28px; max-width: 420px; width: 90%; }
.share-box h3 { color: #fff; margin-bottom: 16px; font-size: 1.1rem; }
.share-link { display: flex; gap: 8px; margin-bottom: 16px; }
.share-link input { flex: 1; background: #1a1a1a; border: 1px solid #333; border-radius: 8px; padding: 10px 14px; color: #fff; font-size: 0.85rem; }
.share-link button { background: #3B82F6; color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 600; cursor: pointer; }
.share-people { display: flex; gap: 12px; flex-wrap: wrap; }
.share-avatar { width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #3B82F6, #7c3aed); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; color: #fff; cursor: pointer; transition: all 0.2s; }
.share-avatar:hover { transform: scale(1.1); }
.share-close { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1.5rem; float: right; }

/* Responsive */
@media (max-width: 1024px) {
  .player-main { flex-direction: column; }
  .player-right { width: 100%; max-height: none; position: static; border-left: none; border-top: 1px solid #1a1a1a; }
  .art-controls { padding: 4px 8px !important; gap: 1px !important; }
  .art-progress { padding: 8px 8px 4px 8px !important; }
}
@media (max-width: 768px) {
  .art-controls { padding: 2px 6px !important; gap: 0 !important; height: 38px !important; }
  .art-controls .art-control { padding: 0 4px !important; height: 30px !important; }
  .art-controls .art-control svg { width: 18px !important; height: 18px !important; }
  .art-time { font-size: 11px !important; padding: 0 4px !important; }
  .art-progress { padding: 6px 6px 4px 6px !important; }
  .art-progress .art-indicator { width: 12px !important; height: 12px !important; }
  .art-bottom { padding-bottom: 4px !important; }
  .art-back-btn { top: 8px; left: 8px; width: 36px; height: 36px; border-radius: 10px; }
  .art-episode-title { bottom: 60px; left: 8px; font-size: 0.8rem; padding: 6px 12px; }
  .art-quality-badge { font-size: 0.6rem; padding: 1px 4px; }
  .video-actions { gap: 6px; }
  .video-actions .action-btn { padding: 6px 10px; font-size: 0.75rem; }
  .episode-thumb { width: 100px; height: 56px; }
  .rec-card { min-width: 160px; }
  .rec-card .rec-thumb { width: 160px; height: 90px; }
  .art-settings-panel { right: 8px; min-width: 220px; }
}
@media (max-width: 480px) {
  .art-controls .art-control { padding: 0 3px !important; height: 26px !important; }
  .art-controls .art-control svg { width: 16px !important; height: 16px !important; }
  .art-time { font-size: 10px !important; }
}
</style>

<main class="main-content player-page">
  <div class="player-main">
    <div class="player-left">
      <div id="artplayer-app"></div>
      <div class="theater-overlay" id="theaterOverlay" onclick="exitTheater()"></div>

      <div class="video-info">
        <h1><%= item.title %><% if (currentEpisode) { %> - E<%= currentEpisode.number %>: <%= currentEpisode.title %><% } %></h1>
        <div class="video-meta">
          <span class="rating">&#9733; <%= item.rating %></span>
          <span><%= item.year %></span>
          <span><%= item.genre %></span>
          <% if (currentEpisode) { %><span><%= currentEpisode.duration %></span><% } else if (item.duration) { %><span><%= item.duration %></span><% } %>
          <% if (item.premium) { %><span class="premium-badge">PREMIUM</span><% } %>
          <span class="quality-badge">HD 1080p</span>
          <% if (item.cast) { %><span><%= item.cast %></span><% } %>
        </div>
        <p class="video-desc"><%= currentEpisode ? currentEpisode.description : item.description %></p>
        <div class="video-actions">
          <button class="action-btn" onclick="this.classList.toggle('liked')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
            Like
          </button>
          <button class="action-btn" onclick="document.getElementById('shareModal').classList.add('active')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            Share
          </button>
          <form action="/watchlist/add" method="POST" style="display:inline">
            <input type="hidden" name="id" value="<%= item.id %>">
            <button type="submit" class="action-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
              Watchlist
            </button>
          </form>
          <a href="/download/<%= type %>/<%= item.id %>" class="action-btn" style="text-decoration:none;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download
          </a>
        </div>
      </div>

      <%
        const hasSub = streaming && streaming.subscription && streaming.subscription.length > 0;
        const hasFree = streaming && streaming.free && streaming.free.length > 0;
        const hasRent = streaming && streaming.rent && streaming.rent.length > 0;
        const hasBuy = streaming && streaming.buy && streaming.buy.length > 0;
      %>
      <% if (hasSub || hasFree || hasRent || hasBuy) { %>
      <div class="episodes-section" style="border-top: 1px solid #1a1a1a;">
        <div class="episodes-header"><h2>Where to Watch</h2></div>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
          <% if (hasSub) { streaming.subscription.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 160px;">
            <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 28px; height: 28px; border-radius: 6px; object-fit: contain;"><% } else { %><span style="font-size: 1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
            <div><div style="font-weight: 600; font-size: 0.85rem;"><%= s.name %></div><div style="font-size: 0.7rem; color: #4ade80;">Stream Now</div></div>
          </a>
          <% }) } %>
          <% if (hasFree) { streaming.free.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 160px;">
            <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 28px; height: 28px; border-radius: 6px; object-fit: contain;"><% } else { %><span style="font-size: 1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
            <div><div style="font-weight: 600; font-size: 0.85rem;"><%= s.name %></div><div style="font-size: 0.7rem; color: #4ade80;">Free</div></div>
          </a>
          <% }) } %>
          <% if (hasRent) { streaming.rent.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 160px;">
            <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 28px; height: 28px; border-radius: 6px; object-fit: contain;"><% } else { %><span style="font-size: 1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
            <div><div style="font-weight: 600; font-size: 0.85rem;"><%= s.name %></div><div style="font-size: 0.7rem; color: #f59e0b;">Rent</div></div>
          </a>
          <% }) } %>
          <% if (hasBuy) { streaming.buy.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" style="display: flex; align-items: center; gap: 10px; padding: 12px 16px; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; text-decoration: none; color: #fff; transition: all 0.3s; min-width: 160px;">
            <% if (s.logo) { %><img src="<%= s.logo %>" alt="<%= s.name %>" style="width: 28px; height: 28px; border-radius: 6px; object-fit: contain;"><% } else { %><span style="font-size: 1.3rem;"><%= getSourceIcon(s.name) %></span><% } %>
            <div><div style="font-weight: 600; font-size: 0.85rem;"><%= s.name %></div><div style="font-size: 0.7rem; color: #3b82f6;">Buy</div></div>
          </a>
          <% }) } %>
        </div>
      </div>
      <% } %>

      <% if (episodes.length > 0) { %>
      <div class="episodes-section">
        <div class="episodes-header"><h2>Episodes</h2></div>
        <% if (totalSeasons > 1) { %>
        <div class="season-tabs">
          <% for (let s = 1; s <= totalSeasons; s++) { %>
          <a href="?season=<%= s %>&ep=1" class="season-tab <%= s === currentSeason ? 'active' : '' %>">Season <%= s %></a>
          <% } %>
        </div>
        <% } %>
        <% episodes.forEach(e => { %>
        <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= e.number %>" class="episode-card <%= e.number === ep ? 'active' : '' %>">
          <div class="episode-thumb">
            <img src="<%= item.poster %>" alt="<%= e.title %>" loading="lazy">
            <span class="ep-num">E<%= e.number %></span>
            <% if (e.number === ep) { %><span class="ep-now">NOW</span><% } %>
          </div>
          <div class="episode-info">
            <h4><%= e.title %></h4>
            <p><%= e.description %></p>
            <span class="ep-duration"><%= e.duration %></span>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>

      <% if (related.length > 0) { %>
      <div class="recommended-section">
        <div class="episodes-header"><h2>More Like This</h2></div>
        <div class="rec-scroll">
          <% related.forEach(r => { %>
          <a href="/<%= type === 'movie' ? 'movies' : 'series' %>/<%= r.id %>" class="rec-card">
            <div class="rec-thumb">
              <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
              <div class="rec-play"><svg width="28" height="28" viewBox="0 0 24 24" fill="white" opacity="0.9"><path d="M8 5v14l11-7z"/></svg></div>
            </div>
            <div class="rec-info"><h4><%= r.title %></h4><p>&#9733; <%= r.rating %> &bull; <%= r.genre %></p></div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>

      <% if (trending.length > 0) { %>
      <div class="recommended-section" style="border-top: 1px solid #1a1a1a;">
        <div class="episodes-header"><h2>Trending Now</h2></div>
        <div class="rec-scroll">
          <% trending.forEach(t => { %>
          <a href="/<%= t.seasons ? 'series' : 'movies' %>/<%= t.id %>" class="rec-card">
            <div class="rec-thumb">
              <img src="<%= t.poster %>" alt="<%= t.title %>" loading="lazy">
              <div class="rec-play"><svg width="28" height="28" viewBox="0 0 24 24" fill="white" opacity="0.9"><path d="M8 5v14l11-7z"/></svg></div>
            </div>
            <div class="rec-info"><h4><%= t.title %></h4><p>&#9733; <%= t.rating %> &bull; <%= t.genre %></p></div>
          </a>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <div class="player-right">
      <div class="player-right-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        Up Next
      </div>
      <% if (episodes.length > 0) { %>
        <% const nextEp = episodes.find(e => e.number === ep + 1); %>
        <% if (nextEp) { %>
        <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= nextEp.number %>" class="episode-card" style="margin-bottom: 12px;">
          <div class="episode-thumb" style="width:120px;height:68px;">
            <img src="<%= item.poster %>" alt="<%= nextEp.title %>" loading="lazy">
            <span class="ep-num">E<%= nextEp.number %></span>
          </div>
          <div class="episode-info"><h4><%= nextEp.title %></h4><p><%= nextEp.duration %></p></div>
        </a>
        <% } %>
        <% episodes.filter(e => e.number > ep).slice(1, 6).forEach(e => { %>
        <a href="/watch/<%= type %>/<%= item.id %>?ep=<%= e.number %>" class="episode-card">
          <div class="episode-thumb" style="width:120px;height:68px;">
            <img src="<%= item.poster %>" alt="<%= e.title %>" loading="lazy">
            <span class="ep-num">E<%= e.number %></span>
          </div>
          <div class="episode-info"><h4><%= e.title %></h4><p><%= e.duration %></p></div>
        </a>
        <% }) %>
      <% } else { %>
        <% related.slice(0, 6).forEach(r => { %>
        <a href="/watch/<%= type %>/<%= r.id %>" class="episode-card">
          <div class="episode-thumb" style="width:120px;height:68px;">
            <img src="<%= r.poster %>" alt="<%= r.title %>" loading="lazy">
          </div>
          <div class="episode-info"><h4><%= r.title %></h4><p>&#9733; <%= r.rating %></p></div>
        </a>
        <% }) %>
      <% } %>
    </div>
  </div>
</main>

